		form Quotation_Line_Items
		{
			displayname = "Quotation Line Items"
			success message = "Rfq Line Item Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Product_Name
			(
				type = picklist	
