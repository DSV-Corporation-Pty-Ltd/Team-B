			Populate_RFQ_Data as "Populate RFQ Data"
			{
				type =  form
				form = Quotation

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											getLogisticData1 = Logistic_Master[Email == zoho.loginuserid];
										if(getLogisticData1.count() > 0)
										{
											input.Transporter_Name = getLogisticData1.ID;
										}
										checkCond = false;
										getRFQreport = RFQ[ID == input.RFQ];
										if(getRFQreport.count() > 0)
										{
											tranList = getRFQreport.Logistic_List.toList();
											if(tranList.contains(input.Transporter_Name) == true)
											{
												checkCond = true;
											}
										}
										getRFQQuote = Quotation[RFQ == input.RFQ];
										if(getRFQQuote.count() > 0 && checkCond == true)
										{
											openUrl("#Form:Quotation_Alert1?zc_BgClr=#34ebd2&zc_Header=false","popup window","height=154px,width=410px");
											input.CNF_Name = null;
											input.Transporter_Name = null;
										}
										else
										{
											getRFQData = RFQ[ID == input.RFQ];
											if(getRFQData.count() > 0)
											{
												input.CNF_Name = getRFQData.CNF_Name;
												input.Location_Type = getRFQData.Type_field;
												input.To = input.RFQ.To;
												input.From = input.RFQ.From;
												if(getRFQData.Line_Items.isEmpty() == false)
												{
													for each  items in getRFQData.Line_Items
													{
														rowData = Quotation.Line_Items();
														rowData.Product_Name=items.Product_Name;
														rowData.Product_Code=items.Product_Code;
														rowData.SKU=items.SKU;
														rowData.Technical_Name=items.Technical_Name;
														rowData.Gross_Weight=items.Gross_Weight;
														rowData.Nos_of_Box=items.No_of_Box;
														rowData.Total_Gross_Weight=items.Total_Gross_Weight;
														rowData.Quantity=items.Requested_Quantity;
														rowcoll = Collection();
														rowcoll.insert(rowData);
														input.Line_Items.insert(rowcoll);
													}
												}
											}
										}
										hide Quotation_No;
										disable RFQ;
										disable Status;
										disable CNF_Name;
										disable Transporter_Name;
										disable Billing_State;
										disable Billing_City;
										disable Billing_Code;
										disable Billing_Street;
										disable Billing_Country;
										disable To;
										disable Location_Type;
										disable From;
										disable Line_Items.Product_Name;
										disable Line_Items.Quantity;
										hide Line_Items.TotalFreight;
										disable Line_Items.Product_Code;
										disable Line_Items.SKU;
										disable Line_Items.Technical_Name;
										disable IGST_Val;
										disable CGST_Val;
										disable Grand_Total;
										disable Sub_Total;
										disable Tax_Amount;
						)
					}
				}

			}
