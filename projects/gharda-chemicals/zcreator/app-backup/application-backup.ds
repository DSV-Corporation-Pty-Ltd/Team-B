				{
					actions 
					{
						custom deluge script
						(
											if(input.PO_Date.isNull() == false && input.Due_Date.isNull() == false)
										{
											if(input.PO_Date > input.Due_Date)
											{
												alert "PO Date should be not be greater than due date";
												input.PO_Date = null;
											}
											if(input.PO_Date < zoho.currentdate)
											{
												alert "PO Date should not be past date";
												input.PO_Date = null;
											}
										}
						)
					}
				}

			}
