			on_the_row_add as "on the row add"
			{
				type =  form
				form = RFQ

				record event = on add or edit

				on add row of Line_Items
				{
					actions 
					{
						custom deluge script
						(
											getBrandList = Product_Master[ID != 0 && Brand_Name != null && Product_Type == "FERT"].Brand_Name.getAll();
										getBrands = getBrandList.distinct();
										getBrList = List();
										if(getBrands.isEmpty() == false)
										{
											for each  brand in getBrands
											{
												getBr = Product_Master[Brand_Name == brand && Product_Type == "FERT" && For_UAT == true];
												if(getBr.count() > 0)
												{
													// 			if(getBr.Product_Code.startsWith("FG") == true)
													// 			{
													getBrList.add(getBr.ID);
													//}
												}
											}
										}
										for each  items in input.Line_Items
										{
											items.Product_Name:ui.add(getBrList);
											items.Product_Name=items.Product_Name;
										}
										emptytList = List();
										row.SKU:ui.add(emptytList);
						)
					}
				}

			}
			on_the_user_in_put_of_sku as "on the user in put of sku"
			{
				type =  form
				form = RFQ

				record event = on add or edit

				on user input of Line_Items.SKU
				{
					actions 
					{
						custom deluge script
						(
											getProData = Product_Master[ID == row.SKU];
										if(getProData.count() > 0)
										{
											row.Product_Code=getProData.Product_Code;
											row.Technical_Name=getProData.Full_Technical_Name;
											row.Gross_Weight=getProData.Gross_Weight;
											// 	row.Nos_in_One_Box=getProData.Nos_in_One_Box;
										}
										duplicateFound = false;
										currentProduct = row.Product_Name;
										currentSKU = row.SKU;
										for each  lineItem in input.Line_Items
										{
											if(lineItem != row)
											{
												if(lineItem.Product_Name == currentProduct && lineItem.SKU == currentSKU)
												{
													duplicateFound = true;
													break;
												}
											}
										}
										if(duplicateFound)
										{
											alert "This product with same SKU is already added. Please increase the quantity in the existing row.";
											row.Product_Name=null;
											row.SKU=null;
											row.Product_Code=null;
											row.Technical_Name=null;
											row.Requested_Quantity=null;
										}
						)
					}
				}

			}
