		list Distributor_Invoice
		{
			displayName = "Invoices"
			show all rows from Invoice  [Distributor_Name.Email == zoho.loginuserid]  
			(
				Invoice_Date as "Invoice Date"
				Distributor_Name as "Distributor Name"
				Email
				Status
				Due_Date as "Due Date"
				custom action "View Invoice"
				(
	  			workflow = View_Invoice
				show action in view header = true
				show action in edit record menu = true
				column header = "View Invoice"
				)
				Invoice_Number as "Invoice Number"
				Subtotal
				Tax_Amount as "Tax Amount"
				GST as "CGST"
				IGST
				Grand_Total as "Grand Total"
				SAPID
				custom action "Pay Now"
				(
	  			workflow = Pay_Now
				show action in edit record menu = true
				column header = "Pay Now"
				condition = (Status == "Open")
				confirmation before execution
				(
					message for individual record = "Execute the Pay Now action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				ID
				SGST
			)
			custom actions
			(
				"Download PDF"
				(
	  			workflow = Download_Button
				show action in view header = true
				show action in edit record menu = true
				)
				"Create Return"
				(
	  			workflow = Create_Return1
				show action in edit record menu = true
				condition = (Return_Done == false)
				)
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#FFFFFF'\n    borderWidth = '0px'\n\n	  value = 'Invoice_Number'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '17px'\n\n		width = '100%'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#4E96F4'\n    borderWidth = '0px'\n\n	  value = 'Email'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '28'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Distributor_Name'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#2D3C4D'\n    borderWidth = '0px'\n\n	  value = 'Invoice_Date'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr><pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '0px'\n	paddingLeft = '17px'\n	paddingRight = '17px'\n	paddingBottom = '17px'\n	bgColor = 'transparent'\n\n		width = '100%'\n		hAlign = 'center'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#000000'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '27'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#000000'\n    borderWidth = '0px'\n\n	  value = 'Grand_Total'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
