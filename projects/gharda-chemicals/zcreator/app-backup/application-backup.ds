										htmlMessage = "<html>" + "<body style='font-family:Arial,sans-serif;background-color:#f9f9f9;padding:20px;'>" + "<div style='max-width:500px;margin:auto;background:#ffffff;border-radius:10px;padding:20px;box-shadow:0 2px 5px rgba(0,0,0,0.1);'>" + "<h2 style='color:#2563eb;text-align:center;'>OTP Verification</h2>" + "<p>Dear " + DisName + ",</p>" + "<p>Your One-Time Password (OTP) for GRN Delivery verification is:</p>" + "<div style='text-align:center;font-size:32px;font-weight:bold;color:#2563eb;margin:20px 0;'>" + rannum.toString() + "</div>" + "" + "<p>If you did not request this, please ignore this email.</p>" + "<hr style='border:none;border-top:1px solid #eee;'>" + "<p style='font-size:12px;color:#888;text-align:center;'>This is an automated email. Please do not reply.</p>" + "</div>" + "</body>" + "</html>";
