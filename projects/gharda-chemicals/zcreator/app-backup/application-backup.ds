				 map FA.getSovereignRoute(string startLng, string startLat, string endLng, string endLat, string profile)
                 {
                 	resp = Map();
                 	sLng = ifnull(startLng,"").trim();
                 	sLat = ifnull(startLat,"").trim();
                 	eLng = ifnull(endLng,"").trim();
                 	eLat = ifnull(endLat,"").trim();
                 	profileVal = ifnull(profile,"bike").trim();
                 	if(sLng == "" || sLat == "" || eLng == "" || eLat == "")
                 	{
                 		resp.put("code",4000);
                 		resp.put("message","start/end coordinates missing");
                 		return resp;
                 	}
                 	tokenResp = thisapp.FA.getSovereignAccessToken();
                 	if(tokenResp.get("success") != true)
                 	{
                 		resp.put("code",5001);
                 		resp.put("message","Sovereign auth failed");
                 		resp.put("result",tokenResp);
                 		return resp;
                 	}
                 	cfg = Sovereign_Config[Is_Active == true];
                 	baseUrl = ifnull(cfg.Base_URL,"").trim();
                 	apiKey = ifnull(cfg.API_KEY,"").trim();
                 	token = ifnull(tokenResp.get("access_token"),"").trim();
                 	routeResp = invokeurl
                 	[
                 		url :baseUrl + "/api/route/" + profileVal + "/" + sLng + "," + sLat + ";" + eLng + "," + eLat + "?alternatives=false&steps=false&overview=simplified"
                 		type :GET
                 		headers:{"Accept":"application/json","Authorization":"Bearer " + token,"X-Sovereign-Api-Key":apiKey}
                 	];
                 	resp.put("code",3000);
                 	resp.put("message","Route fetched");
                 	resp.put("result",routeResp);
                 	return resp;
                 }
				 map FA.getTodayJourneyStatus(string loginUserEmail)
                 {
                 	resp = Map();
                 	emailVal = ifnull(loginUserEmail,"").trim();
                 	resp.put("code",3000);
                 	resp.put("dayStatus","NOT_STARTED");
                 	resp.put("canCheckin",true);
                 	resp.put("attendanceId","");
                 	resp.put("message","No journey found for today");
                 	if(emailVal == "")
                 	{
                 		resp.put("code",4000);
                 		resp.put("message","loginUserEmail is required");
                 		return resp;
                 	}
                 	latestId = 0;
                 	latestStatus = "";
                 	latestVillage = "";
                 	latestSelectedJson = "";
                 	latestDriver = "";
                 	latestTracker = "";
                 	latestSession = "";
                 	for each  rec in Attendance_Module[Email == emailVal]
                 	{
                 		if(rec.Check_In_Time != null && rec.Check_In_Time.toDate() == zoho.currentdate)
                 		{
                 			if(rec.ID > latestId)
                 			{
                 				latestId = rec.ID;
                 				latestStatus = ifnull(rec.Journey_Status,"");
                 				latestVillage = ifnull(rec.Selected_Village,"");
                 				latestSelectedJson = ifnull(rec.Selected_Distributors_JSON,"");
                 				latestDriver = ifnull(rec.Sovereign_Driver_Code,"");
                 				latestTracker = ifnull(rec.Sovereign_Tracker_Id,"");
                 				latestSession = ifnull(rec.Journey_Session,"");
                 			}
                 		}
                 	}
                 	if(latestId > 0)
                 	{
                 		resp.put("attendanceId",latestId.toString());
                 		resp.put("selectedVillage",latestVillage);
                 		resp.put("selectedDistributorsJson",latestSelectedJson);
                 		resp.put("driver",latestDriver);
                 		resp.put("trackerId",latestTracker);
                 		resp.put("session",latestSession);
                 		if(latestStatus == "Completed")
                 		{
                 			resp.put("dayStatus","COMPLETED");
                 			resp.put("canCheckin",false);
                 			resp.put("message","You have already completed today's journey.");
                 		}
                 		else if(latestStatus == "In Progress" || latestStatus == "Checked In")
                 		{
                 			resp.put("dayStatus","IN_PROGRESS");
                 			resp.put("canCheckin",false);
                 			resp.put("message","Today's journey is already in progress.");
                 		}
                 		else
                 		{
                 			resp.put("dayStatus","NOT_STARTED");
                 			resp.put("canCheckin",true);
                 		}
                 	}
                 	return resp;
                 }
				 list FA.getVillageList(string loginUserEmail)
                 {
                 	villageList = List();
                 	seenNames = List();
                 	allRecords = thisapp.CropCalendar.FetchLiquidationAgentData(loginUserEmail);
                 	if(allRecords != null && allRecords.isEmpty() == false)
                 	{
                 		for each  rec in allRecords
                 		{
                 			villageObj = rec.get("Village");
                 			// <-- REPLACE if actual field differs
                 			if(villageObj != null)
                 			{
                 				villageId = ifnull(villageObj.get("id"),"");
                 				villageName = ifnull(villageObj.get("name"),ifnull(villageObj.get("Name"),""));
                 				if(villageName != "" && seenNames.contains(villageName) == false)
                 				{
                 					vMap = Map();
                 					vMap.put("villageID",villageId);
                 					vMap.put("villageName",villageName);
                 					villageList.add(vMap);
                 					seenNames.add(villageName);
                 				}
                 			}
                 		}
                 	}
                 	return villageList;
                 }
				 map FA.pushSovereignTracking(string attendanceId, string pointsJson, string pointCount)
                 {
                 	resp = Map();
                 	attIdText = ifnull(attendanceId,"").trim();
                 	pointsRaw = ifnull(pointsJson,"").trim();
                 	countVal = 0;
                 	if(pointCount != null && pointCount.trim() != "")
                 	{
                 		countVal = pointCount.toLong();
                 	}
                 	if(attIdText == "" || pointsRaw == "")
                 	{
                 		resp.put("code",4000);
                 		resp.put("message","attendanceId or pointsJson missing");
                 		return resp;
                 	}
                 	attId = attIdText.toLong();
                 	getAtt = Attendance_Module[ID == attId];
                 	if(getAtt.count() == 0)
                 	{
                 		resp.put("code",4004);
                 		resp.put("message","Attendance record not found");
                 		return resp;
                 	}
                 	tokenResp = thisapp.FA.getSovereignAccessToken();
                 	if(tokenResp.get("success") != true)
                 	{
                 		getAtt.Last_Push_Response=tokenResp.toString();
                 		resp.put("code",5001);
                 		resp.put("message","Sovereign auth failed");
                 		resp.put("result",tokenResp);
                 		return resp;
                 	}
                 	cfg = Sovereign_Config[Is_Active == true];
                 	baseUrl = ifnull(cfg.Base_URL,"").trim();
                 	apiKey = ifnull(cfg.API_KEY,"").trim();
                 	// field link name check kar lo
                 	token = ifnull(tokenResp.get("access_token"),"").trim();
                 	pushResp = invokeurl
                 	[
                 		url :baseUrl + "/api/app-base/vdms-tracking/push"
                 		type :POST
                 		body:pointsRaw
                 		headers:{"Authorization":"Bearer " + token,"X-Sovereign-Api-Key":apiKey,"Content-Type":"application/json"}
                 	];
                 	getAtt.Sovereign_Push_Count=ifnull(getAtt.Sovereign_Push_Count,0) + countVal;
                 	getAtt.Last_Push_Response=pushResp.toString();
                 	resp.put("code",3000);
                 	resp.put("message","Tracking pushed successfully");
                 	resp.put("result",pushResp);
                 	return resp;
                 }
				 list FA.saveLiquidationVisit(string checkInTime, string checkOutTime, string totalDistanceKm, string loginUserEmail)
                 {
                 	respList = List();
                 	resp = Map();
                 	dist = 0.0;
                 	emailVal = "";
                 	checkInDT = null;
                 	checkOutDT = null;
                 	if(totalDistanceKm != null && totalDistanceKm.trim() != "")
                 	{
                 		dist = totalDistanceKm.toDecimal();
                 	}
                 	if(checkInTime != null && checkInTime.trim() != "")
                 	{
                 		checkInDT = checkInTime.trim().toDateTime("dd-MMM-yyyy HH:mm:ss");
                 	}
                 	if(checkOutTime != null && checkOutTime.trim() != "")
                 	{
                 		checkOutDT = checkOutTime.trim().toDateTime("dd-MMM-yyyy HH:mm:ss");
                 	}
                 	if(loginUserEmail != null && loginUserEmail.trim() != "")
                 	{
                 		emailVal = loginUserEmail.trim();
                 	}
                 	else
                 	{
                 		emailVal = zoho.loginuserid;
                 	}
                 	resp.put("emailPassed",emailVal);
                 	resp.put("zoho_loginuser",zoho.loginuser);
                 	resp.put("zoho_loginuserid",zoho.loginuserid);
                 	getLiquiData = Liquidation_Agent[Email == emailVal];
                 	if(getLiquiData.count() > 0)
                 	{
                 		newRec = insert into Attendance_Module
                 		[
                 			Check_In_Time=checkInDT
                 			Check_Out_Time=checkOutDT
                 			Total_Distance_KM=dist
                 			Added_User=zoho.loginuser
                 			Email=getLiquiData.Email
                 			Liquidation_Agent_Name=getLiquiData.ID
                 		];
                 		resp.put("code",3000);
                 		resp.put("message","inserted");
                 		resp.put("id",newRec.toString());
                 		resp.put("agentEmail",getLiquiData.Email);
                 		resp.put("agentId",getLiquiData.ID.toString());
                 	}
                 	else
                 	{
                 		resp.put("code",4000);
                 		resp.put("message","No Liquidation Agent found for email: " + emailVal);
                 	}
                 	respList.add(resp);
                 	return respList;
                 }
				 map FA.startLiveJourney(string loginUserEmail, string villageName, string selectedDistributorsJson)
                 {
                 	resp = Map();
                 	emailVal = ifnull(loginUserEmail,"").trim();
                 	villageVal = ifnull(villageName,"").trim();
                 	selectedJson = ifnull(selectedDistributorsJson,"[]");
                 	if(emailVal == "")
                 	{
                 		resp.put("code",4000);
                 		resp.put("message","Login user email is required");
                 		return resp;
                 	}
                 	todayStatus = thisapp.FA.getTodayJourneyStatus(emailVal);
                 	if(todayStatus.get("dayStatus") == "COMPLETED")
                 	{
                 		resp.put("code",4005);
                 		resp.put("message","You have already completed today's journey.");
                 		return resp;
                 	}
                 	if(todayStatus.get("dayStatus") == "IN_PROGRESS")
                 	{
                 		resp.put("code",4006);
                 		resp.put("message","Today's journey is already in progress.");
                 		return resp;
                 	}
                 	getLiquiData = Liquidation_Agent[Email == emailVal];
                 	if(getLiquiData.count() == 0)
                 	{
                 		resp.put("code",4001);
                 		resp.put("message","No Liquidation Agent found for email: " + emailVal);
                 		return resp;
                 	}
                 	driverCode = ifnull(getLiquiData.Sovereign_Driver_Code,"").trim();
                 	trackerId = ifnull(getLiquiData.Sovereign_Tracker_Id,"").trim();
                 	if(driverCode == "" || trackerId == "")
                 	{
                 		resp.put("code",4002);
                 		resp.put("message","Sovereign driver / tracker mapping missing");
                 		return resp;
                 	}
                 	sessionTs = (zoho.currenttime.toLong() / 1000).round(0);
                 	newRec = insert into Attendance_Module
                 	[
                 		Check_In_Time=zoho.currenttime
                 		Added_User=zoho.loginuser
                 		Email=getLiquiData.Email
                 		Liquidation_Agent_Name=getLiquiData.ID
                 		Journey_Status="In Progress"
                 		Journey_Session=sessionTs.toString()
                 		Sovereign_Driver_Code=driverCode
                 		Sovereign_Tracker_Id=trackerId
                 		Selected_Village=villageVal
                 		Selected_Distributors_JSON=selectedJson
                 		Sovereign_Push_Count=0
                 		Last_Push_Response=""
                 	];
                 	resultMap = Map();
                 	resultMap.put("attendanceId",newRec.toString());
                 	resultMap.put("driver",driverCode);
                 	resultMap.put("trackerId",trackerId);
                 	resultMap.put("session",sessionTs);
                 	resp.put("code",3000);
                 	resp.put("message","Journey started");
                 	resp.put("result",resultMap);
                 	return resp;
                 }
				 list FA.updateAttendanceRecord(string attendanceId, string endTime, string endLatitude, string endLongitude, string totalDistanceKm)
                 {
                 	respList = List();
                 	resp = Map();
                 	attIdText = ifnull(attendanceId,"").trim();
                 	if(attIdText == "")
                 	{
                 		resp.put("code",4000);
                 		resp.put("message","attendanceId is required");
                 		respList.add(resp);
                 		return respList;
                 	}
                 	dist = 0.0;
                 	endLat = 0.0;
                 	endLng = 0.0;
                 	checkOutDT = null;
                 	if(totalDistanceKm != null && totalDistanceKm.trim() != "")
                 	{
                 		dist = totalDistanceKm.toDecimal();
                 	}
                 	if(endLatitude != null && endLatitude.trim() != "")
                 	{
                 		endLat = endLatitude.toDecimal();
                 	}
                 	if(endLongitude != null && endLongitude.trim() != "")
                 	{
                 		endLng = endLongitude.toDecimal();
                 	}
                 	if(endTime != null && endTime.trim() != "")
                 	{
                 		checkOutDT = endTime.trim().toDateTime("dd-MMM-yyyy HH:mm:ss");
                 	}
                 	else
                 	{
                 		checkOutDT = zoho.currenttime;
                 	}
                 	attId = attIdText.toLong();
                 	getAtt = Attendance_Module[ID == attId];
                 	if(getAtt.count() == 0)
                 	{
                 		resp.put("code",4004);
                 		resp.put("message","Attendance record not found for ID: " + attIdText);
                 		respList.add(resp);
                 		return respList;
                 	}
                 	/*
                      * Update using field assignment — same pattern as endLiveJourney.
                      * This correctly updates the existing record, not creates a new one.
                      */
                 	getAtt.Check_Out_Time=checkOutDT;
                 	getAtt.End_Journey_Latitude=endLat.toString();
                 	getAtt.End_Journey_Longitude=endLng.toString();
                 	getAtt.Total_Distance_KM=dist;
                 	getAtt.Status="Completed";
                 	resp.put("code",3000);
                 	resp.put("message","Attendance updated successfully");
                 	resp.put("attendanceId",attIdText);
                 	respList.add(resp);
                 	return respList;
                 }
				 string Image.getImage(string ReportName, string FieldName, string Publishurl, string Profile_Pic)
                 {
                 	imgURL = Profile_Pic.replaceFirst("sharedBy",zoho.adminuser).replaceFirst("appLinkName",zoho.appname).replaceFirst("viewLinkName",ReportName).replaceFirst("fieldName",FieldName).replaceFirst("image/","image/" + Publishurl + "/");
                 	endOfImg = imgURL.indexOf("\" lowqual");
                 	imgURL = imgURL.substring(12,endOfImg);
                 	return imgURL.toString();
                 }
