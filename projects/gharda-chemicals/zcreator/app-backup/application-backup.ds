			send_for_approval as "send for approval"
			{
				type =  functions
				form = Quotation
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						// input.Send_for_approval = true;
										// thisapp.Notifications.QuotationNotificationToCNF(input.ID);
										// Level 1 approvers (parallel)
										level1List = List();
										level1List.add("amiya.pandey@gilgharda.com");
										level1List.add("ravi.pole86@gmail.com");
										level1List.add("sgbodas66@gmail.com");
										// level1List.add("maninder@fristinetech.com");
										// level1List.add("zohotest768@gmail.com");
										// Set initial values
										input.Current_Level = "1";
										input.Status = "Pending";
										input.Level1_Approved = "No";
										// Email content
										message = "<p>Dear Approver,</p>" + "<p>A quotation " + input.Quotation_No + " requires your approval.</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Quotations'>View & Approve</a></p>" + "<p>Thanks</p>";
										// Send to all Level 1 approvers
										for each  email in level1List
										{
											sendmail
											[
												from :zoho.adminuserid
												to :email
												subject :"Quotation " + input.Quotation_No + " Approval - Level 1"
												message :message
											]
										}
					)
					}
				}
			}
