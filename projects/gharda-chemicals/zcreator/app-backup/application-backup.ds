				 void LiquidationCapture.SyncLiquidationCaptureInCRM(int id)
                 {
                 	getLiquidationCaptureData = Liquidation_Capture[ID == id];
                 	//     info getLiquidationCaptureData;
                 	dataMap = Map();
                 	othermap = Map();
                 	if(getLiquidationCaptureData.count() > 0)
                 	{
                 		getProducts = Liquidation_Capture_Line_Items[Liquidation_Capture == id];
                 		//        info getProducts;
                 		if(getProducts.count() > 0)
                 		{
                 			productList = List();
                 			for each  getPro in getProducts
                 			{
                 				productmap = Map();
                 				//searchPro = zoho.crm.searchRecords("Products","Product_Code:equals:" + getPro.Product_Name.Product_Code + "",0,200,othermap,"zohocrm_connection");
                 				searchPro = zoho.crm.searchRecords("Products","Product_Code:equals:" + getPro.Product_Name.Product_Code + "",0,200,othermap,"zoho_oauth_connection");
                 				//                     info searchPro;
                 				if(searchPro.isEmpty() == false)
                 				{
                 					for each  serachpr in searchPro
                 					{
                 						prodid = serachpr.getJSON("id");
                 						productmap.put("Product_Name",prodid);
                 					}
                 					productmap.put("Product_Code",getPro.Product_Name.Product_Code);
                 					productmap.put("Batch_Number",ifnull(getPro.Batch_Number,""));
                 					productmap.put("Quantity",getPro.Quantity);
                 					productmap.put("Liquidate_Quantity",getPro.Liquidate_Quantity);
                 					productList.add(productmap);
                 				}
                 			}
                 			// 						dataMap.put("Product_Line_Items1",productList);
                 		}
                 		getDistributor = getLiquidationCaptureData.Distributor_Name;
                 		//                  info getDistributor;
                 		if(getDistributor != null)
                 		{
                 			getDistributorData = Distributor_Master[ID == getDistributor];
                 			//                       info getDistributorData;
                 			if(getDistributorData.count() > 0)
                 			{
                 				getCRmId = getDistributorData.Account_CRM_record_ID;
                 				//                         info "CRM Id" + getCRmId;
                 				if(getCRmId != "")
                 				{
                 					dataMap.put("Distributor_Name",getCRmId);
                 				}
                 			}
                 		}
                 		getAgent = getLiquidationCaptureData.Liquidation_Agent;
                 		//                  info getAgent;
                 		if(getAgent != null)
                 		{
                 			//searchAgent = zoho.crm.searchRecords("Liquidation_Agent_Master","Creator_record_Id:equals:" + getAgent.toString() + "",0,200,othermap,"zohocrm_connection");
                 			searchAgent = zoho.crm.searchRecords("Liquidation_Agent_Master","Creator_record_Id:equals:" + getAgent.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 			if(searchAgent.isEmpty() == false)
                 			{
                 				getId = searchAgent.getJSON("id");
                 				dataMap.put("Liquidation_Agent",getId.toLong());
                 				emptymap = Map();
                 				//liquidationdata = zoho.crm.getRecordById("Liquidation_Agent_Master",getId.toLong(),emptymap,"zoho_oauth_connection");
                 				liquidationownerid = searchAgent.getJSON("Owner").get("id");
                 				dataMap.put("Owner",liquidationownerid);
                 			}
                 		}
                 		dataMap.put("Email",ifnull(getLiquidationCaptureData.Liquidation_Agent_Email,""));
                 		parsedDate = getLiquidationCaptureData.Date_field.toDateTime("dd-MMM-yyyy HH:mm:ss");
                 		formattedDate = parsedDate.toString("yyyy-MM-dd'T'HH:mm:ssXXX");
                 		dataMap.put("Date",formattedDate);
                 		info dataMap;
                 		//searchLiquidationCapture = zoho.crm.searchRecords("Liquidity_Capture","Creator_record_Id:equals:" + id.toString() + "",0,200,othermap,"zohocrm_connection");
                 		searchLiquidationCapture = zoho.crm.searchRecords("Liquidity_Capture","Creator_record_Id:equals:" + id.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 		if(searchLiquidationCapture.isEmpty() == false)
                 		{
                 			for each  searchdata in searchLiquidationCapture
                 			{
                 				crmLCID = searchdata.get("id");
                 			}
                 			if(crmLCID.isNull() == false)
                 			{
                 				Prod = List();
                 				dataMap.put("Product_Line_Items1",Prod);
                 				//data = zoho.crm.updateRecord("Liquidity_Capture",crmLCID.toLong(),dataMap,othermap,"zohocrm_connection");
                 				data = zoho.crm.updateRecord("Liquidity_Capture",crmLCID.toLong(),dataMap,othermap,"zoho_oauth_connection");
                 				info data;
                 				dataMap.put("Product_Line_Items1",productList);
                 				datamap1 = Map();
                 				datamap1.put("data",{dataMap});
                 				info datamap1;
                 				// 				updateresp = invokeurl
                 				// 				[
                 				// 					url :"https://www.zohoapis.in/crm/v8/Liquidity_Capture/" + crmLCID
                 				// 					type :PUT
                 				// 					parameters:datamap1.toString()
                 				// 					connection:"zohocrm_connection"
                 				// 				];
                 				updateresp = invokeurl
                 				[
                 					url :"https://www.zohoapis.in/crm/v8/Liquidity_Capture/" + crmLCID
                 					type :PUT
                 					parameters:datamap1.toString()
                 					connection:"zoho_oauth_connection"
                 				];
                 				info "updateresp" + updateresp;
                 			}
                 		}
                 		else
                 		{
                 			dataMap.put("Product_Line_Items1",productList);
                 			dataMap.put("Creator_record_Id",id.toString());
                 			datamap1 = Map();
                 			datamap1.put("data",{dataMap});
                 			// 			insertresp = invokeurl
                 			// 			[
                 			// 				url :"https://www.zohoapis.in/crm/v8/Liquidity_Capture"
                 			// 				type :POST
                 			// 				parameters:datamap1.toString()
                 			// 				connection:"zohocrm_connection"
                 			// 			];
                 			insertresp = invokeurl
                 			[
                 				url :"https://www.zohoapis.in/crm/v8/Liquidity_Capture"
                 				type :POST
                 				parameters:datamap1.toString()
                 				connection:"zoho_oauth_connection"
                 			];
                 			craetemsg = insertresp.get("data").getJson("message");
                 			if(craetemsg == "record added")
                 			{
                 				details = insertresp.get("data").getJson("details");
                 				getLiquidationCaptureData.zoho_crm_id=details.get("id").toString();
                 			}
                 		}
                 	}
                 }
				 void Meetings.CreateMeeting(int MeetingID)
                 {
                 	getMeetData = Meeting[ID == MeetingID];
                 	if(getMeetData.count() > 0)
                 	{
                 		meetingDetails = Map();
                 		othermap = Map();
                 		//SearchMeet = zoho.crm.searchRecords("Liquidation_Agent_Master","(Email:starts_with:" + getMeetData.Liquidation_Agent_Email.Email.toString() + ")",0,200,othermap,"zohocrm_connection");
                 		SearchMeet = zoho.crm.searchRecords("Liquidation_Agent_Master","(Email:starts_with:" + getMeetData.Liquidation_Agent_Email.Email.toString() + ")",0,200,othermap,"zoho_oauth_connection");
                 		LAID = null;
                 		if(SearchMeet.isEmpty() == false)
                 		{
                 			for each  SearchData in SearchMeet
                 			{
                 				LAID = SearchData.get("id");
                 				liquidationownerid = SearchData.getJSON("Owner").get("id");
                 				meetingDetails.put("Owner",liquidationownerid);
                 			}
                 		}
                 		meetingDetails.put("$se_module","Liquidation_Agent_Master");
                 		meetingDetails.put("What_Id",LAID);
                 		meetingDetails.put("Event_Title",getMeetData.Title);
                 		meetingDetails.put("Description",getMeetData.Description);
                 		meetingDetails.put("Start_DateTime",getMeetData.From.toString("yyyy-MM-dd'T'HH:mm:ss"));
                 		meetingDetails.put("End_DateTime",getMeetData.To.toString("yyyy-MM-dd'T'HH:mm:ss"));
                 		meetingDetails.put("Venue","Offline Meeting");
                 		participantsList = List();
                 		if(getMeetData.Sales_Officer.isNull() == false)
                 		{
                 			meetingDetails.put("Owner",ifnull(getMeetData.Sales_Officer.UserID.toLong(),null));
                 			participant1 = Map();
                 			participant1.put("type","user");
                 			participant1.put("participant",ifnull(getMeetData.Sales_Officer.UserID.toLong(),null));
                 			participantsList.add(participant1);
                 			meetingDetails.put("Participants",participantsList);
                 		}
                 		else
                 		{
                 			meetingDetails.put("Owner",1000823000000415001);
                 		}
                 		if(getMeetData.Distributor.isNull() == false)
                 		{
                 			accid = getMeetData.Distributor.Account_CRM_record_ID;
                 			//getrelatedData = zoho.crm.getRelatedRecords("Contacts","Accounts",accid.toLong(),0,200,othermap,"zohocrm_connection");
                 			getrelatedData = zoho.crm.getRelatedRecords("Contacts","Accounts",accid.toLong(),0,200,othermap,"zoho_oauth_connection");
                 			if(getrelatedData.isEmpty() == false)
                 			{
                 				participant2 = Map();
                 				participant2.put("type","contact");
                 				participant2.put("participant",ifnull(getrelatedData.getJson("id").toLong(),null));
                 				participantsList.add(participant2);
                 			}
                 		}
                 		meetingDetails.put("Participants",participantsList);
                 		meetingDetails.put("CreatorID",MeetingID.toString());
                 		//createResponse = zoho.crm.createRecord("Events",meetingDetails,othermap,"zohocrm_connection");
                 		createResponse = zoho.crm.createRecord("Events",meetingDetails,othermap,"zoho_oauth_connection");
                 		getMeetData.Response_of_the_meeting=createResponse.toString();
                 		if(createResponse.isEmpty() == false)
                 		{
                 			getMeetData.CRMID=createResponse.get("id").toString();
                 		}
                 	}
                 }
				 void Notifications.LeaveRequestNotification(int LRID)
                 {
                 	leaveData = Leave_Request[ID == LRID.toLong()];
                 	if(leaveData.count() > 0)
                 	{
                 		liqAgentData = leaveData.Liquidation_Agent_Name;
                 		LiqRegion = null;
                 		Liquidationdata = Liquidation_Agent[ID == leaveData.Liquidation_Agent_Name];
                 		if(Liquidationdata.count() > 0)
                 		{
                 			LiqRegion = Liquidationdata.Region;
                 		}
                 		if(LiqRegion.isNull() == false)
                 		{
                 			getDistData = Users[Region == LiqRegion];
                 			if(getDistData.count() > 0)
                 			{
                 				Participants = List();
                 				Participants.add(getDistData.Email);
                 				html = "<div style='font-family:Arial, sans-serif; color:#333; font-size:15px; line-height:1.6;'>" + "<p>Dear " + ifnull(getDistData.First_Name,"Distributor") + ",</p>" + "<p>I have applied for <strong>" + ifnull(leaveData.Leave_Type.Leave_Type,"-") + "</strong> leave from <strong>" + ifnull(leaveData.From.toString("dd-MMM-yyyy"),"-") + "</strong> to <strong>" + ifnull(leaveData.To.toString("dd-MMM-yyyy"),"-") + "</strong> (" + leaveData.Total_Days + " day(s)) due to " + ifnull(leaveData.Reason,"personal reasons") + ".</p>" + "<p>Thank you for your understanding.</p>" + "<p>Thanks & Regards,<br><strong>" + ifnull(leaveData.Liquidation_Agent_Name.Liquidation_Agent_Name,"Field Agent") + "</strong></p>" + "</div>";
                 				if(Liquidationdata.Email.isEmpty() == false)
                 				{
                 					sendmail
                 					[
                 						from :Liquidationdata.Email
                 						to :Participants
                 						subject :"Leave Request from " + ifnull(leaveData.Liquidation_Agent_Name.Liquidation_Agent_Name,"")
                 						message :html.toString()
                 					]
                 				}
                 			}
                 		}
                 	}
                 }
