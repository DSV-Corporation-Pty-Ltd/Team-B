			on_the_suer_input_of_expe as "on the suer input of expense cat subform"
			{
				type =  form
				form = Expense_Master

				record event = on add or edit

				on user input of Expenses.Expense_Category
				{
					actions 
					{
						custom deluge script
						(
											getexpensecat = Expense_Category[Category == row.Expense_Category.Category];
										if(getexpensecat.count() > 0)
										{
											row.Expense_Type=getexpensecat.ID;
											row.GL_Code=getexpensecat.GL_Code;
											exptype = row.Expense_Type.Expense_Type;
											// 	show row.Quantity;
											if(exptype.toString() == "VARIABLE")
											{
												enable row.Quantity;
											}
										}
										getExpenseTxData = Expense_Tax_Master[CNF_Name == input.CNF_Name && Expense_Category == row.Expense_Category];
										hide CSGST;
										hide CGST;
										hide SGST;
										hide RCM_CGST;
										hide RCM;
										hide IGST;
										hide RCM_IGST;
										if(getExpenseTxData.count() > 0)
										{
											if(getExpenseTxData.CGST != "NO" && getExpenseTxData.CGST != "")
											{
												show row.CGST;
												row.CGST=getExpenseTxData.CGST + " %";
											}
											if(getExpenseTxData.SGST != "NO" && getExpenseTxData.SGST != "")
											{
												show row.SGST;
												row.SGST=getExpenseTxData.SGST + " %";
											}
											if(getExpenseTxData.CSGST != "NO" && getExpenseTxData.CSGST != "")
											{
												show row.CSGST;
												row.CSGST=getExpenseTxData.CSGST + " %";
											}
											if(getExpenseTxData.RCM_CGST != "NO" && getExpenseTxData.RCM_CGST != "")
											{
												show row.RCM_CGST;
												row.RCM_CGST=getExpenseTxData.RCM_CGST + " %";
											}
											if(getExpenseTxData.RCM_IGST != "NO" && getExpenseTxData.RCM_IGST != "")
											{
												show row.RCM_IGST;
												row.RCM_IGST=getExpenseTxData.RCM_IGST + " %";
											}
											if(getExpenseTxData.RCM != "NO" && getExpenseTxData.RCM != "")
											{
												show row.RCM;
												row.RCM=getExpenseTxData.RCM + " %";
											}
											if(getExpenseTxData.IGST != "NO" && getExpenseTxData.IGST != "")
											{
												show row.IGST;
												row.IGST=getExpenseTxData.IGST + " %";
											}
											row.Tax=ifnull(getExpenseTxData.Tax,0);
											if(row.Tax != null && row.Tax > 0)
											{
												row.Tax_Amount=ifnull(row.Tax,0) / 100 * ifnull(row.Amount,0);
												row.Total=ifnull(row.Amount,0) + ifnull(row.Tax_Amount,0);
											}
											else
											{
												//	row.Tax_Amount = 0;
												row.Total=ifnull(row.Amount,0);
											}
										}
										else
										{
											row.Tax=0;
											row.Tax_Amount=0;
											row.Total=0;
										}
										if(row.Tax_Amount < 1)
										{
											row.Tax_Amount=0;
										}
						)
					}
				}

			}
			on_the_user_input_of_amou2 as "on the user input of amount"
			{
				type =  form
				form = Expense_Master

				record event = on add or edit

				on user input of Expenses.Amount
				{
					actions 
					{
						custom deluge script
						(
											if(row.Tax != null && row.Tax > 0)
										{
											row.Tax_Amount=row.Tax / 100 * row.Amount;
											row.Total=ifnull(row.Amount,0) + ifnull(row.Tax_Amount,0);
										}
										else
										{
											row.Total=ifnull(row.Amount,0);
										}
										GrantTotal = 0;
										totalTax = 0;
										if(input.Expenses.isEmpty() == false)
										{
											for each  exp in input.Expenses
											{
												GrantTotal = GrantTotal + ifnull(exp.Total,0);
												totalTax = totalTax + ifnull(exp.Tax_Amount,0);
											}
											input.Grand_Total = ifnull(GrantTotal,0);
											input.Total_Tax_Amount = ifnull(totalTax,0);
										}
						)
					}
				}

			}
			on_the_user_input_of_expe1 as "on the user input of expenses"
			{
				type =  form
				form = Expense_Master

				record event = on add or edit

				on add row of Expenses
				{
					actions 
					{
						custom deluge script
						(
											categories = Expense_Category[ID != 0].Category.getAll();
										if(categories.size() > 0)
										{
											distinctCat = categories.distinct();
											finalList = List();
											for each  cat in distinctCat
											{
												rec = Expense_Category[Category == cat];
												if(rec != null)
												{
													finalList.add(rec.ID);
												}
											}
											row.Expense_Category:ui.add(finalList);
											row.Expense_Category=row.Expense_Category;
										}
						)
					}
				}

			}
			on_the_deletion_of_row as "on the deletion of row"
			{
				type =  form
				form = Expense_Master

				record event = on add or edit

				on delete row of Expenses
				{
					actions 
					{
						custom deluge script
						(
											GrantTotal = 0;
										totalTax = 0;
										if(input.Expenses.isEmpty() == false)
										{
											for each  exp in input.Expenses
											{
												GrantTotal = GrantTotal + ifnull(exp.Total,0);
												totalTax = totalTax + ifnull(exp.Tax_Amount,0);
											}
											input.Grand_Total = ifnull(GrantTotal,0) - ifnull(row.Total,0);
											input.Total_Tax_Amount = ifnull(totalTax,0) - ifnull(row.Tax_Amount,0);
										}
						)
					}
				}

			}
