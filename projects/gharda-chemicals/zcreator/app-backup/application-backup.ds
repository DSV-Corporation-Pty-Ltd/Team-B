			Populate_sales_order_data as "Populate sales order data"
			{
				type =  form
				form = Dispatch

				record event = on add or edit

				on user input of Sales_Order
				{
					actions 
					{
						custom deluge script
						(
											getOrderData = Order_Management[ID == input.Sales_Order];
										if(getOrderData.count() > 0)
										{
											input.Distributor = getOrderData.Distributor_Name;
											input.Billing_State = getOrderData.Billing_State;
											input.Billing_City = getOrderData.Billing_City;
											input.Billing_Code = getOrderData.Billing_Code;
											input.Billing_Street = getOrderData.Billing_Street;
											input.Billing_Country = getOrderData.Billing_Country;
											input.Shipping_Street = getOrderData.Shipping_Street;
											input.Shipping_Code = getOrderData.Shipping_Code;
											input.Shipping_Country = getOrderData.Shipping_Country;
											input.Shipping_Code = getOrderData.Shipping_Code;
											input.Shipping_City = getOrderData.Shipping_City;
											clear Line_Items;
											if(getOrderData.Line_Items.isEmpty() == false)
											{
												getdispatchData = Dispatch[Sales_Order == input.Sales_Order];
												for each  items in getOrderData.Line_Items
												{
													if(getdispatchData.count() <= 0)
													{
														rowData = Dispatch.Line_Items();
														rowData.Product_Name=items.Product_Name;
														rowData.SKU=items.SKU;
														rowData.Batch_Number=items.Batch_Number;
														rowData.Price=items.Discount_Price;
														rowData.Order_Quantity=items.Quantity;
														rowData.SO_Line_Item_ID=items.ID;
														rowcoll = Collection();
														rowcoll.insert(rowData);
														input.Line_Items.insert(rowcoll);
													}
													else if(getdispatchData.count() > 0 && items.Balance_Quantity > 0)
													{
														rowData = Dispatch.Line_Items();
														rowData.Product_Name=items.Product_Name;
														rowData.SKU=items.SKU;
														rowData.Batch_Number=items.Batch_Number;
														rowData.Price=items.Discount_Price;
														rowData.Order_Quantity=items.Quantity;
														rowData.SO_Line_Item_ID=items.ID;
														rowcoll = Collection();
														rowcoll.insert(rowData);
														input.Line_Items.insert(rowcoll);
													}
												}
											}
										}
						)
					}
				}

			}
