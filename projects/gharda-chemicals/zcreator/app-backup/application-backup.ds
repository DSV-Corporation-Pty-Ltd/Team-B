				 map OTP.ResendOTP(string mobile)
                 {
                 	APIKey = thisapp.variables.MSG91_API_Key;
                 	url = "https://control.msg91.com/api/v5/otp/retry?mobile=91" + mobile + "&authkey=" + APIKey + "&retrytype=text";
                 	response = invokeurl
                 	[
                 		url :url
                 		type :GET
                 	];
                 	return response;
                 }
				 string OTP.SendOTP(string mobile, string template_id)
                 {
                 	APIKey = thisapp.variables.MSG91_API_Key;
                 	url = "https://control.msg91.com/api/v5/otp?mobile=91" + mobile + "&authkey=" + APIKey + "&template_id=" + template_id;
                 	response = invokeurl
                 	[
                 		url :url
                 		type :POST
                 		headers:{"Content-Type":"application/json","Accept":"application/json"}
                 	];
                 	return response;
                 }
				 map OTP.VerifyOTP(string mobile, string otp)
                 {
                 	url = "https://control.msg91.com/api/v5/otp/verify?otp=" + otp + "&mobile=91" + mobile;
                 	APIKey = thisapp.variables.MSG91_API_Key;
                 	response = invokeurl
                 	[
                 		url :url
                 		type :GET
                 		headers:{"authkey":APIKey}
                 	];
                 	return response;
                 }
				 void Payment_Integration.AdvancePayment(int DistributorID, float amt)
                 {
                 	orderId = "0111";
                 	amountValue = ifnull(amt,0);
                 	getDistt = Distributor_Master[ID == DistributorID.toLong()];
                 	custEmail = ifnull(getDistt.Email,"");
                 	custMobile = ifnull(getDistt.Mobile,"");
                 	custName = ifnull(getDistt.Distributor_Name,"");
                 	merchantId = "100000000007164";
                 	aggregatorId = "A100000000007164";
                 	secretKey = "db06cca0-838b-4e01-8b20-6ac446ffb6bd";
                 	saleUrl = "https://pgpayuat.icicibank.com/tsp/pg/api/v2/initiateSale";
                 	// must be alphanumeric only, max 20
                 	merchantTxnNo = "ORD" + zoho.currenttime.toLong().toString();
                 	txnDate = zoho.currenttime.toString("yyyyMMddHHmmss");
                 	// 	returnUrl = "https://ghardasalesportal.gharda.com";
                 	returnUrl = "https://zoho.gharda.com:14443/pages/payment/success" + "?customerName=" + encodeUrl(custName) + "&amount=" + amountValue.toString();
                 	payloadMap = Map();
                 	payloadMap.put("merchantId",merchantId);
                 	payloadMap.put("aggregatorID",aggregatorId);
                 	payloadMap.put("merchantTxnNo",merchantTxnNo);
                 	payloadMap.put("amount",amountValue.toString());
                 	payloadMap.put("currencyCode","356");
                 	payloadMap.put("payType","0");
                 	payloadMap.put("customerEmailID",custEmail);
                 	payloadMap.put("transactionType","SALE");
                 	payloadMap.put("returnURL",returnUrl);
                 	payloadMap.put("txnDate",txnDate);
                 	payloadMap.put("customerMobileNo",custMobile);
                 	payloadMap.put("customerName",custName);
                 	payloadMap.put("addlParam1",orderId);
                 	payloadMap.put("addlParam2","DistributorPayment");
                 	// hash v1: concatenate non-empty values in ascending order of parameter names
                 	keyList = List();
                 	keyList.add("addlParam1");
                 	keyList.add("addlParam2");
                 	keyList.add("aggregatorID");
                 	keyList.add("amount");
                 	keyList.add("currencyCode");
                 	keyList.add("customerEmailID");
                 	keyList.add("customerMobileNo");
                 	keyList.add("customerName");
                 	keyList.add("merchantId");
                 	keyList.add("merchantTxnNo");
                 	keyList.add("payType");
                 	keyList.add("returnURL");
                 	keyList.add("transactionType");
                 	keyList.add("txnDate");
                 	hashText = "";
                 	for each  k in keyList
                 	{
                 		val = payloadMap.get(k);
                 		if(val != null && val.toString() != "")
                 		{
                 			hashText = hashText + val.toString();
                 		}
                 	}
                 	secureHash = zoho.encryption.hmacsha256(secretKey,hashText,"hex").toLowerCase();
                 	payloadMap.put("secureHash",secureHash);
                 	payloadText = payloadMap.toString();
                 	// 		info hashText;
                 	// 		info secureHash;
                 	// 		info payloadText;
                 	headerMap = Map();
                 	headerMap.put("Content-Type","application/json");
                 	resp = invokeurl
                 	[
                 		url :saleUrl
                 		type :POST
                 		parameters:payloadMap.toString()
                 		headers:headerMap
                 		detailed:true
                 	];
                 	respText = resp.get("responseText");
                 	respJson = respText.toMap();
                 	info respJson;
                 	if(respJson.get("responseCode") == "R1000")
                 	{
                 		redirectUri = ifnull(respJson.get("redirectURI"),"");
                 		tranCtx = ifnull(respJson.get("tranCtx"),"");
                 		showOtp = ifnull(respJson.get("showOTPCapturePage"),"N");
                 		if(showOtp == "N" && redirectUri != "" && tranCtx != "")
                 		{
                 			openUrl(redirectUri + "?tranCtx=" + encodeUrl(tranCtx),"same window");
                 		}
                 		else
                 		{
                 			info "ICICI returned OTP/seamless flow. This needs a separate OTP implementation.";
                 		}
                 	}
                 	else
                 	{
                 		info "Unable to initiate ICICI payment. Response: " + respText;
                 	}
                 }
				 void Payment_Integration.InvoicePayment(int invID)
                 {
                 	// ── 1. Fetch Invoice & Distributor Data ─────────────────────────────
                 	getInvoiceData = Invoice[ID == invID];
                 	if(getInvoiceData.count() == 0)
                 	{
                 		info "Invoice not found for ID: " + invID;
                 		return;
                 	}
                 	orderId = ifnull(getInvoiceData.Invoice_Number,"");
                 	amountValue = ifnull(getInvoiceData.Grand_Total,0);
                 	getDistt = Distributor_Master[ID == getInvoiceData.Distributor_Name];
                 	custName = ifnull(getDistt.Distributor_Name,"");
                 	custEmail = ifnull(getDistt.Email,"");
                 	custMobile = ifnull(getDistt.Mobile,"");
                 	// ── 2. Gateway Config ───────────────────────────────────────────────
                 	merchantId = "100000000007164";
                 	aggregatorId = "A100000000007164";
                 	secretKey = "db06cca0-838b-4e01-8b20-6ac446ffb6bd";
                 	saleUrl = "https://pgpayuat.icicibank.com/tsp/pg/api/v2/initiateSale";
                 	merchantTxnNo = "ORD" + zoho.currenttime.toLong().toString();
                 	txnDate = zoho.currenttime.toString("yyyyMMddHHmmss");
                 	returnUrl = "https://zoho.gharda.com:14443/pages/payment/success" + "?customerName=" + encodeUrl(custName) + "&amount=" + amountValue.toString() + "&orderId=" + orderId;
                 	// ── 3. Build Payload ────────────────────────────────────────────────
                 	payloadMap = Map();
                 	payloadMap.put("merchantId",merchantId);
                 	payloadMap.put("aggregatorID",aggregatorId);
                 	payloadMap.put("merchantTxnNo",merchantTxnNo);
                 	payloadMap.put("amount",amountValue.toString());
                 	payloadMap.put("currencyCode","356");
                 	payloadMap.put("payType","0");
                 	payloadMap.put("customerEmailID",custEmail);
                 	payloadMap.put("transactionType","SALE");
                 	payloadMap.put("returnURL",returnUrl);
                 	payloadMap.put("txnDate",txnDate);
                 	payloadMap.put("customerMobileNo",custMobile);
                 	payloadMap.put("customerName",custName);
                 	payloadMap.put("addlParam1",orderId);
                 	payloadMap.put("addlParam2","DistributorPayment");
                 	// ── 4. Generate Secure Hash ─────────────────────────────────────────
                 	// Keys must be in ascending alphabetical order per ICICI spec
                 	hashKeys = {"addlParam1","addlParam2","aggregatorID","amount","currencyCode","customerEmailID","customerMobileNo","customerName","merchantId","merchantTxnNo","payType","returnURL","transactionType","txnDate"};
                 	hashText = "";
                 	for each  k in hashKeys
                 	{
                 		val = payloadMap.get(k);
                 		if(val != null && val.toString() != "")
                 		{
                 			hashText = hashText + val.toString();
                 		}
                 	}
                 	secureHash = zoho.encryption.hmacsha256(secretKey,hashText,"hex").toLowerCase();
                 	payloadMap.put("secureHash",secureHash);
                 	// ── 5. Call ICICI API ───────────────────────────────────────────────
                 	resp = invokeurl
                 	[
                 		url :saleUrl
                 		type :POST
                 		parameters:payloadMap.toString()
                 		headers:{"Content-Type":"application/json"}
                 		detailed:true
                 	];
                 	respJson = resp.get("responseText").toMap();
                 	responseCode = ifnull(respJson.get("responseCode"),"");
                 	redirectUri = ifnull(respJson.get("redirectURI"),"");
                 	tranCtx = ifnull(respJson.get("tranCtx"),"");
                 	// ── 6. Log to Payment_Logs ──────────────────────────────────────────
                 	insert into Payment_Logs
                 	[
                 		Invoice_Number=orderId
                 		Merchant_Txn_No=merchantTxnNo
                 		Amount=amountValue
                 		Customer_Name=custName
                 		Customer_Email=custEmail
                 		Customer_Mobile=custMobile
                 		Merchant_ID=merchantId
                 		Aggregator_ID=aggregatorId
                 		Secure_Hash=secureHash
                 		Response_Code=if(responseCode != "",responseCode,"NO_RESPONSE")
                 		Redirect_URI=redirectUri
                 		Tran_Ctx=tranCtx
                 		Status=if(responseCode == "R1000","Initiated","Failed")
                 		Error_Message=if(responseCode == "R1000","",ifnull(respJson.get("message"),""))
                 		Initiated_At=zoho.currenttime
                 		Added_User=zoho.loginuser
                 	]
                 	// 	dev-rohit
                 	// Update the status field of the Invoice Module, 
                 	invoiceStatus = if(responseCode == "R1000","Payment Initiated","Payment Failed");
                 	getInvoiceData.Status=invoiceStatus;
                 	// ── 7. Redirect to ICICI Payment Page ──────────────────────────────
                 	if(responseCode == "R1000" && redirectUri != "" && tranCtx != "")
                 	{
                 		openUrl(redirectUri + "?tranCtx=" + encodeUrl(tranCtx),"new window");
                 	}
                 	else if(responseCode == "R1000")
                 	{
                 		info "OTP flow required — separate implementation needed.";
                 	}
                 	else
                 	{
                 		info "Payment initiation failed. Response: " + resp.get("responseText");
                 	}
                 }
