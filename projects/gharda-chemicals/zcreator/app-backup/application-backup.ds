			Delivered as "Delivered"
			{
				type =  functions
				form = Dispatch
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						rannum = randomnumber(100000,999999);
										insertdata = insert into OTP_Module
										[
											Added_User=zoho.loginuser
											DispatchID=input.ID
											OTP=ifnull(rannum,0)
										];
										userEmail = zoho.loginuserid;
										getTransdata = Logistic_Master[ID == input.Transporter_Name];
										TransEmail = "";
										DISEmail = "";
										getdisadata = Distributor_Master[ID == input.Distributor];
										if(getdisadata.count() > 0)
										{
											DISEmail = getdisadata.Email;
										}
										TransName = "";
										if(getTransdata.count() > 0)
										{
											TransEmail = getTransdata.Email;
											TransName = getTransdata.Transporter_Name;
										}
										htmlMessage = "<html>" + "<body style='font-family:Arial,sans-serif;background-color:#f9f9f9;padding:20px;'>" + "<div style='max-width:500px;margin:auto;background:#ffffff;border-radius:10px;padding:20px;box-shadow:0 2px 5px rgba(0,0,0,0.1);'>" + "<h2 style='color:#2563eb;text-align:center;'>OTP Verification</h2>" + "<p>Dear " + TransName + ",</p>" + "<p>Your One-Time Password (OTP) for dispatch verification is:</p>" + "<div style='text-align:center;font-size:32px;font-weight:bold;color:#2563eb;margin:20px 0;'>" + rannum.toString() + "</div>" + "" + "<p>If you did not request this, please ignore this email.</p>" + "<hr style='border:none;border-top:1px solid #eee;'>" + "<p style='font-size:12px;color:#888;text-align:center;'>This is an automated email. Please do not reply.</p>" + "</div>" + "</body>" + "</html>";
										// if(TransEmail.isEmpty() == false)
										// {
										// 	sendmail
										// 	[
										// 		from :zoho.loginuserid
										// 		to :DISEmail
										// 		subject :"Your OTP for Dispatch Verification"
										// 		message :htmlMessage
										// 	]
										// }
										disphone = getdisadata.Contact_Number;
										if(disphone.isEmpty() == false)
										{
											last10 = right(disphone,10);
											thisapp.OTP.SendOTP(last10.toString(),"69d880d718e3f37670035d00");
										}
										//thisapp.Notifications.SendSMSforOTP(rannum.toString());
										openUrl("#Form:Verify_OTP?DispatchID=" + input.ID + "&zc_Header=false","popup window","height=350px,width=500px");
					)
					}
				}
			}
