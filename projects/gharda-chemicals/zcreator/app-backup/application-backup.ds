			hide_and_disable_fields10 as "hide and disable fields"
			{
				type =  form
				form = SRF_Master

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											//Basic Information
										hide SRF_Number;
										hide STD_SRF_Number;
										hide Date_of_Requisition;
										hide Contact_Number_Rep;
										hide GCL_Project_Name;
										hide GCL_Representative1;
										hide ISO_Number;
										hide Approval_Status;
										hide Segment;
										hide Requested_By;
										hide STD_Submit;
										hide Sales_Marketing_Person1;
										hide Segment;
										hide Purpose;
										hide Company_Name;
										hide Complete_Address;
										hide Customer_Name;
										hide Customer_Contact_Number;
										hide Segment;
										hide Customer_Email;
										hide Sales_Marketing_Person1;
										hide STD_Submit;
										hide Purpose;
										hide Details_of_Sample;
										//Details of customer
										hide OEM_Customer_Name;
										hide Customer_Name;
										hide Customer_Email;
										hide Customer_Contact_Number;
										hide Company_Name;
										hide Company_Address;
										hide Potential_Next_Year;
										hide Potential_Annum;
										hide Complete_Address;
										hide Application_Details;
										hide Billing_Address;
										//Details of Competitors
										hide Competitor_Name;
										hide Competitor_Activity;
										hide Testing_Details;
										hide Grade_Product_Used;
										hide Bus_CY;
										hide Bus_NY;
										hide Submitted_Trials;
										//subforms
										hide Details_of_Sample;
										hide Free_Sample_Line_Items;
										//sections
										hide Details_of_Customer;
										hide Details_of_Competitors;
										hide SRF_Number;
										getCustData = Customer[Email == zoho.loginuserid];
										if(getCustData.count() > 0)
										{
											if(getCustData.Customer_Type == "Polymer")
											{
												show Date_of_Requisition;
												show Contact_Number_Rep;
												show OEM_Customer_Name;
												show Customer_Name;
												show Customer_Contact_Number;
												show Company_Name;
												show Application_Details;
												show Billing_Address;
												show Free_Sample_Line_Items;
												show Purpose;
												disable Free_Sample_Line_Items.Total_Cost;
											}
											else if(getCustData.Customer_Type == "Pigment")
											{
												show Customer_Email;
												show Date_of_Requisition;
												show Customer_Name;
												show Customer_Name;
												show Customer_Contact_Number;
												show Customer_Email;
												show Purpose;
												show Details_of_Sample;
											}
										}
										getCustData = Customer[Email == zoho.loginuserid];
										if(getCustData.count() > 0)
										{
											input.Customer_Name = getCustData.ID;
											input.Customer_Email = getCustData.Email;
											input.Customer_Contact_Number = getCustData.Phone_Number;
											input.Customer_Type = getCustData.Customer_Type;
										}
										disable Customer_Name;
										disable Customer_Email;
										disable Customer_Contact_Number;
						)
					}
				}

			}
