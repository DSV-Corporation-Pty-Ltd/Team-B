			on_success3 as "on success"
			{
				type =  form
				form = QC_Check

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											getreturn = Return_Sales_order_Line_Items[ID == input.Return_Line_Item_ID];
										if(getreturn.count() > 0)
										{
											getreturn.QC_Check=true;
											getreturn.Return_Qty=input.Received_Quantity;
											getreturn.Approve_Reject=input.Approve_Reject_QC;
											if(input.Approve_Reject_QC == "Approve")
											{
												getallreturn = Return_Sales_order_Line_Items[Return_Sales_Order == input.Return_Sales_Order].QC_Check.getAll();
												if(!getallreturn.contains(false))
												{
													parentOrder = Return_Sales_Order[ID == input.Return_Sales_Order];
													if(parentOrder.count() > 0)
													{
														parentOrder.QC_Check=true;
														thisapp.Notifications.ReturnSOC_QCNotification(input.Return_Sales_Order);
													}
												}
											}
										}
						)
					}
				}

			}
