			Send_for_approval1 as "Send for approval"
			{
				type =  functions
				form = Expense_Master
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						approvalData = Approval_Master[Plant == input.Plant && Approval_Type == "Expense Approval"];
										if(approvalData.count() > 0)
										{
											level1Email = ifnull(approvalData.Approver_1.Approver_Email,"");
											level2Email = ifnull(approvalData.Approver_2.Approver_Email,"");
											level1Name = ifnull(approvalData.Approver_1.Approver_Name,"");
											level2Name = ifnull(approvalData.Approver_2.Approver_Name,"");
											sendTo = "";
											approverName = "";
											currentLevel = "";
											// CASE 1: Level 1 empty → go to Level 2
											if(level1Email == "" && level2Email != "")
											{
												sendTo = level2Email;
												approverName = level2Name;
												currentLevel = "2";
											}
											// CASE 2: Level 1 and Level 2 same → skip Level 1
											else if(level1Email != "" && level1Email == level2Email)
											{
												sendTo = level2Email;
												approverName = level2Name;
												currentLevel = "2";
											}
											// CASE 3: Normal Level 1 flow
											else if(level1Email != "")
											{
												sendTo = level1Email;
												approverName = level1Name;
												currentLevel = "1";
											}
											// Assign values if approver found
											if(sendTo != "")
											{
												input.Current_Level = currentLevel;
												input.Current_Approver = sendTo;
												input.Status = "Pending";
												message = "<div style='font-family: Arial, sans-serif; font-size:14px; color:#333;'>" + "<p>Dear <b>" + approverName + "</b>,</p>" + "<p>An expense request has been submitted and requires your approval.</p>" + "<p>You can review the details and take action using the link below:</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Expenses' style='color:#1a73e8; font-weight:bold;'>View Expense Report</a></p>" + "<p>Kindly review and approve/reject at your earliest convenience.</p>" + "<br>" + "<p>Thank you,<br><b>Team Gharda</b></p>" + "</div>";
												sendmail
												[
													from :zoho.adminuserid
													to :sendTo
													subject :"Expense Approval Required"
													message :message
												]
											}
										}
					)
					}
				}
			}
			Approve2 as "Approve"
			{
				type =  functions
				form = Expense_Master
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						rec = Expense_Master[ID == input.ID];
										approvalData = Approval_Master[Plant == rec.Plant && Approval_Type == "Expense Approval"];
										if(approvalData.count() > 0)
										{
											// Level 1 → Level 2
											if(rec.Current_Level == "1")
											{
												level2Email = ifnull(approvalData.Approver_2.Approver_Email,"");
												if(level2Email != "")
												{
													rec.Current_Level="2";
													rec.Current_Approver=level2Email;
													message1 = "<div style='font-family: Arial, sans-serif; font-size:14px; color:#333;'>" + "<p>Dear <b>" + approvalData.Approver_2.Approver_Name + "</b>,</p>" + "<p>An expense request has been submitted and requires your approval.</p>" + "<p>You can review the details and take action using the link below:</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Expenses' style='color:#1a73e8; font-weight:bold;'>View Expense Report</a></p>" + "<p>Kindly review and approve/reject at your earliest convenience.</p>" + "<br>" + "<p>Thank you,<br><b>Team Gharda</b></p>" + "</div>";
													sendmail
													[
														from :zoho.adminuserid
														to :level2Email
														subject :"Expense Approval Level 2"
														message :message1
													]
												}
												else
												{
													rec.Status="Approved";
												}
											}
											// Level 2 → Level 3
											else if(rec.Current_Level == "2")
											{
												level3Email = ifnull(approvalData.Approver_3.Approver_Email,"");
												if(level3Email != "")
												{
													rec.Current_Level="3";
													rec.Current_Approver=level3Email;
													message2 = "<div style='font-family: Arial, sans-serif; font-size:14px; color:#333;'>" + "<p>Dear <b>" + approvalData.Approver_3.Approver_Name + "</b>,</p>" + "<p>An expense request has been submitted and requires your approval.</p>" + "<p>You can review the details and take action using the link below:</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Expenses' style='color:#1a73e8; font-weight:bold;'>View Expense Report</a></p>" + "<p>Kindly review and approve/reject at your earliest convenience.</p>" + "<br>" + "<p>Thank you,<br><b>Team Gharda</b></p>" + "</div>";
													sendmail
													[
														from :zoho.adminuserid
														to :level3Email
														subject :"Expense Approval Level 3"
														message :message2
													]
												}
												else
												{
													rec.Status="Approved";
												}
											}
											// Final Approval
											else if(rec.Current_Level == "3")
											{
												rec.Status="Approved";
												rec.Current_Approver="";
												message3 = "<div style='font-family: Arial, sans-serif; font-size:14px; color:#333;'>" + "<p>Dear <b>" + rec.CNF_Name.CNF_Name + "</b>,</p>" + "<p>An expense request has been approved.</p>" + "<p>You can review the details below:</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Page:Expense_Report' style='color:#1a73e8; font-weight:bold;'>View Expense Report</a></p>" + "<p>Kindly review at your earliest convenience.</p>" + "<br>" + "<p>Thank you,<br><b>Team Gharda</b></p>" + "</div>";
												sendmail
												[
													from :zoho.adminuserid
													to :rec.CNF_Name.GCL_Accountant_Email_Id
													subject :"Expense Approved"
													message :message3
												]
											}
											if(rec.Status == "Approved" && rec.Current_Approver == "")
											{
												thisapp.ZohoExpenseApi.PushExpenseToZohoExpense(input.ID);
											}
										}
					)
					}
				}
			}
			Rejected as "Rejected"
			{
				type =  functions
				form = Expense_Master
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						rec = Expense_Master[ID == input.ID];
										if(rec.count() > 0)
										{
											rec.Status="Rejected";
											rec.Current_Level="";
											rec.Current_Approver="";
											message3 = "<div style='font-family: Arial, sans-serif; font-size:14px; color:#333;'>" + "<p>Dear <b>" + rec.CNF_Name.CNF_Name + "</b>,</p>" + "<p>An expense request has been rejected.</p>" + "<p>You can review the details below:</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Page:Expense_Report' style='color:#1a73e8; font-weight:bold;'>View Expense Report</a></p>" + "<p>Kindly review at your earliest convenience.</p>" + "<br>" + "<p>Thank you,<br><b>Team Gharda</b></p>" + "</div>";
											sendmail
											[
												from :zoho.adminuserid
												to :rec.CNF_Name.GCL_Accountant_Email_Id
												subject :"Expense " + input.Expense_No + " has been Rejected"
												message :message3
											]
										}
					)
					}
				}
			}
			Update_Expense as "Update Expense"
			{
				type =  functions
				form = Expense_Master
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						openURL("#Form:Expense_Master?recLinkID=" + input.ID + "&viewLinkName=Expenses_CNF","same window");
					)
					}
				}
			}
			update_quote as "update quote"
			{
				type =  functions
				form = Quotation
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						openURL("#Form:Quotation?recLinkID=" + input.ID + "&viewLinkName=Quotations_Logistic","same window");
					)
					}
				}
			}
			update_order as "update order"
			{
				type =  functions
				form = Order_Management
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						openURL("#Form:Order_Management?recLinkID=" + input.ID + "&viewLinkName=View_Orders","same window");
					)
					}
				}
			}
		}
	}
