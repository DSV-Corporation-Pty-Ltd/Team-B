										disable Line_Items.Billing_Price;
										hide Line_Items.Balance_Quantity;
										disable Line_Items.Technical_Name;
										disable Line_Items.CRM_Line_Item_ID;
										hide Line_Items.CRM_Line_Item_ID;
										hide Status;
										disable Tax_Amount;
										hide Order_Number;
										disable Order_Date;
										disable Contact_Number;
										disable Distributor_SAP_ID;
										disable Contact_Name;
										disable Email;
										disable Shipping_Street;
										disable Shipping_City;
										disable Shipping_State;
										disable Shipping_Country;
										disable Shipping_Code;
										disable Billing_Street;
										disable Billing_City;
										disable Billing_State;
										disable Billing_Country;
										disable Billing_Code;
										disable Status;
										disable Distributor_Name;
										hide Backend_Fields;
										hide Payment_Terms2;
										disable Territory;
										hide Line_Items.Liquidate_Done;
										hide Line_Items.Discount_Value;
										hide Line_Items.Discount;
						)
					}
				}

			}
			Order_ID_Generated as "Order ID Generated"
			{
				type =  form
				form = Order_Management

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											// rec = Order_Management[ID != null].count();
										// no = rec.toLong() + 0;
										// input.Order_Number = "SO-" + no;
										thisapp.AutoNumber.generateAutoNumber("Order Management",input.ID);
										input.Order_Description = input.Distributor_Name.Distributor_Name + " - Order";
										if(SyncFrom == false)
										{
											thisapp.SalesOrder.SyncSalesOrderInCRM(input.ID);
											//condityions checkjavascript:;
											if(input.Order_Type == "Credit Limit Order")
											{
												today = zoho.currentdate;
												distname = input.Distributor_Name;
												input.Status = "Order Process";
												overdue = false;
												cond1 = "";
												cond2 = "";
												cond3 = "";
												invoices = Invoice[Distributor_Name == input.Distributor_Name && Status == "Unpaid"] sort by Added_Time desc;
												if(invoices.count() > 0)
												{
													for each  inv in invoices
													{
														inv_date = inv.Invoice_Date;
														age = daysBetween(inv_date,today);
														if(age > 90)
														{
															overdue = true;
														}
													}
													if(overdue)
													{
														input.Status = "Pending";
														cond1 = "You have invoices overdue by more than 90 days. Please clear outstanding dues to proceed with a new order.<br><br>";
													}
												}
												dstributor = Distributor_Master[ID == input.Distributor_Name];
												if(dstributor.count() > 0)
												{
													gardtotal = ifnull(input.Grand_Total,0) * 70 / 100;
													if(gardtotal > dstributor.Credit_Limit)
													{
														input.Status = "Pending";
														cond2 = "Credit Limit is less then the 70% Order Amount.<br><br>";
													}
													grandtotal1 = ifnull(input.Grand_Total,0) * 30 / 100;
													if(grandtotal1 > dstributor.Advance_Deposit)
													{
														input.Status = "Pending";
														cond3 = "Advance Deposit is less than 30% of the order amount. Order is 'Awaiting Advance Payment'.<br><br>";
													}
												}
												email_body = "Dear " + input.Distributor_Name.Distributor_Name + ",<br><br>";
												email_body = email_body + "An order attempt has been marked as <b>" + input.Status + "</b>.<br><br>";
												email_body = email_body + "<b>Reason:</b>" + cond1 + cond2 + cond3;
												email_body = email_body + "<b>Date:</b> " + today.toString("dd-MMM-yyyy") + "<br>";
												email_body = email_body + "Best regards,<br>Gharda Chemicals";
												sendmail
												[
													from :zoho.adminuserid
													to :zoho.loginuserid
													subject :"Recent Order " + input.Order_Number + " – Action Required"
													message :email_body
												]
											}
										}
						)
					}
				}

			}
			assign_Portal1 as "assign Portal"
			{
				type =  form
				form = Distributor_Master

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Email != null)
										{
											getDist = Distributor_Master[Email == input.Email];
											if(getDist.count() <= 1)
											{
												accID = input.Account_CRM_record_ID;
												user_assignment = thisapp.portal.assignUserInProfile(input.Email,"Distributor");
												input.Portal_Assign_Date_and_Time = zoho.currenttime;
												input.Distributor_Created_from_CRM = true;
												input.Primary_Distributor = true;
												input.Response = user_assignment;
												accmap1 = Map();
												othermap1 = Map();
												accmap1.put("Primary_Distributor",true);
												accresponse1 = zoho.crm.updateRecord("Accounts",accID.toLong(),accmap1,othermap1,"connection_crm");
											}
											else
											{
												input.Primary_Distributor = false;
												accID = input.Account_CRM_record_ID;
												accmap = Map();
												othermap = Map();
												accmap.put("Primary_Distributor",false);
												accresponse = zoho.crm.updateRecord("Accounts",accID.toLong(),accmap,othermap,"connection_crm");
											}
										}
						)
					}
				}

			}
