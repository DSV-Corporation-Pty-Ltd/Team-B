				 void Notifications.PIApprovalNotifyToUsers(int PIID, string actionType)
                 {
                 	getPiData = Proforma_Invoice[ID == PIID];
                 	if(getPiData.count() > 0)
                 	{
                 		CustomerName = getPiData.Customer.Customer_Name;
                 		piCRMID = getPiData.zoho_crm_id;
                 		emptymap = Map();
                 		ownerEmail = "";
                 		getCRMPIData = zoho.crm.getRecordById("Proforma_Invoice",piCRMID.toLong(),emptymap,"zoho_oauth_connection");
                 		if(getCRMPIData.isEmpty() == false)
                 		{
                 			owner = getCRMPIData.get("Owner");
                 			if(getCRMPIData.isEmpty() == false)
                 			{
                 				ownerEmail = owner.get("email");
                 			}
                 		}
                 		piCRMID = getPiData.zoho_crm_id;
                 		emptymap = Map();
                 		ownerEmail = "";
                 		getCRMPIData = zoho.crm.getRecordById("Proforma_Invoice",piCRMID.toLong(),emptymap,"zoho_oauth_connection");
                 		if(getCRMPIData.isEmpty() == false)
                 		{
                 			owner = getCRMPIData.get("Owner");
                 			if(getCRMPIData.isEmpty() == false)
                 			{
                 				ownerEmail = owner.get("email");
                 			}
                 		}
                 		statusText = "";
                 		if(actionType == "Approved")
                 		{
                 			statusText = "approved";
                 		}
                 		else if(actionType == "Rejected")
                 		{
                 			statusText = "rejected";
                 		}
                 		email_content = "<html><body style='font-family:Arial, sans-serif;'><h2 style='color:#2563eb;'>Proforma Invoice " + statusText.toUpperCase() + " by CustomerName</h2><p>Dear " + "UserName" + ",</p><p>Your Proforma Invoice submitted against Purchase Order <b>" + getPiData.PO_No.PO_NO + "</b> has been <b>" + statusText + "</b> by Customer Name <b>" + CustomerName + "</b>.</p><table style='width:100%;margin-bottom:20px;'><tr><td><b>PI No:</b></td><td>" + getPiData.PI_Number + "</td></tr><tr><td><b>PO No.:</b></td><td>" + getPiData.PO_No.PO_NO + "</td></tr><tr><td><b>Status:</b></td><td><b style='color:#2563eb;'>" + actionType + "</b></td></tr></table><p><a href='https://zohoadmingharda782.zohocreatorportal.in/#Report:Proforma_Invoices' style='background-color:#2563eb;color:white;padding:10px 20px;text-decoration:none;border-radius:5px;'>View Quotation</a></p><p>Best regards,<br>" + CustomerName + "</p></body></html>";
                 		sendmail
                 		[
                 			from :zoho.loginuserid
                 			to :"ajay@fristinetech.com"
                 			subject :"Proforma Invoice " + actionType + " - " + getPiData.PI_Number
                 			message :email_content
                 		]
                 	}
                 }
