				 void SMS.sendSMSInvoiceOverdewInSO(Int SOID)
                 {
                 	// 	GHARDA CHEMICALS LTD Dear ##DistributorName##, invoice ##InvoiceNo## amounting to ##Amount## is overdue by ##OverdueDays## days. Please arrange payment immediately.
                 	getSOdATA = Order_Management[ID == SOID];
                 	if(getSOdATA.count() > 0)
                 	{
                 		DistData = Distributor_Master[ID == getSOdATA.Distributor_Name];
                 		if(DistData.count() > 0)
                 		{
                 			statusList = {"Unpaid","Payment Pending","Open"};
                 			invoices = Invoice[Distributor_Name == DistData.ID && Status in statusList] sort by Added_Time desc;
                 			age = "";
                 			inv_no = "";
                 			Amount = "";
                 			if(invoices.count() > 0)
                 			{
                 				inv_date = invoices.Invoice_Date;
                 				age = daysBetween(inv_date,today);
                 				inv_no = invoices.Invoice_Number;
                 				Amount = invoices.Grand_Total;
                 			}
                 			phone = DistData.Contact_Number.toString();
                 			if(phone.isEmpty() == false)
                 			{
                 				last10 = right(phone,10);
                 				Payload = {"template_id":"69d74208aa2ca3e0b206f4f3","short_url":"0","short_url_expiry":"","realTimeResponse":"1","recipients":{{"mobiles":"91" + last10,"DistributorName":ifnull(DistData.Distributor_Name,""),"OrderID":ifnull(getSOdATA.Order_Number,""),"OverdueDays":age,"OrderID":ifnull(Amount.toString(),""),"InvoiceNo":ifnull(inv_no.toString(),"")}}};
                 				info Payload;
                 				header = Map();
                 				header.put("Accept","application/json");
                 				header.put("authkey","506742AeM4FBCH69d505a4P1");
                 				header.put("Content-Type","application/json");
                 				sendSMS = invokeurl
                 				[
                 					url :"https://control.msg91.com/api/v5/flow"
                 					type :POST
                 					parameters:Payload.toString()
                 					headers:header
                 				];
                 				info sendSMS;
                 			}
                 		}
                 	}
                 }
