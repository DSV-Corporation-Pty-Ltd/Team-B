                 	// 	fieldMap.put("value",getExpenseData.Expense_Type.Expense_Type);
                 	// 	expensemap.put("custom_fields",{fieldMap});
                 	// 	lineList = List();
                 	// 	lineitem = Map();
                 	// 	lineitem.put("category_id",getExpenseData.Expense_Category.CatID);
                 	// 	lineitem.put("amount",getExpenseData.Amount);
                 	// 	lineitem.put("description",getExpenseData.Description);
                 	// 	lineList.add(lineitem);
                 	// 	expensemap.put("line_items",lineList);
                 	// 	header_map = Map();
                 	// 	header_map.put("X-com-zoho-expense-organizationid",60047789605);
                 	// 	createExpense = invokeurl
                 	// 	[
                 	// 		url :"https://www.zohoapis.in/expense/v1/expenses"
                 	// 		type :POST
                 	// 		parameters:expensemap.toString()
                 	// 		headers:header_map
                 	// 		connection:"zoho_oauth_connection"
                 	// 	];
                 	// 	info expensemap;
                 	// 	info createExpense;
                 	// 	expResp = {"Module":"Expense","Trigger":"Create","Resp":createExpense.get("message")};
                 	// 	getExpenseData.Expense_Response=expResp.toString();
                 	// 	if(createExpense.containkey("code") && createExpense.get("code") == 0)
                 	// 	{
                 	// 		getData = createExpense.get("expenses");
                 	// 		expenseid = getData.getJson("expense_id");
                 	// 		getExpenseData.Zoho_Expense_ID=expenseid.toString();
                 	// 		getExpenseData.ReportID=reportID.toString();
                 	// 		getExpenseData.MerchantID=merchantID.toString();
                 	// 		//upload Attachement in expense 
                 	// 		if(getExpenseData.Upload_Receipt.isEmpty() == false)
                 	// 		{
                 	// 			header_map = Map();
                 	// 			parameters_map = Map();
                 	// 			header_map.put("X-com-zoho-expense-organizationid",60047789605);
                 	// 			imageDownloadURL = "https://www.zohoapis.in/creator/v2.1/data" + zoho.appuri + "report/All_Expense_Masters/" + getExpenseData.ID + "/Upload_Receipt/download";
                 	// 			receipt = invokeurl
                 	// 			[
                 	// 				url :imageDownloadURL
                 	// 				type :GET
                 	// 				connection:"zoho_oauth_connection"
                 	// 			];
                 	// 			parameters_data = Map();
                 	// 			parameters_data.put("attachment",receipt);
                 	// 			fileData = {"paramName":"attachment","content":receipt};
                 	// 			response = invokeurl
                 	// 			[
                 	// 				url :"https://www.zohoapis.in/expense/v1/expenses/" + expenseid + "/documents"
                 	// 				type :POST
                 	// 				headers:header_map
                 	// 				files:fileData
                 	// 				connection:"zoho_oauth_connection"
                 	// 			];
                 	// 		}
                 	// 	}
                 	//multi expense code 
                 	ExpenseLineItems = Expense_Line_Items[Expense_Master == getExpenseData.ID];
                 	//info ExpenseLineItems;
                 	if(ExpenseLineItems.count() > 0)
                 	{
                 		for each  expenseItem in ExpenseLineItems
                 		{
                 			expensemap = Map();
                 			expensemap.put("currency_id",2962877000000000064);
                 			expensemap.put("date",getExpenseData.Expense_Date.toString("yyyy-MM-dd"));
                 			if(reportID.isEmpty() == false)
                 			{
                 				expensemap.put("report_id",reportID);
                 				expensemap.put("merchant_id",merchantID);
                 				expensemap.put("is_reimbursable",true);
                 				fieldMap = Map();
                 				fieldMap.put("customfield_id","2962877000000119001");
                 				fieldMap.put("value",expenseItem.Expense_Type.Expense_Type);
                 				expensemap.put("custom_fields",{fieldMap});
                 				lineList = List();
                 				lineitem = Map();
                 				lineitem.put("category_id",expenseItem.Expense_Category.CatID);
                 				lineitem.put("amount",expenseItem.Total);
                 				lineitem.put("description",expenseItem.Description);
                 				lineList.add(lineitem);
                 				expensemap.put("line_items",lineList);
                 				//info expensemap;
                 				header_map = Map();
                 				header_map.put("X-com-zoho-expense-organizationid",60047789605);
                 				createExpense = invokeurl
                 				[
                 					url :"https://www.zohoapis.in/expense/v1/expenses"
                 					type :POST
                 					parameters:expensemap.toString()
                 					headers:header_map
                 					connection:"zoho_oauth_connection"
                 				];
                 				// 		info expensemap;
                 				// 		info createExpense;
                 				expResp = {"Module":"Expense","Trigger":"Create","Resp":createExpense.get("message")};
                 				expenseItem.Expense_Response=expResp.toString();
                 				if(createExpense.containkey("code") && createExpense.get("code") == 0)
                 				{
                 					getData = createExpense.get("expenses");
                 					expenseid = getData.getJson("expense_id");
                 					expenseItem.Zoho_Expense_ID=expenseid.toString();
                 					getExpenseData.ReportID=reportID.toString();
                 					getExpenseData.MerchantID=merchantID.toString();
                 					//info expenseid;
                 					//upload Attachement in expense 
                 					if(expenseItem.Upload_Receipt.isEmpty() == false)
                 					{
                 						header_map = Map();
                 						parameters_map = Map();
                 						header_map.put("X-com-zoho-expense-organizationid",60047789605);
                 						imageDownloadURL = "https://www.zohoapis.in/creator/v2.1/data" + zoho.appuri + "report/All_Expense_Line_Items1/" + expenseItem.ID + "/Upload_Receipt/download";
                 						receipt = invokeurl
                 						[
                 							url :imageDownloadURL
                 							type :GET
                 							connection:"zoho_oauth_connection"
                 						];
                 						parameters_data = Map();
                 						parameters_data.put("attachment",receipt);
                 						fileData = {"paramName":"attachment","content":receipt};
                 						response = invokeurl
                 						[
                 							url :"https://www.zohoapis.in/expense/v1/expenses/" + expenseid + "/documents"
                 							type :POST
                 							headers:header_map
                 							files:fileData
                 							connection:"zoho_oauth_connection"
                 						];
                 						//info response;
                 					}
                 				}
                 			}
                 		}
                 	}
                 }
			 }
		 }


