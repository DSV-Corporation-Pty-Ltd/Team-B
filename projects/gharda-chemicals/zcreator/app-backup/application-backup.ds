			get_Price as "get Price"
			{
				type =  form
				form = Order_Management

				record event = on add or edit

				on user input of Line_Items.SKU
				{
					actions 
					{
						custom deluge script
						(
											if(row.Product_Name != null && row.SKU != null)
										{
											skuval = row.SKU;
											pricingRecord = Price_Master[Product_Code == row.SKU.Product_Code && ProductName == skuval.toLong()];
											// 	alert pricingRecord;
											// 	alert skuval;
											if(pricingRecord.count() > 0)
											{
												//this has to be 	put on the user input of the sku
												row.Billing_Price=thisapp.Pricing_Logic.getZNDPPrice(row.SKU.Product_Code,input.Customer_Code,input.Customer_Group,input.Plant.Plant,"ZNDP");
												ZK07Price = thisapp.Pricing_Logic.getZNDPPrice(row.SKU.Product_Code,input.Customer_Code,input.Customer_Group,input.Plant.Plant,"ZK07");
												ZK08Price = thisapp.Pricing_Logic.getZNDPPrice(row.SKU.Product_Code,input.Customer_Code,input.Customer_Group,input.Plant.Plant,"ZK08");
												// 		alert "ZK07Price " +ZK07Price;
												// 		alert "ZK08Price "+ZK08Price;
												row.Discount_Price=ifnull(toDecimal(ZK07Price),0) + ifnull(toDecimal(ZK08Price),0);
												// 		row.Discount_Price=ifnull(pricingRecord.Final_Price,0);
												// 		if(row.Billing_Price == 0 || row.Billing_Price.isNull() == true)
												// 		{
												// 			row.Billing_Price=ifnull(pricingRecord.BasePrice,0);
												// 		}
												// 		row.Billing_Price=ifnull(pricingRecord.BasePrice,0);
											}
											else
											{
												alert "Price not available for this product & plant.";
												row.Product_Name=null;
												row.Product_Code=null;
												row.SKU=null;
												row.Batch_Number=null;
												row.Discount=null;
												row.Discount_Value=null;
												row.Total=null;
												row.Discount_Price=null;
												row.Billing_Price=null;
											}
											getpro = Product_Master[ID == row.SKU];
											if(getpro.count() > 0)
											{
												row.Product_Code=getpro.Product_Code;
												//row.Product_Name=getpro.ID;
												row.Technical_Name=getpro.Full_Technical_Name;
											}
										}
										duplicateFound = false;
										currentProduct = row.Product_Name;
										currentSKU = row.SKU;
										for each  lineItem in input.Line_Items
										{
											if(lineItem != row)
											{
												if(lineItem.Product_Name == currentProduct && lineItem.SKU == currentSKU)
												{
													duplicateFound = true;
													break;
												}
											}
										}
										if(duplicateFound)
										{
											alert "This product with same SKU is already added. Please increase the quantity in the existing row.";
											row.Product_Name=null;
											row.SKU=null;
											row.Product_Code=null;
											row.Batch_Number=null;
											row.Discount=null;
											row.Discount_Value=null;
											row.Total=null;
											row.Discount_Price=null;
											row.Billing_Price=null;
										}
										Fertilizer = false;
										Pesticide = false;
										getpro = Product_Master[ID == row.SKU];
										productCat = getpro.Product_Category;
										if(productCat == "NPK Fertilizer" || productCat == "Liquid Fertilizer")
										{
											Fertilizer = true;
										}
										else
										{
											Pesticide = true;
										}
										getDist = Distributor_Master[ID == input.Distributor_Name];
										Fertilizer_License_Number = false;
										Pesticide_License_Number = false;
										if(getDist.count() > 0)
										{
											Fertilizer_License_Number = ifnull(getDist.Fertilizer_License_Number,"");
											if(Fertilizer_License_Number.isEmpty() == true)
											{
												Fertilizer_License_Number = true;
											}
											Pesticide_License_Number = ifnull(getDist.Pesticide_License_Number,"");
											if(Pesticide_License_Number.isEmpty() == true)
											{
												Pesticide_License_Number = true;
											}
										}
										if(Fertilizer == true && Fertilizer_License_Number == true)
										{
											alert "You can't create this order because you don't have a fertilizer license.";
											row.Product_Name=null;
											row.SKU=null;
											row.Product_Code=null;
											row.Batch_Number=null;
											row.Discount=null;
											row.Discount_Value=null;
											row.Total=null;
											row.Discount_Price=null;
											row.Billing_Price=null;
										}
										if(Pesticide == true && Pesticide_License_Number == true)
										{
											alert "You can't create this order because you don't have a Pesticide license.";
											row.Product_Name=null;
											row.SKU=null;
											row.Product_Code=null;
											row.Batch_Number=null;
											row.Discount=null;
											row.Discount_Value=null;
											row.Total=null;
											row.Discount_Price=null;
											row.Billing_Price=null;
										}
						)
					}
				}

			}
