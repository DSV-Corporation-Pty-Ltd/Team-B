                 			// 				updateresp = invokeurl
                 			// 				[
                 			// 					url :"https://www.zohoapis.in/crm/v8/Sales_Orders/" + crmSOID
                 			// 					type :PUT
                 			// 					parameters:dataMap.toString()
                 			// 					connection:"zoho_oauth_connection"
                 			// 				];
                 			// 			}
                 		}
                 		else
                 		{
                 			datamap1 = Map();
                 			info dataMap;
                 			datamap1.put("data",{dataMap});
                 			insertresp = invokeurl
                 			[
                 				url :"https://www.zohoapis.in/crm/v8/Sales_Orders"
                 				type :POST
                 				parameters:datamap1.toString()
                 				connection:"zoho_oauth_connection"
                 			];
                 			// 			insertresp = invokeurl
                 			// 			[
                 			// 				url :"https://www.zohoapis.in/crm/v8/Sales_Orders"
                 			// 				type :POST
                 			// 				parameters:datamap1.toString()
                 			// 				connection:"zohocrm_connection"
                 			// 			];
                 			info "line 137 " + insertresp;
                 			craetemsg = insertresp.get("data").getJson("message");
                 			details = insertresp.get("data").getJson("details");
                 			crmID = details.get("id").toString();
                 			getCRMRecord = invokeurl
                 			[
                 				url :"https://www.zohoapis.in/crm/v8/Sales_Orders/" + crmID
                 				type :GET
                 				connection:"zoho_oauth_connection"
                 			];
                 			// 			getCRMRecord = invokeurl
                 			// 			[
                 			// 				url :"https://www.zohoapis.in/crm/v8/Sales_Orders/" + crmID
                 			// 				type :GET
                 			// 				connection:"zohocrm_connection"
                 			// 			];
                 			crmData = getCRMRecord.get("data").get(0);
                 			if(crmData.isEmpty() == false)
                 			{
                 				orderedItems = crmData.get("Ordered_Items");
                 				for each  crmItem in orderedItems
                 				{
                 					crmLineID = crmItem.get("id");
                 					crmProductCode = crmItem.get("Product_Code");
                 					getCreatorLine = Order_Line_Items[Order_Management == SOID && Product_Code == crmProductCode];
                 					for each  rec in getCreatorLine
                 					{
                 						rec.CRM_Line_Item_ID=crmLineID;
                 					}
                 				}
                 			}
                 			if(craetemsg == "record added")
                 			{
                 				//insert log data
                 				insertLog = insert into Log_Master
                 				[
                 					Added_User=zoho.loginuser
                 					Module_Name="Sales Order"
                 					Trigger="Create"
                 					RecordID=getSOData.ID.toString()
                 					Response=insertresp.toString()
                 					Sync_From="Creator"
                 					Sync_To="CRM"
                 					Created_Time=zoho.currenttime
                 					Function_Workflow="SyncSalesOrderInCRM"
                 				];
                 				getSOData.CRM_SO_ID=details.get("id").toString();
                 				crmID = details.get("id").toString();
                 				//update cash deposit
                 				if(getSOData.Order_Type == "Cash Advance Order")
                 				{
                 					getDist = Distributor_Master[ID == getSOData.Distributor_Name];
                 					if(getDist.count() > 0)
                 					{
                 						if(getDist.Advance_Deposit > 0 && getDist.Advance_Deposit > getSOData.Grand_Total)
                 						{
                 							// 							pendingDeposit = ifnull(getDist.Advance_Deposit,0) - ifnull(getSOData.Grand_Total,0);
                 							// 							getDist.Advance_Deposit=ifnull(pendingDeposit,0);
                 							// 							accID = getDist.Account_CRM_record_ID;
                 							// 							disMap = Map();
                 							// 							otherMap = Map();
                 							// 							disMap.put("Advance_Deposit",ifnull(pendingDeposit,0));
                 							// 							//updateacc = zoho.crm.updateRecord("Accounts",accID.toLong(),disMap,otherMap,"zohocrm_connection");
                 							// 							updateacc = zoho.crm.updateRecord("Accounts",accID.toLong(),disMap,otherMap,"zoho_oauth_connection");
                 						}
                 					}
                 				}
                 			}
                 		}
                 	}
                 }
				 void SalesOrder.updateSOInCRM(int SOID)
                 {
                 	getSOData = Order_Management[ID == SOID];
                 	othermap = Map();
                 	if(getSOData.count() > 0)
                 	{
                 		dataMap = Map();
                 		dataMap.put("So_No",ifnull(getSOData.Order_Number,""));
                 		dataMap.put("Submitted_By_Distributor",true);
                 		dataMap.put("Creator_SO_Id",ifnull(SOID.toString(),""));
                 		dataMap.put("Trigger_From",true);
                 		dataMap.put("Order_Date",ifnull(getSOData.Order_Date.toString("yyyy-MM-dd"),""));
                 		dataMap.put("Due_Date",ifnull(getSOData.Due_Date.toString("yyyy-MM-dd"),""));
                 		dataMap.put("Subject",ifnull(getSOData.Order_Description,""));
                 		dataMap.put("Status",ifnull(getSOData.Status,""));
                 		dataMap.put("Account_Name",ifnull(getSOData.Distributor_Name.Account_CRM_record_ID,""));
                 		dataMap.put("Billing_Street",ifnull(getSOData.Billing_Street,""));
                 		dataMap.put("Billing_City",ifnull(getSOData.Billing_City,""));
                 		dataMap.put("Billing_State",ifnull(getSOData.Billing_State,""));
                 		dataMap.put("Billing_Country",ifnull(getSOData.Billing_Country,""));
                 		dataMap.put("Billing_Code",ifnull(getSOData.Billing_Code.toString(),""));
                 		dataMap.put("Shipping_Street",ifnull(getSOData.Shipping_Street,""));
                 		dataMap.put("Shipping_City",ifnull(getSOData.Shipping_City,""));
                 		dataMap.put("Shipping_State",ifnull(getSOData.Shipping_State,""));
                 		dataMap.put("Shipping_Country",ifnull(getSOData.Shipping_Country,""));
                 		dataMap.put("Shipping_Code",ifnull(getSOData.Shipping_Code.toString(),""));
                 		dataMap.put("Sub_Total",ifnull(getSOData.Subtotal,""));
                 		dataMap.put("IGST",ifnull(getSOData.IGST,0));
                 		dataMap.put("GST",ifnull(getSOData.CGST,0));
                 		dataMap.put("SGST",ifnull(getSOData.SGST,0));
                 		dataMap.put("Grand_Total",ifnull(getSOData.Grand_Total,0));
                 		dataMap.put("Order_Type",ifnull(getSOData.Order_Type,""));
                 		/******** Distributor ********/
                 		getDistributorData = Distributor_Master[ID == getSOData.Distributor_Name];
                 		if(getDistributorData.count() > 0)
                 		{
                 			if(getDistributorData.Employee_ID.isEmpty() == false)
                 			{
                 				dataMap.put("Owner",toLong(getDistributorData.Employee_ID));
                 			}
                 		}
                 		/******** Territory ********/
                 		getTerritory = getSOData.Territory;
                 		if(getTerritory.isNull() == false)
                 		{
                 			getTerritoryData = Territory[ID == getTerritory];
                 			if(getTerritoryData.count() > 0)
                 			{
                 				getCRmTId = getTerritoryData.zoho_crm_id;
                 				if(getCRmTId != "")
                 				{
                 					dataMap.put("Territory_Name",getCRmTId.toLong());
                 				}
                 			}
                 		}
                 		/******** Subform Logic ********/
                 		getProducts = Order_Line_Items[Order_Management == SOID];
                 		productList = List();
                 		for each  getPro in getProducts
                 		{
                 			productmap = Map();
                 			// ✅ SAFE Product Code
                 			prodCode = "";
                 			if(getPro.Product_Name != null)
                 			{
                 				prodCode = ifnull(getPro.Product_Name.Product_Code,"");
                 			}
                 			if(prodCode == "")
                 			{
                 				continue;
                 			}
                 			searchPro = zoho.crm.searchRecords("Products","Product_Code:equals:" + prodCode,0,200,othermap,"zoho_oauth_connection");
                 			if(searchPro.isEmpty() == false)
                 			{
                 				prodid = "";
                 				for each  serachpr in searchPro
                 				{
                 					prodid = serachpr.get("id");
                 				}
                 				productmap.put("Product_Name",prodid);
                 				productmap.put("Product_Code",getPro.Product_Code);
                 				productmap.put("Price",getPro.Discount_Price);
                 				productmap.put("Billing_Price",getPro.Billing_Price);
                 				// ✅ SAFE Unit
                 				if(getPro.Product_Name != null)
                 				{
                 					productmap.put("UOM",ifnull(getPro.Product_Name.Unit,""));
                 				}
                 				// ✅ SAFE SKU
                 				if(getPro.SKU != null)
                 				{
                 					productmap.put("SKU",ifnull(getPro.SKU.SKU1,""));
                 				}
                 				productmap.put("Discount",ifnull(getPro.Discount_Value,0));
                 				productmap.put("Quantity",getPro.Quantity);
                 				// 🔥 KEY LOGIC (Update vs Create)
                 				if(getPro.CRM_Line_Item_ID != null && getPro.CRM_Line_Item_ID != "")
                 				{
                 					productmap.put("id",getPro.CRM_Line_Item_ID);
                 				}
                 				productList.add(productmap);
                 			}
                 		}
                 		//info productList;
                 		/******** Search CRM SO ********/
                 		searchSO = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/crm/v8/Sales_Orders/search?criteria=(Creator_SO_Id:equals:" + SOID.toString() + ")&approved=both"
                 			type :GET
                 			connection:"zoho_oauth_connection"
                 		];
                 		if(searchSO.isEmpty() == false)
                 		{
                 			getdata = searchSO.get("data");
                 			if(getdata.size() > 0)
                 			{
                 				crmSOID = getdata.get(0).get("id");
                 				if(crmSOID != null)
                 				{
                 					dataMap.put("Ordered_Items",productList);
                 					datamap2 = Map();
                 					datamap2.put("data",{dataMap});
                 					updateresp = invokeurl
                 					[
                 						url :"https://www.zohoapis.in/crm/v8/Sales_Orders/" + crmSOID
                 						type :PUT
                 						parameters:datamap2.toString()
                 						connection:"zoho_oauth_connection"
                 					];
                 					//info updateresp;
                 					updateMDG = updateresp.get("data").get(0).get("message");
                 					// AFTER SUCCESSFUL UPDATE
                 					if(updateMDG == "record updated")
                 					{
                 						insertLog = insert into Log_Master
                 						[
                 							Added_User=zoho.loginuser
                 							Module_Name="Sales Order"
                 							Trigger="Update"
                 							RecordID=getSOData.ID.toString()
                 							Response=updateresp.toString()
                 							Sync_From="Creator"
                 							Sync_To="CRM"
                 							Created_Time=zoho.currenttime
                 							Function_Workflow="updateSOInCRM"
                 						];
                 						/******** 🔥 NEW LOGIC: FETCH CRM SUBFORM IDS ********/
                 						getCRMRecord = invokeurl
                 						[
                 							url :"https://www.zohoapis.in/crm/v8/Sales_Orders/" + crmSOID
                 							type :GET
                 							connection:"zoho_oauth_connection"
                 						];
                 						if(getCRMRecord.isEmpty() == false)
                 						{
                 							crmData = getCRMRecord.get("data").get(0);
                 							orderedItems = crmData.get("Ordered_Items");
                 							if(orderedItems != null)
                 							{
                 								for each  crmItem in orderedItems
                 								{
                 									crmLineID = crmItem.get("id");
                 									crmProductCode = ifnull(crmItem.get("Product_Code"),"");
                 									crmSKU = ifnull(crmItem.get("SKU"),"");
                 									// 🔴 Match with Creator line
                 									getCreatorLine = Order_Line_Items[Order_Management == SOID];
                 									for each  rec in getCreatorLine
                 									{
                 										match = false;
                 										// Prefer SKU match (best)
                 										if(crmSKU != "" && rec.SKU != null && rec.SKU.SKU1 == crmSKU)
                 										{
                 											match = true;
                 										}
                 										// fallback Product Code
                 										else if(crmProductCode != "" && rec.Product_Code == crmProductCode)
                 										{
                 											match = true;
                 										}
                 										if(match == true)
                 										{
                 											// ✅ Update CRM Line ID back to Creator
                 											rec.CRM_Line_Item_ID=crmLineID;
                 										}
                 									}
                 								}
                 							}
                 						}
                 					}
                 				}
                 			}
                 		}
                 	}
                 }
				 void Service_PO.createservicePOCPI(string id)
                 {
                 	// 	341335000002470093
                 	expendedata = Expense_Master[ID == id.toLong()];
                 	if(expendedata.Vendor_Name != null)
                 	{
                 		vendorCRMId = expendedata.Vendor_Name;
                 		//info vendorCRMId;
                 		vendorRecord = zoho.crm.getRecordById("Vendors",vendorCRMId.toLong(),Map(),"zohocrm_connection_sandbox");
                 		//     info vendorRecord;
                 		if(vendorRecord != null)
                 		{
                 			sapId = ifnull(vendorRecord.get("SAP_ID"),"");
                 			//	info sapId;
                 		}
                 	}
                 	relatedplant = expendedata.Plant;
                 	plantcode = relatedplant.Plant;
                 	// 	plantcostcenter = relatedplant.Cost_Center;
                 	expcategory = expendedata.Expense_Category;
                 	expcategorydata = Expense_Category[ID == expcategory];
                 	if(expcategorydata.count() > 0)
                 	{
                 		maerialgrp = expcategorydata.Material_Group;
                 		if(expcategorydata.Expense_Type == "VARIABLE")
                 		{
                 			serviceqty = expendedata.Enter_Quantity;
                 		}
                 		else
                 		{
                 			serviceqty = 1;
                 		}
                 	}
                 	expcategoryname = expcategorydata.Category;
                 	// 	netprice = expendedata.Amount1;
                 	headermap = Map();
                 	headermap.put("purchasingDocument","ZSCF");
                 	headermap.put("companyCode","1000");
                 	headermap.put("purchasingOrg","1000");
                 	headermap.put("purchasingGroup","FMD");
                 	headermap.put("currency","INR");
                 	headermap.put("paymentTerms","P000");
                 	headermap.put("documentDate",zoho.currentdate.toString("yyyy-MM-dd"));
                 	// 	headermap.put("vendor",sapId);
                 	headermap.put("vendor","1000003");
                 	// 	1000003
                 	// from crm vendor master, need to send vendor code sap 
                 	// user input
                 	headermap.put("headerText","");
                 	itemlist = List();
                 	servicesList = List();
                 	scheduleMap = Map();
                 	scheduleMap.put("deliveryDate",zoho.currentdate.toString("yyyy-MM-dd"));
                 	poItemsList = List();
                 	itemCounter = 10;
                 	for each  expenseLine in expendedata.Expenses
                 	{
                 		// -----------------------------
                 		// Generate PO Item Number
                 		// -----------------------------
                 		poItemNo = itemCounter.toString();
                 		if(itemCounter < 100)
                 		{
                 			poItemNo = "000" + itemCounter.toString();
                 		}
                 		else
                 		{
                 			poItemNo = "00" + itemCounter.toString();
                 		}
                 		// -----------------------------
                 		// Get values from current subform row only
                 		// -----------------------------
                 		expenseCategory = ifnull(expenseLine.Expense_Category.Category,"");
                 		expenseType = ifnull(expenseLine.Expense_Type,"");
                 		glCode = ifnull(expenseLine.GL_Code,"");
                 		description = ifnull(expenseLine.Description,"");
                 		taxPercent = ifnull(expenseLine.Tax,"0");
                 		lineAmount = ifnull(expenseLine.Amount,0);
                 		taxCode = "G0";
                 		// 		controlCode = "998719";
                 		controlCode = ifnull(expenseLine.Expense_Category.SAC_Code,"");
                 		// expense category
                 		// Example: get material group from Expense Category lookup/master
                 		materialGroup = "";
                 		if(expenseLine.Expense_Category != null)
                 		{
                 			materialGroup = ifnull(expenseLine.Expense_Category.Material_Group,"");
                 		}
                 		// -----------------------------
                 		// Schedule
                 		// -----------------------------
                 		scheduleMap = Map();
                 		scheduleMap.put("deliveryDate",zoho.currentdate.toString("yyyy-MM-dd"));
                 		// -----------------------------
                 		// Account Assignment
                 		// IMPORTANT: use current row GL Code only
                 		// -----------------------------
                 		accountAssignment = Map();
                 		plantMaster = Plants_Master[ID == expendedata.Plant];
                 		costCenter = "";
                 		costCenter = "";
                 		if(plantMaster.count() > 0)
                 		{
                 			//	accountAssignment.put("costCenter","1201AKO");
                 			costCenter = ifnull(plantMaster.Cost_Center,"");
                 			accountAssignment.put("costCenter",costCenter);
                 		}
                 		// plant master
                 		accountAssignment.put("GLAccount",glCode);
                 		// -----------------------------
                 		// Service Hierarchy
                 		// IMPORTANT: use current row description/amount only
                 		// -----------------------------
                 		serviceHierarchy = Map();
                 		serviceHierarchy.put("shortText",description);
                 		serviceHierarchy.put("serviceUom","LE");
                 		if(expenseType == "VARIABLE")
                 		{
                 			serviceHierarchy.put("plannedQty",ifnull(expenseLine.Quantity,1));
                 		}
                 		else
                 		{
                 			serviceHierarchy.put("plannedQty","1");
                 		}
                 		serviceHierarchy.put("plannedPrice",lineAmount);
                 		serviceHierarchy.put("serviceCode","");
                 		// -----------------------------
                 		// Service Line
                 		// -----------------------------
                 		serviceLine = Map();
                 		serviceLine.put("accountAssignment",accountAssignment);
                 		serviceLine.put("serviceHierarchy",serviceHierarchy);
                 		// VERY IMPORTANT:
                 		// Create servicesList INSIDE the loop
                 		// so every PO item has only one service line
                 		servicesList = List();
                 		servicesList.add(serviceLine);
                 		// -----------------------------
                 		// PO Item
                 		// -----------------------------
                 		poItem = Map();
                 		poItem.put("poItem",poItemNo);
                 		poItem.put("itemCategory","9");
                 		poItem.put("accountAssignmentCat","K");
                 		//poItem.put("plant","1201");
                 		poItem.put("plant",ifnull(expendedata.Plant.Plant,""));
                 		// dynamic
                 		poItem.put("itemText",expenseCategory);
                 		poItem.put("quantity","1.000");
                 		poItem.put("unit","LE");
                 		poItem.put("netPrice",lineAmount);
                 		poItem.put("taxCode",taxCode);
                 		poItem.put("controlCode",controlCode);
                 		poItem.put("materialGroup",materialGroup);
                 		poItem.put("storageLocation","");
                 		poItem.put("schedule",scheduleMap);
                 		poItem.put("Services",servicesList);
                 		poItemsList.add(poItem);
                 		itemCounter = itemCounter + 10;
                 	}
                 	// 	info poItemsList;
                 	sapPayload = Map();
                 	sapPayload.put("poHeader",headermap);
                 	sapPayload.put("poItems",poItemsList);
                 	jsonPayload = sapPayload.toString();
                 	//	info jsonPayload;
                 	response = invokeurl
                 	[
                 		url :"https://www.zohoapis.in/crm/v7/functions/testfunc/actions/execute?auth_type=apikey&zapikey=1003.39fc3833f02c1bdc6b94501fbb49565f.9606408102d38e58538a704592709e01"
                 		type :POST
                 	];
                 	if(response.get("code") == "success")
                 	{
                 		details = response.get("details");
                 		authToken = details.get("output");
                 		headermap = Map();
                 		headermap.put("Authorization","Bearer " + authToken.toString());
                 		headermap.put("Content-Type","application/json");
                 		geturl = "https://sap-cpi-dev-k6iny30n.it-cpi004-rt.cfapps.ap11.hana.ondemand.com/http/ServicePOCreationQAS";
                 		info jsonPayload;
                 		createservicepo = invokeurl
                 		[
                 			url :geturl
                 			type :POST
                 			parameters:jsonPayload.toString()
                 			headers:headermap
                 		];
                 		info "line 102" + createservicepo;
                 	}
                 	insertLog = insert into Log_Master
                 	[
                 		Added_User=zoho.loginuser
                 		Module_Name="Expense"
                 		Trigger="Create"
                 		RecordID=id.toString()
                 		Response=createservicepo.toString()
                 		Sync_From="Creator"
                 		Sync_To="SAP"
                 		Created_Time=zoho.currenttime
                 		Function_Workflow="createservicePOCPI"
                 	];
                 }
