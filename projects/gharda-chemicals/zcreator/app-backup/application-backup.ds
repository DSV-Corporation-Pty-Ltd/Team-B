			fetch_Distributor_data as "fetch Distributor data"
			{
				type =  form
				form = Order_Management

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											loginemail = zoho.loginuserid;
										// rec = Distributor_Master[Email == loginemail && Primary_Distributor == true];
										rec = Distributor_Master[Email == loginemail];
										if(rec.count() > 0)
										{
											//exception condition start here
											input.Due_Date = today.addDay(90);
											disable Due_Date;
											distID = rec.Account_CRM_record_ID;
											accmap = Map();
											accmap.put("distributor_id",distID.toString());
											// 	alert accmap;
											// 	https://www.zohoapis.in/crm/v7/functions/checkoverdueinvoice/actions/execute?auth_type=apikey&zapikey=1003.39fc3833f02c1bdc6b94501fbb49565f.9606408102d38e58538a704592709e01
											//     	parameters: accmap.toString()
											var = invokeurl
											[
												url :"https://www.zohoapis.in/crm/v7/functions/checkoverdueinvoice/actions/execute?auth_type=apikey&zapikey=1003.39fc3833f02c1bdc6b94501fbb49565f.9606408102d38e58538a704592709e01&distributor_id=" + distID
												type :POST
												connection:"zoho_oauth_connection"
											];
											if(var.get("code") == "success")
											{
												details = var.get("details");
												if(details.get("output") == true)
												{
													alert "You have bills overdue by 90 days, please clear bills first.";
													openUrl("#Report:View_Orders","same window");
												}
											}
											// 	if(var.get())
											input.Order_Description = rec.Distributor_Name + " - Order";
											orderTrigger = false;
											if(distID != null)
											{
												criteria = "((Distributor:equals:" + distID.toString() + ") and (Status:equals:Approved))";
												othermap = Map();
												othermap.put("sort_by","Created_Time");
												othermap.put("sort_order","desc");
												getException = zoho.crm.searchRecords("Exception_Case",criteria,0,200,othermap,"zoho_oauth_connection");
												//getException = zoho.crm.searchRecords("Exception_Case",criteria,0,200,othermap,"zohocrm_connection");
												if(getException.isEmpty() == false)
												{
													for each  Exception in getException
													{
														status = Exception.get("Status");
														if(status == "Approved")
														{
															orderTrigger = True;
														}
													}
												}
											}
											//exception cond end here
											input.Distributor_Name = rec.ID;
											statusList = {"Unpaid","Payment Pending","Open"};
											invoices = Invoice[Distributor_Name == input.Distributor_Name && Status in statusList];
											input.Email = invoices.count().toString();
											overdue = false;
											if(invoices.count() > 0)
											{
												for each  inv in invoices
												{
													inv_date = inv.Invoice_Date;
													age = daysBetween(inv_date,today);
													if(age > 90)
													{
														overdue = true;
													}
												}
											}
											input.Status = "Pending";
											// 	if(overdue && orderTrigger == false)
											// 	{
											// 		thisapp.SMS.sendSMSInvoiceOverdewInSO(input.ID);
											// 		alert "You have invoices overdue by more than 90 days. Please clear outstanding dues to proceed with a new order.";
											// 		input.Distributor_Name = null;
											// 		Plantcode = null;
											// 		input.Email = "";
											// 	}
											// 	else
											// 	{
											if(input.Order_Type.isEmpty() == true)
											{
												openUrl("#Form:Popup_Form?zc_BgClr=#34ebd2&zc_Header=false","popup window","height=154px,width=410px");
											}
											getcont = Contact[Distributor_Master == rec];
											if(getcont.count() > 0)
											{
												input.Contact_Name = getcont.Contact_Name;
												input.Contact_Number = getcont.Contact_Number;
											}
											input.Distributor_Name = rec.ID;
											input.Plant = rec.Plant;
											input.Customer_Group = rec.Customer_Group;
											input.Customer_Code = rec.Customer_Code;
											input.Email = rec.Email;
											input.Billing_Street = rec.Billing_Street;
											input.Billing_City = rec.Billing_City;
											input.Billing_State = rec.Billing_State;
											input.Billing_Country = rec.Billing_Country;
											input.Billing_Code = rec.Billing_Code;
											input.Region = rec.Region;
											input.Territory = rec.Territory;
											getAllDistributor = Distributor_Master[Email == loginemail].ID.getAll();
											if(getAllDistributor.size() > 0)
											{
												input.Shipping_Addresses:ui.add(getAllDistributor);
											}
											if(getAllDistributor.size() == 1)
											{
												hide Shipping_Addresses;
												input.Shipping_Street = rec.Billing_Street;
												input.Shipping_City = rec.Billing_City;
												input.Shipping_State = rec.Billing_State;
												input.Shipping_Country = rec.Billing_Country;
												input.Shipping_Code = rec.Billing_Code;
											}
											if(input.Order_Type == "Cash Advance Order")
											{
												// 			input.Advance_Deposit = rec.Advance_Deposit;
												hide Available_Credit_Limit;
												input.Due_Date = zoho.currentdate;
											}
											else if(input.Order_Type == "Credit Limit Order")
											{
												// 			input.Available_Credit_Limit = rec.Credit_Limit;
												hide Advance_Deposit;
												if(rec.Credit_Limit <= 1)
												{
													alert "Your credit limit is not sufficient to create this order";
													openUrl("#Report:View_Orders","same window");
												}
											}
											// 	}
											Plantcode = input.Plant.Plant;
											SAPID = rec.Distributor_SAP_ID;
											if(SAPID.isEmpty() == false)
											{
												othermap = Map();
												regionCode = "";
												//searchRec = zoho.crm.searchRecords("Accounts","SAP_ID:equals:" + SAPID.toString(),0,200,othermap,"zohocrm_connection");
												searchRec = zoho.crm.searchRecords("Accounts","SAP_ID:equals:" + SAPID.toString(),0,200,othermap,"zoho_oauth_connection");
												if(searchRec.size() > 0)
												{
													input.Available_Credit_Limit = searchRec.get(0).get("Credit_Limit");
													// 			alert searchRec.get(0).get("Credit_Limit");
													input.Advance_Deposit = searchRec.get(0).get("Advance_Deposit");
													regionCode = searchRec.get(0).get("RG");
													if(regionCode.isEmpty() == false)
													{
														//searchReg = zoho.crm.searchRecords("CGST_Rates","Name:equals:" + regionCode.toString(),0,200,othermap,"zohocrm_connection");
														searchReg = zoho.crm.searchRecords("CGST_Rates","Name:equals:" + regionCode.toString(),0,200,othermap,"zoho_oauth_connection");
														if(searchReg.size() > 0)
														{
															input.CGST = ifnull(searchReg.getJson("CGST"),0);
															input.SGST = ifnull(searchReg.getJson("SGST"),0);
														}
														//searchPlant = zoho.crm.searchRecords("Plants_Master","Name:equals:" + Plantcode.toString(),0,200,othermap,"zohocrm_connection");
														searchPlant = zoho.crm.searchRecords("Plants_Master","Name:equals:" + Plantcode.toString(),0,200,othermap,"zoho_oauth_connection");
														if(searchPlant.size() > 0)
														{
															getreg = searchPlant.get(0).get("Region");
															//searchIGST = zoho.crm.searchRecords("CGST_Rates","Name:equals:" + getreg.toString(),0,200,othermap,"zohocrm_connection");
															searchIGST = zoho.crm.searchRecords("CGST_Rates","Name:equals:" + getreg.toString(),0,200,othermap,"zoho_oauth_connection");
															if(searchIGST.size() > 0)
															{
																//alert "regionCode"+regionCode;alert "getreg"+getreg;
																if(regionCode != getreg)
																{
																	//alert regionCode;alert getreg;
																	input.IGST = ifnull(searchIGST.getJson("IGST"),0);
																}
															}
														}
													}
												}
											}
											if(input.Order_Type == "Cash Advance Order")
											{
												if(input.Advance_Deposit > 0)
												{
													alert "You do not have sufficient advance amount for placing cash order. Please make credit order.";
													openUrl("#Report:View_Orders","same window");
												}
											}
										}
										hide CGST1;
										hide SGST1;
										hide IGST1;
						)
					}
				}

			}
