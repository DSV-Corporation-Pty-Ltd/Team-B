			Attendance_calculation as "Attendance calculation"
			{
				type =  form
				form = Attendance_Module

				record event = on add

				on user input of Check_Out_Time
				{
					actions 
					{
						custom deluge script
						(
											checkInTime = ifnull(input.Check_In_Time,0);
										checkOutTime = ifnull(input.Check_Out_Time,0);
										timeduration = checkOutTime.getHour() - checkInTime.getHour();
										input.Total_Working_Hours = timeduration;
						)
					}
				}

			}
			checkout_time as "checkout time"
			{
				type =  form
				form = Attendance_Module

				record event = on edit

				on user input of Status
				{
					actions 
					{
						custom deluge script
						(
											if(input.Status == "Checked Out" && input.Check_Out_Time == null)
										{
											input.Check_Out_Time = zoho.currenttime;
											mil_sec = (input.Check_Out_Time - input.Check_In_Time);
											actual_minutes = mil_sec / (1000 * 60);
											//1000 -> mill sec to sec, 60 -> sec to min
											mins = actual_minutes.toLong() % 60;
											// % 60 -> Exclude Hours
											hours = (actual_minutes / 60).toLong();
											// 60 -> min to hour, % 24 (optional) -> Exclude Days
											time_string = hours + " : " + mins;
											input.Total_Working_Hours = time_string;
										}
						)
					}
				}

			}
