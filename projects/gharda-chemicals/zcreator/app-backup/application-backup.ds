		form Verify_OTP
		{
			displayname = "Verify OTP"
			success message = "Status has been marked as Delivered"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Upload_Consignee_Copy
			(
    			type = upload file
				displayname = "Upload Consignee Copy"
				browse = local_drive
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Transporter_Image
			(
    			type = image
				displayname = "Transporter Image"
				source  = file
				aspect ratio = original
				camera = primary
				show gallery = true
				switch camera = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			plain
			(
    			type = plaintext
				value = "<div><b><span class=\"colour\" style=\"color: rgb(255, 0, 0)\">&nbsp;An OTP has been sent to distributor mobile. Kindly check and enter it below.</span></b><br /></div>"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Resend
			(
    			type = checkbox
				displayname = "Resend OTP"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Enter_OTP
			(
				type = number
				displayname = "Enter OTP"
	 			row = 1
	 			column = 1   
				width = medium
			)
			DispatchID
			(
				type = number
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					Mark_As_Delivered
					(
   						type = submit
   						displayname = "Mark As Delivered"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
