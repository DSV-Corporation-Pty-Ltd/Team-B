		page Payment
		{
			displayname = "Payment"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet3' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet3()\ncontent\n&lt;%{\n\trec = Distributor_Master[Email == zoho.loginuserid];\n\tadv = 0;\n\tif(rec.count() &gt; 0)\n\t{\n\t\tadv = ifnull(rec.Advance_Deposit,0);\n\t}\n\t// \tblanceamt = rec.Advance_Deposit \n\t%&gt;\n&lt;div style=&quot;padding:12px;border:1px solid #f59e0b;border-radius:10px;background:#fff7ed;font-family:Arial;&quot;&gt;\n  &lt;div style=&quot;font-size:14px;color:#7c2d12;font-weight:700;margin-bottom:6px;&quot;&gt;\n    Credit Balance is not sufficient for this order. Difference in amount: \u20B9&lt;%=adv%&gt;\n  &lt;/div&gt;\n\n  &lt;div style=&quot;font-size:13px;color:#111827;margin-bottom:10px;&quot;&gt;\n    Please reduce the order value or add Credit Balance from here.\n  &lt;/div&gt;\n\n  &lt;!-- Button \n\n  \t&lt;a href=&quot;https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/form-perma/Payment_Form/1b3WA9Xtzg3yTebUVOzSKzGwzg9USCJB4k7zmXsqJHwNkdrNvBej4UkjDrvq2harXxqKPjBrwzE7xCme3easTGKf6UkAYFtjXS6m?Distributor=&lt;%=rec.ID%&gt;&amp;zc_LoadIn=dialog&amp;height:600px;width=550px&quot; style=&quot;display:inline-block;background:#2563eb;color:#fff;padding:10px 14px;border-radius:8px;text-decoration:none;font-weight:700;&quot; target=&quot;_blank&quot;&gt;\n    Add Security Deposit\n  &lt;/a&gt;\n\n  &lt;div style=&quot;font-size:12px;color:#6b7280;margin-top:10px;&quot;&gt;\n    * You will be redirected to the payment gateway.\n  &lt;/div&gt;--&gt;\n&lt;/div&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
