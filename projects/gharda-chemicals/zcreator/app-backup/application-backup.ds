			RCM_IGST
			(
    			type = text
				displayname = "RCM IGST"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Tax
			(
    			type = percentage
				displayname = "Tax %"
	 			row = 1
	 			column = 2   
				width = medium
			)
			Tax_Amount
			(
				displayname = "Tax Amount"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Amount
			(
				displayname = "Grand Total"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			Upload_Receipt
			(
    			type = upload file
				displayname = "Upload Receipt"
				browse = local_drive
	 			row = 1
	 			column = 2   
				width = medium
			)
			Status
			(
				type = picklist
				maxchar = 100
				values = {"Reimbursed","Approved","Rejected","Submitted","Pending"}
				initial value = "Pending"
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Expenses
			(
				type = grid
				values  = Expense_Line_Items.ID
    			bidirectional = Expense_Master
	 			row = 2
	 			column = 1   
				width = medium
			)
			Total_Expense_Details
			(
				type = section
				displayname = "Total Expense Details"
				visibility = true
	 			row = 3
	 			column = 0   
				width = medium
			)
			Total_Tax_Amount
			(
				displayname = "Total Tax Amount"
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 1   
				width = medium
			)
			Grand_Total
			(
				displayname = "Grand Total"
				type = INR
				format = commadotindian
	 			row = 3
	 			column = 1   
				width = medium
			)
			Backend_Fields
			(
				type = section
				displayname = "Backend Fields"
				visibility = true
	 			row = 4
	 			column = 0   
				width = medium
			)
			Plant1
			(
    			type = text
				displayname = "Plant"
	 			row = 4
	 			column = 1   
				width = medium
			)
			Zoho_Expense_ID
			(
    			type = text
				displayname = "Zoho Expense ID"
	 			row = 4
	 			column = 1   
				width = medium
			)
			Report_Response
			(
    			type = richtext
				displayname = "Report Response"
				height = 200px
				toolbar = enable
				[
					style, font-color, background-color, link, bullets-and-numbering, 
					font-size : {1, 2, 3, 4, 5, 6, 7}
				]
	 			row = 4
	 			column = 1   
				width = medium
			)
			Expense_Response
			(
    			type = richtext
				displayname = "Expense Response"
				height = 200px
				toolbar = enable
				[
					style, font-color, background-color, link, bullets-and-numbering, 
					font-size : {1, 2, 3, 4, 5, 6, 7}
				]
	 			row = 4
	 			column = 1   
				width = medium
			)
			MerchantID
			(
    			type = text
	 			row = 4
	 			column = 2   
				width = medium
			)
			ReportID
			(
    			type = text
	 			row = 4
	 			column = 2   
				width = medium
			)
			Merchant_Response
			(
    			type = richtext
				displayname = "Merchant Response"
				height = 200px
				toolbar = enable
				[
					style, font-color, background-color, link, bullets-and-numbering, 
					font-size : {1, 2, 3, 4, 5, 6, 7}
				]
	 			row = 4
	 			column = 2   
				width = medium
			)
			Current_Level
			(
    			type = text
				displayname = "Current Level"
	 			row = 4
	 			column = 2   
				width = medium
			)
			Current_Approver
			(
    			type = text
				displayname = "Current Approver"
	 			row = 4
	 			column = 2   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
