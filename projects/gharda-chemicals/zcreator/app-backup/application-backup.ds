			update_Liquidity_in_Creat as "update Liquidity in Creator"
			{
				type =  form
				form = Liquidation_Capture

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											fromDate = zoho.currentdate.addMonth(-2);
										so_ids = Order_Management[Distributor_Name == input.Distributor_Name && Order_Date >= fromDate].ID.getAll();
										all_caps = Liquidation_Capture[Distributor_Name == input.Distributor_Name];
										liqMap = Map();
										for each  cap in all_caps
										{
											for each  prow in cap.Product_Line_Items
											{
												code = ifnull(prow.Product_Code,"");
												liqMap.put(code,ifnull(liqMap.get(code),0) + ifnull(prow.Liquidate_Quantity,0));
											}
										}
										for each  code in liqMap.keys()
										{
											toConsume = ifnull(liqMap.get(code),0);
											lines = Order_Line_Items[Order_Management in so_ids && Product_Code == code] sort by ID asc;
											for each  li in lines
											{
												qty = ifnull(li.Quantity,0);
												if(toConsume >= qty && qty > 0)
												{
													li.Liquidate_Done=true;
													toConsume = toConsume - qty;
												}
												else
												{
													li.Liquidate_Done=false;
												}
											}
										}
						)
					}
				}

			}
