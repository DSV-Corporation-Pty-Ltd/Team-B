										{
											// 	getallplants = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid].Plant.getAll();
											getallplants = CNF_Master[Billing_Person_Email_Id == zoho.loginuserid].Plant.getAll();
											input.Plant1:ui.add(getallplants);
										}
										if(getCNFData.count() > 0 && getCNFData.count() == 1)
										{
											input.CNF_Name = getCNFData.ID;
											input.Plant1 = getCNFData.Plant;
											// 	input.Billing_State = getCNFData.State;
											// 	input.Billing_City = getCNFData.City;
											// 	input.Billing_Country = getCNFData.Country;
											// 	input.Billing_Street = getCNFData.Street;
											// 	input.Billing_Code = getCNFData.Zipcode;
											// 	input.Shipping_State = getCNFData.Shipping_State;
											// 	input.Shipping_City = getCNFData.Shipping_City;
											// 	input.Shipping_Country = getCNFData.Shipping_Country;
											// 	input.Shipping_Street = getCNFData.Shipping_Street;
											// 	input.Shipping_Code = getCNFData.Shipping_Code;
											input.Region = getCNFData.Region;
											input.Plant = getCNFData.Plant.Plant;
											disable Plant1;
										}
						)
					}
				}

			}
			on_the_user_input_of_requ as "on the user input of requested quantity"
			{
				type =  form
				form = RFQ

				record event = on add or edit

				on user input of Line_Items.Requested_Quantity
				{
					actions 
					{
						custom deluge script
						(
											if(row.Requested_Quantity.isNull() == false)
										{
											if(row.Requested_Quantity <= 0)
											{
												alert "Requested Quantity should not be 0 or negative value.";
												row.Requested_Quantity=null;
											}
											else if(row.Requested_Quantity % 10 != 0)
											{
												alert "Requested Quantity should be a multiple of 10.";
												row.Requested_Quantity=null;
											}
											else
											{
												getpro = Product_Master[Product_Code == row.Product_Code];
												if(getpro.count() > 0)
												{
													if(getpro.Delivery_Unit.isEmpty() == false)
													{
														row.No_of_Box=ifnull(row.Requested_Quantity,0) / ifnull(getpro.Delivery_Unit,0);
														row.Total_Gross_Weight=ifnull(row.No_of_Box,0) * ifnull(row.Gross_Weight,0);
													}
													else
													{
														alert "Delivery Unit not available for this product.";
													}
												}
											}
										}
										totalqty = 0;
										totalNoB = 0;
										totalGW = 0;
										if(row.Requested_Quantity > 0)
										{
											for each  products in input.Line_Items
											{
												totalqty = totalqty + ifnull(products.Requested_Quantity,0);
												totalNoB = totalNoB + ifnull(products.No_of_Box,0);
												totalGW = totalGW + ifnull(products.Total_Gross_Weight,0);
											}
										}
										input.Total_Requested_Quantity = totalqty;
										input.Total_nos_of_boxes = totalNoB;
										input.Total_Gross_Weight = totalGW;
						)
					}
				}

			}
