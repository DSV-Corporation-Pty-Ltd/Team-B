			on_edit_success as "on edit success"
			{
				type =  form
				form = GRN_Master

				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											getGRNMasterData = GRN_Master[Return_Sales_Order == input.Return_Sales_Order];
										getGRNata = GRN_Master[Return_Sales_Order == getGRNMasterData.Return_Sales_Order].Delivery_Status.getAll();
										input.Delivery_Status = "Delivered";
										if(getGRNata.size() > 0)
										{
											if(getGRNata.contains("Partially Delivered") == false)
											{
												getRSData = Return_Sales_Order[ID == input.Return_Sales_Order];
												if(getRSData.count() > 0)
												{
													getRSData.Status="Completed";
												}
											}
										}
						)
					}
				}

			}
