			get_batch_number1 as "get batch number"
			{
				type =  form
				form = Customer_Dispatch

				record event = on add or edit

				on user input of Line_Items.SKU
				{
					actions 
					{
						custom deluge script
						(
											if(row.SKU != null)
										{
											selectedProduct = Product_Master[ID == row.SKU];
											if(selectedProduct.count() > 0)
											{
												row.Batch_Number=selectedProduct.Batch_Number;
											}
											else
											{
												row.Batch_Number=null;
											}
										}
										else
										{
											row.Batch_Number=null;
										}
										// if(row.Product_Name != null)
										// {
										// 	pricingRecord = Price_Master[SKU == row.SKU];
										// 	if(pricingRecord != null)
										// 	{
										// 		row.Price=pricingRecord.Final_Price;
										// 	}
										// 	else
										// 	{
										// 		row.Price=null;
										// 	}
										// }
										duplicateFound = false;
										currentProduct = row.Product_Name;
										currentSKU = row.SKU;
										for each  lineItem in input.Line_Items
										{
											if(lineItem != row)
											{
												if(lineItem.Product_Name == currentProduct && lineItem.SKU == currentSKU)
												{
													duplicateFound = true;
													break;
												}
											}
										}
										if(duplicateFound)
										{
											alert "This product with same SKU is already added. Please increase the quantity in the existing row.";
											row.Product_Name=null;
											row.SKU=null;
											row.Batch_Number=null;
											row.Total=null;
											row.Price=null;
										}
						)
					}
				}

			}
