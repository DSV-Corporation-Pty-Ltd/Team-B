			hide_and_disable_fields7 as "hide and disable fields"
			{
				type =  form
				form = Expense_Master

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Expenses.Quantity;
										hide Enter_Quantity;
										hide Backend_Fields;
										hide Tax_Amount;
										disable CNF_Name;
										hide Amount;
										hide CGST;
										hide SGST;
										hide IGST;
										hide Vendor_Name_Pro;
										hide CSGST;
										hide RCM_CGST;
										hide RCM_IGST;
										hide RCM;
										hide Tax;
										hide CGST;
										hide IGST;
										hide SGST;
										hide CSGST;
										hide RCM_CGST;
										hide RCM_IGST;
										hide RCM;
										hide Tax;
										hide Expense_No;
										hide Status;
										hide Expense_Type;
										hide GL_Code;
										hide Upload_Receipt;
										hide Expense_Category;
										hide Description;
										hide Amount1;
										hide Amount;
										// getCNFData = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid];
										getCNFData = CNF_Master[Billing_Person_Email_Id == zoho.loginuserid];
										if(getCNFData.count() > 0 && getCNFData.count() > 1)
										{
											// 	getallplants = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid].Plant.getAll();
											getallplants = CNF_Master[Billing_Person_Email_Id == zoho.loginuserid].Plant.getAll();
											input.Plant:ui.add(getallplants);
										}
										if(getCNFData.count() > 0 && getCNFData.count() == 1)
										{
											input.CNF_Name = getCNFData.ID;
											input.Plant = getCNFData.Plant;
											input.Plant1 = getCNFData.Plant.Plant;
											disable Plant;
										}
										categories = Expense_Category[ID != 0].Category.getAll();
										if(categories.size() > 0)
										{
											distinctCat = categories.distinct();
											finalList = List();
											for each  cat in distinctCat
											{
												rec = Expense_Category[Category == cat];
												if(rec != null)
												{
													finalList.add(rec.ID);
												}
											}
											input.Expense_Category:ui.add(finalList);
											input.Expense_Category = input.Expense_Category;
										}
										//subform fields
										disable Expenses.Tax_Amount;
										disable Expenses.Total;
										//disable Expenses.Amount;
										disable Expenses.CGST;
										disable Expenses.SGST;
										disable Expenses.IGST;
										disable Expenses.CSGST;
										disable Expenses.RCM_CGST;
										disable Expenses.RCM_IGST;
										disable Expenses.RCM;
										disable Expenses.Tax;
										hide Expenses.CGST;
										hide Expenses.IGST;
										hide Expenses.SGST;
										hide Expenses.CSGST;
										hide Expenses.RCM_CGST;
										hide Expenses.RCM_IGST;
										hide Expenses.RCM;
										hide Expenses.Zoho_Expense_ID;
										hide Expenses.Expense_Response;
										disable Expenses.Tax;
										disable Expenses.Expense_Type;
										disable Expenses.GL_Code;
										disable Grand_Total;
										disable Total_Tax_Amount;
						)
					}
				}

			}
