				 void Notifications.ReturnSOC_QCNotification(int ReturnSOID)
                 {
                 	getReturnSO = Return_Sales_Order[ID == ReturnSOID];
                 	if(getReturnSO.count() > 0)
                 	{
                 		getReturnSO.Status="Completed";
                 		if(getReturnSO.CRMID.isEmpty() == false)
                 		{
                 			emptymap = Map();
                 			//getCRMReturndata = zoho.crm.getRecordById("Return_Sales_Order",getReturnSO.CRMID.toLong(),emptymap,"zohocrm_connection");
                 			getCRMReturndata = zoho.crm.getRecordById("Return_Sales_Order",getReturnSO.CRMID.toLong(),emptymap,"zoho_oauth_connection");
                 			if(getCRMReturndata.isEmpty() == false)
                 			{
                 				updateMap = Map();
                 				otherMap = Map();
                 				updateMap.put("Status","Completed");
                 				mp = Map();
                 				triggerList = List();
                 				triggerList.add("workflow");
                 				other = Map();
                 				other.put("trigger",triggerList);
                 				//updateInCRM = zoho.crm.updateRecord("Return_Sales_Order",getReturnSO.CRMID.toLong(),updateMap,other,"zohocrm_connection");
                 				updateInCRM = zoho.crm.updateRecord("Return_Sales_Order",getReturnSO.CRMID.toLong(),updateMap,other,"zoho_oauth_connection");
                 				info updateInCRM;
                 			}
                 		}
                 		// Fetch distributor details
                 		distributorName = ifnull(getReturnSO.Distributor_Name.Distributor_Name,"");
                 		distributorEmail = ifnull(getReturnSO.Distributor_Email.Email,"");
                 		salesOrderNo = ifnull(getReturnSO.Sales_Order.Order_Number,"");
                 		invoiceNo = ifnull(getReturnSO.Invoice.Invoice_Number,"");
                 		returnSONo = ifnull(getReturnSO.Return_No,"");
                 		// Email HTML Content
                 		email_body = "<html><body style='font-family:Arial, sans-serif;line-height:1.7;'>" + "<h2 style='color:#059669;'>QC Completed – Return Sales Order : " + returnSONo + "</h2>" + "<p>Dear <b>" + distributorName + "</b>,</p>" + "<p>We are pleased to inform you that the QC process for your return material has been successfully completed.</p>" + "<table border='1' cellpadding='7' cellspacing='0' style='border-collapse:collapse;width:70%;margin-top:10px;'>" + "<tr style='background-color:#059669;color:white;font-weight:bold;'><th>Detail</th><th>Value</th></tr>" + "<tr><td>Return Sales Order No.</td><td>" + returnSONo + "</td></tr>" + "<tr><td>Invoice No.</td><td>" + invoiceNo + "</td></tr>" + "<tr><td>Sales Order No.</td><td>" + salesOrderNo + "</td></tr>" + "</table><br>" + "<p>You may proceed further as required.</p>" + "<p><b>Regards,</b><br>Gharda Chemicals Team</p>" + "</body></html>";
                 		// Sending Email
                 		sendmail
                 		[
                 			from :zoho.loginuserid
                 			to :distributorEmail
                 			subject :"Return QC has been completed for – RSO No: " + returnSONo
                 			message :email_body
                 		]
                 	}
                 }
				 void Notifications.RFQNotificationtoLogistic(int RFQID)
                 {
                 	getRFQData = RFQ[ID == RFQID];
                 	if(getRFQData.count() > 0)
                 	{
                 		//getcfdata = CNF_Master[ID == getRFQData.CNF_Name];
                 		getLogisticData = Logistic_Master[CNF_Name == getRFQData.CNF_Name && Transport_Type == "Primary"];
                 		if(getLogisticData.count() > 0)
                 		{
                 			getTransEmails = List();
                 			for each  LogisticData in getLogisticData
                 			{
                 				getTransEmails.add(LogisticData.Email);
                 			}
                 		}
                 		//info getTransEmails;
                 		line_items = getRFQData.Line_Items;
                 		product_table = "<table border='1' cellpadding='6' cellspacing='0' style='border-collapse:collapse;width:100%;'><tr style='background-color:#2563eb;color:white;'><th>Product Name</th><th>Product Code</th><th>Technical Name</th><th>Gross Weight</th><th>Requested Quantity</th><th>No of Box</th><th>Total Gross Weight</th></tr>";
                 		for each  item in getRFQData.Line_Items
                 		{
                 			product_table = product_table + "<tr><td>" + item.Product_Name.Product_Name + "</td><td>" + item.Product_Code + "</td><td>" + item.Technical_Name + "</td><td>" + item.Gross_Weight.toString() + "</td><td>" + item.Requested_Quantity.toString() + "</td><td>" + item.No_of_Box.toString() + "</td><td>" + item.Total_Gross_Weight.toString() + "</td></tr>";
                 		}
                 		product_table = product_table + "</table>";
                 		email_content = "<html><body style='font-family:Arial, sans-serif;'><h2 style='color:#2563eb;'>New RFQ Generated</h2><p>Dear Transporter,</p><p>A new RFQ has been generated by " + getRFQData.CNF_Name.CNF_Name + ". Please find the details below:</p><table style='width:100%;margin-bottom:20px;'><tr><td><b>RFQ No:</b></td><td>" + getRFQData.RFQ_No + "</td></tr><tr><td><b>RFQ Date:</b></td><td>" + getRFQData.RFQ_Date.toDate("dd-MMM-yyyy").toString("dd-MMM-yyyy") + "</td></tr><tr><td><b>Remarks:</b></td><td>" + getRFQData.Remarks + "</td></tr></table><h3>Product Details</h3>" + product_table + "<br><p><a href='https://ghardasalesportal.gharda.com/#Report:RFQ_Logistic' style='background-color:#2563eb;color:white;padding:10px 20px;text-decoration:none;border-radius:5px;'>View RFQ Details</a></p><p>Best regards,<br>" + getRFQData.CNF_Name.CNF_Name + "</p></body></html>";
                 		if(getTransEmails.size() > 0)
                 		{
                 			for each  emaill in getTransEmails
                 			{
                 				sendmail
                 				[
                 					from :zoho.loginuserid
                 					to :emaill
                 					subject :"New RFQ Generated - " + getRFQData.RFQ_No
                 					message :email_content
                 				]
                 			}
                 			thisapp.SMS.RFQRaisedByCNFSMSToLogistics(getRFQData.ID);
                 		}
                 	}
                 }
				 void Notifications.SendDispatchEmailToTrans(int DispatchID)
                 {
                 	dispatchRecord = Dispatch[ID == DispatchID];
                 	if(dispatchRecord.count() > 0)
                 	{
                 		dispatchNo = ifnull(dispatchRecord.Dispatch_No,"N/A");
                 		dispatchDate = ifnull(dispatchRecord.Dispatch_Date,zoho.currentdate);
                 		salesOrder = ifnull(dispatchRecord.Sales_Order.Order_Number,"N/A");
                 		transporterName = ifnull(dispatchRecord.Transporter_Name.Transporter_Name,"N/A");
                 		transporterEmail = ifnull(dispatchRecord.Transporter_Name.Email,"");
                 		// Make sure transporter email is available
                 		dispatchStatus = ifnull(dispatchRecord.Status,"Pending");
                 		htmlContent = "<html><body style='font-family:Arial,sans-serif;background-color:#f9f9f9;padding:20px;'>" + "<div style='max-width:600px;margin:auto;background:#fff;border-radius:10px;padding:20px;box-shadow:0 2px 6px rgba(0,0,0,0.1);'>" + "<h2 style='color:#2563eb;text-align:center;'>New Dispatch Assigned</h2>" + "<p>Dear <strong>" + transporterName + "</strong>,</p>" + "<p>A new dispatch has been created and assigned to you. Please find the details below:</p>" + "<table style='width:100%;border-collapse:collapse;margin-top:15px;'>" + "<tr><td style='padding:8px;border-bottom:1px solid #ddd;'><strong>Dispatch No.</strong></td><td style='padding:8px;border-bottom:1px solid #ddd;'>" + dispatchNo + "</td></tr>" + "<tr><td style='padding:8px;border-bottom:1px solid #ddd;'><strong>Dispatch Date</strong></td><td style='padding:8px;border-bottom:1px solid #ddd;'>" + dispatchDate.toString("dd-MMM-yyyy") + "</td></tr>" + "<tr><td style='padding:8px;border-bottom:1px solid #ddd;'><strong>Sales Order</strong></td><td style='padding:8px;border-bottom:1px solid #ddd;'>" + salesOrder + "</td></tr>" + "<tr><td style='padding:8px;border-bottom:1px solid #ddd;'><strong>Status</strong></td><td style='padding:8px;border-bottom:1px solid #ddd;'>" + dispatchStatus + "</td></tr>" + "</table>" + "<p style='margin-top:15px;'>Please log in to the portal to view or update the dispatch status.</p>" + "<hr style='border:none;border-top:1px solid #eee;margin:20px 0;'>" + "<p style='font-size:12px;color:#888;text-align:center;'>This is an automated notification. Please do not reply.</p>" + "</div></body></html>";
                 		if(transporterEmail != "")
                 		{
                 			sendmail
                 			[
                 				from :zoho.loginuserid
                 				to :transporterEmail
                 				subject :"New Dispatch Assigned - " + dispatchNo
                 				message :htmlContent
                 			]
                 		}
                 	}
                 }
				 void Notifications.SendQuotionCreateEmailtoCNF(int QuotationID)
                 {
                 	getQuoteData = Quotation[ID == QuotationID];
                 	if(getQuoteData.count() > 0)
                 	{
