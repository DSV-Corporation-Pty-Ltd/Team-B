			Check_Quantity_and_Calcul as "Check Quantity and Calculate Cost"
			{
				type =  form
				form = SRF_Master

				record event = on add or edit

				on user input of Free_Sample_Line_Items.Qty_in_Kgs
				{
					actions 
					{
						custom deluge script
						(
											if(row.Qty_in_Kgs.isNull() == false)
										{
											if(row.Qty_in_Kgs <= 0)
											{
												alert "Quantity should not be 0 or negative value.";
												row.Qty_in_Kgs=null;
											}
											else
											{
												row.Total_Cost=ifnull(row.Qty_in_Kgs,0) * ifnull(row.Basic_Cost,0) + ifnull(row.Transport_Cost,0) + ifnull(row.Other_Cost,0);
											}
										}
						)
					}
				}

			}
