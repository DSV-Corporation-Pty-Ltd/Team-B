			on_create_success as "on create success"
			{
				type =  form
				form = Invoice

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											thisapp.AutoNumber.generateAutoNumber("Invoice",input.ID);
										getDistData = Distributor_Master[ID == input.Distributor_Name];
										if(getDistData.count() > 0)
										{
											if(getDistData.Plant.isNull() == false)
											{
												input.Plant = getDistData.Plant.Plant;
											}
										}
										if(input.Line_Items.isEmpty() == false)
										{
											for each  lineItems in input.Line_Items
											{
												productcode = lineItems.Product_Code;
												plantcode = input.Plant;
												criteria = "((Name:equals:" + productcode.toString() + ") and (Plant:equals:" + plantcode.toString() + "))";
												othermap = Map();
												searchRec = zoho.crm.searchRecords("Product_Inventory",criteria,1,200,othermap,"zohocrm_connection");
												if(searchRec != null && searchRec.isEmpty() == false)
												{
													for each  rec in searchRec
													{
														batch = ifnull(rec.get("Batch"),"");
														lineItems.Batch_Number=batch;
													}
												}
											}
										}
						)
					}
				}

			}
			duplicate_meetings as "duplicate meetings"
			{
				type =  form
				form = Meeting

				record event = on add or edit

				on validate
				{
					actions 
