		list Quotations
		{
			displayName = "Quotations"
			show all rows from Quotation  [Approval_1_Email == zoho.loginuserid || Approval_2_Email == zoho.loginuserid || Approval_3_Email == zoho.loginuserid || Approval_4_Email == zoho.loginuserid || Approval_5_Email == zoho.loginuserid]  
			(
				Quotation_No as "Quotation No."
				RFQ
				Transporter_Name as "Transporter Name"
				Quotation_Date as "Quotation Date"
				Freight_Type as "Freight Type"
				Transit_Time as "Transit Time (In Days)"
				Valid_Till as "Valid Till"
				Remarks
				Status
				Grand_Total as "Grand Total"
				Billing_Street as "Billing Street"
				Billing_City as "Billing City"
				Billing_State as "Billing State"
				Billing_Country as "Billing Country"
				Billing_Code as "Billing Code"
				Shipping_Street as "Shipping Street"
				Shipping_City as "Shipping City"
				Shipping_State as "Shipping State"
				Shipping_Country as "Shipping Country"
				Shipping_Code as "Shipping Code"
				RFQ.CNF_Name as "CNF Name"
				Sub_Total as "Sub Total"
				CGST as "CGST %"
				CGST_Val as "CGST Val"
				IGST as "IGST %"
				IGST_Val as "IGST Val"
				Tax_Amount as "Tax Amount"
				custom action "View Quotation"
				(
	  			workflow = View_Quotation
				show action in edit record menu = true
				column header = "View Quotation"
				)
				Freight_Rate as "Freight Rate"
				custom action "Approve"
				(
	  			workflow = Approve1
				show action in edit record menu = true
				column header = "Approve"
				condition = ((Status == "Pending" && Status != "Approved" && Approval_5_Email != zoho.loginuserid && Current_Level == "1" && Quotation_Approved == false) || (Approval_5_Email == zoho.loginuserid && Status == "Pending" && Status != "Approved" && Current_Level == "2" && Level1_Approved == "Yes" && Quotation_Approved == false))
				confirmation before execution
				(
					message for individual record = "Aye you sure you want to approve this Quotation?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Reject"
				(
	  			workflow = Reject1
				show action in edit record menu = true
				column header = "Reject"
				condition = ((Status != "Approved" && Status == "Pending" && Approval_5_Email != zoho.loginuserid && Current_Level == "1" && Quotation_Approved == false) || (Current_Level == "2" && Approval_5_Email == zoho.loginuserid && Status == "Pending" && Level1_Approved == "Yes" && Quotation_Approved == false))
				confirmation before execution
				(
					message for individual record = "Are you sure you want to Reject this Quotation?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Approved_By as "Approved By"
				Current_Level as "Current Level"
				Added_Time as "Added Time"
				SGST as "SGST %"
				SGST_Val as "SGST Val"
			)
			sort by
			(
				Added_Time descending
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Quotation_No'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '20px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'RFQ'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	padding = '0px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '27'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#132437'\n    borderWidth = '0px'\n\n	  value = 'Quotation_Date'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#2D3C4D'\n    borderWidth = '0px'\n\n	  value = 'Grand_Total'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
		}
