	datasources
	{
		zohocrm_vendors
		{
			displayname = "ZohoCRM Vendors"
			module = Vendors
			connection = zohocrm_connection_sandbox
			category
			(
				type = text
				displayname = "Category"
				source field name = "Category"
				search operators = {"startsWith"}
			)
			city
			(
				type = text
				displayname = "City"
				source field name = "City"
				search operators = {"startsWith"}
			)
			country
			(
				type = text
				displayname = "Country"
				source field name = "Country"
				search operators = {"startsWith"}
			)
			description
			(
				type = textarea
				displayname = "Description"
				source field name = "Description"
			)
			email
			(
				type = email
				displayname = "Email"
				source field name = "Email"
				search operators = {"startsWith"}
			)
			gl_account
			(
				type = picklist
				displayname = "GL Account"
				source field name = "GL_Account"
				search operators = {"startsWith"}
				values = {"Interest Income","Rental Income","Sales-Hardware","Sales-Software"}
			)
			phone
			(
				type = text
				displayname = "Phone"
				source field name = "Phone"
				search operators = {"startsWith"}
			)
			state
			(
				type = text
				displayname = "State"
				source field name = "State"
				search operators = {"startsWith"}
			)
			street
			(
				type = text
				displayname = "Street"
				source field name = "Street"
				search operators = {"startsWith"}
			)
			must have vendor_name
			(
				type = text
				displayname = "Vendor Name"
				source field name = "Vendor_Name"
				search operators = {"startsWith"}
			)
			vendorid
			(
				type = text
				displayname = "VENDORID"
				source field name = "VENDORID"
				primary = true
				report only = true
			)
			website
			(
				type = url
				displayname = "Website"
				source field name = "Website"
			)
			zip_code
			(
				type = text
				displayname = "Zip Code"
				source field name = "Zip_Code"
				search operators = {"startsWith"}
			)
		}
