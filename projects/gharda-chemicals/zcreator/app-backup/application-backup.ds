			(
    			type = text
				displayname = "Expense No"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Created_On
			(
    			type = datetime
				displayname = "Created On"
				initial value = "${zoho.currenttime}"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Expense_Date
			(
    			type = date
				displayname = "Expense Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Expense_Category
			(
				type = picklist	
				displayname = "Expense Category"
				values  = Expense_Category[Type_field == "FA"].ID
