			populate_Export_Customer_ as "populate Export Customer and PO"
			{
				type =  form
				form = Proforma_Invoice

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											getOrderData = Purchase_Order[ID == input.PO_No];
										if(getOrderData.count() > 0)
										{
											input.Customer = getOrderData.Customer;
											input.PO_Date = getOrderData.PO_Date;
											input.Billing_State = getOrderData.Billing_State;
											input.Billing_City = getOrderData.Billing_City;
											input.Billing_Code = getOrderData.Billing_Code;
											input.Billing_Street = getOrderData.Billing_Street;
											input.Billing_Country = getOrderData.Billing_Country;
											input.Billing_Phone = getOrderData.Phone_Number;
											input.Shipping_Street = getOrderData.Shipping_Street;
											input.Shipping_Country = getOrderData.Shipping_Country;
											input.Shipping_State = getOrderData.Shipping_State;
											input.Shipping_Code = getOrderData.Shipping_Code;
											input.Shipping_City = getOrderData.Shipping_City;
											input.Shipping_Phone = getOrderData.Phone_Number1;
											clear Line_Items;
											if(getOrderData.Line_Items.isEmpty() == false)
											{
												getPIData = Proforma_Invoice[PO_No == input.PO_No];
												subtotal = 0;
												for each  items in getOrderData.Line_Items
												{
													rowData = Proforma_Invoice.Line_Items();
													rowData.Product_Name=items.Product_Name;
													rowData.Product_Code=items.Product_Code;
													rowData.SKU=items.SKU;
													rowData.Batch_Number=items.Batch_Number;
													rowData.Price=items.Price;
													rowData.Quantity=items.Quantity;
													rowData.Total=items.Total;
													rowData.Remarks=items.Remarks;
													subtotal = subtotal + ifnull(items.Total,0.0);
													rowcoll = Collection();
													rowcoll.insert(rowData);
													input.Line_Items.insert(rowcoll);
												}
												input.Sub_Total = ifnull(subtotal,0);
												input.Tax = ifnull(getOrderData.Tax,0);
												input.Tax_Amount = ifnull(getOrderData.Tax_Amount,0);
												input.Grand_Total = ifnull(subtotal,0);
											}
										}
						)
					}
				}

			}
