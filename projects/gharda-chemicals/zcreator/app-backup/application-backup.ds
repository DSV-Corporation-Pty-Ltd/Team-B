			duplicate_leave_request as "duplicate leave request"
			{
				type =  form
				form = Leave_Request

				record event = on add

				on validate
				{
					actions 
					{
						custom deluge script
						(
											existingLeaves = Leave_Request[Liquidation_Agent_Name == input.Liquidation_Agent_Name && (From >= input.From && From <= input.To) || (To >= input.From && To <= input.To) || (From >= input.From && From <= input.To)];
										if(existingLeaves.count() > 0)
										{
											alert "You have already applied for leave in this date range. Multiple leaves for the same day are not allowed.";
											cancel submit;
										}
										if(input.From != null)
										{
											dow = input.From.getDayOfWeek();
											if(dow == 1 || dow == 7)
											{
												alert "Leave cannot be applied on weekends.";
												cancel submit;
											}
										}
						)
					}
				}

			}
