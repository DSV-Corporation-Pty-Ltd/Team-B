			validtions_on_credit_and_ as "validtions on credit and edit success"
			{
				type =  form
				form = Order_Management

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Order_Type == "Credit Limit Order")
										{
											getdisData = Distributor_Master[ID == input.Distributor_Name];
											if(getdisData.count() > 0)
											{
												if(input.Advance_Deposit > 0)
												{
													newamount = ifnull(input.Advance_Deposit,0) - ifnull(input.Available_Credit_Limit,0);
													if(input.Grand_Total > abs(newamount.toDecimal()))
													{
														alert "You do not have sufficient credit limit for this order. Available limit: ₹" + ifnull(abs(newamount),0) + ". Please reduce the order value.";
														// 			input.Line_Items.Quantity = null;
														cancel submit;
													}
												}
												if(input.Advance_Deposit < 0)
												{
													newamt = ifnull(abs(input.Advance_Deposit),0) + ifnull(input.Available_Credit_Limit,0);
													if(input.Grand_Total > abs(newamt.toDecimal()))
													{
														alert "You do not have sufficient credit limit for this order. Available limit: ₹" + ifnull(abs(newamt),0) + ". Please reduce the order value.";
														// 			input.Line_Items.Quantity = null;
														cancel submit;
													}
												}
												// 		alert input.Grand_Total;
												// 		alert newamount;
											}
										}
										getAllDistributor = Distributor_Master[Email == zoho.loginuserid].ID.getAll();
										if(getAllDistributor.size() > 1)
										{
											if(input.Shipping_Addresses.isEmpty() == true)
											{
												alert "Shipping address should not be empty.Kindly Select atleast one shipping address.";
												cancel submit;
											}
										}
										// if(input.Order_Type == "Cash Advance Order")
										// {
										// 	getdisData = Distributor_Master[ID == input.Distributor_Name];
