			on_the_user_input_of_due_1 as "on the user input of due date"
			{
				type =  form
				form = Purchase_Order

				record event = on add or edit

				on user input of Due_Date
				{
					actions 
					{
						custom deluge script
						(
											if(input.PO_Date.isNull() == false && input.Due_Date.isNull() == false)
										{
											if(input.Due_Date < input.PO_Date)
											{
												alert "Due Date should be earlier than PO date";
												input.Due_Date = null;
											}
											if(input.Due_Date < zoho.currentdate)
											{
												alert "Due Date should not be past date";
												input.Due_Date = null;
											}
										}
						)
					}
				}

			}
