			resend_OTP as "resend OTP"
			{
				type =  form
				form = Verify_OTP

				record event = on add or edit

				on user input of Resend
				{
					actions 
					{
						custom deluge script
						(
											getdispatchData = Dispatch[ID == input.DispatchID];
										if(getdispatchData.count() > 0)
										{
											getdisadata = Distributor_Master[ID == getdispatchData.Distributor];
											if(getdisadata.count() > 0)
											{
												disphone = getdisadata.Contact_Number;
												if(disphone.isEmpty() == false)
												{
													last10 = right(disphone,10);
													otp = input.Enter_OTP;
													resp = thisapp.OTP.ResendOTP(last10.toString());
													if(resp.get("type") == "error")
													{
														alert resp.get("message");
														input.Enter_OTP = null;
													}
													if(resp.get("type") == "success")
													{
														alert "OTP Resend Successfully.";
													}
												}
											}
										}
						)
					}
				}

			}
