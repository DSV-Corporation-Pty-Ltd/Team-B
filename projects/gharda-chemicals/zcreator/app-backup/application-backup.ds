		list Expenses
		{
			displayName = "Expenses"
			show all rows from Expense_Master  [Current_Approver == zoho.loginuserid]  
			(
				CNF_Name as "CNF Name"
				Expense_No as "Expense No."
				Expense_Date as "Expense Date"
				Upload_Receipt as "Upload Receipt"
				Expense_Category as "Expense Category"
				Description
				Amount as "Grand Total"
				Expense_Type as "Expense Type"
				Status
				Plant1 as "Plant"
				Current_Level as "Current Level"
				Current_Approver as "Current Approver"
				custom action "Approve"
				(
	  			workflow = Approve2
				show action in edit record menu = true
				column header = "Approve"
				condition = (Status == "Pending" || (Status == "Rejected" && Current_Approver == zoho.loginuserid))
				confirmation before execution
				(
					message for individual record = "Execute the Approve action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Reject"
				(
	  			workflow = Rejected
				show action in edit record menu = true
				column header = "Reject"
				condition = (Status == "Pending")
				confirmation before execution
				(
					message for individual record = "Execute the Reject action for this record?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				Grand_Total as "Grand Total"
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#FFFFFF'\n    borderWidth = '0px'\n\n	  value = 'Expense_No'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '20px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Expense_Category'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	padding = '0px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '27'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#132437'\n    borderWidth = '0px'\n\n	  value = 'Expense_Date'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#2D3C4D'\n    borderWidth = '0px'\n\n	  value = 'Amount'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
