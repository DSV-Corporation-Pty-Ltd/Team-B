			on_user_input_of_liquidat as "on user input of liquidate Quantity"
			{
				type =  form
				form = Liquidation_Capture

				record event = on add

				on user input of Product_Line_Items.Liquidate_Quantity
				{
					actions 
					{
						custom deluge script
						(
											entered = ifnull(row.Liquidate_Quantity,0);
										if(entered <= 0)
										{
											alert "Liquidate Quantity must be greater than 0 for product: " + row.Product_Name.Product_Name;
											row.Liquidate_Quantity=null;
											return;
										}
										prev_entered = ifnull(row.Prev_Liquidate_Quantity,0);
										qty = ifnull(row.Quantity,0);
										already = ifnull(row.Already_Liquidate_Quantity,0);
										remaining_before = qty - (already - prev_entered);
										if(remaining_before < 0)
										{
											remaining_before = 0;
										}
										if(entered > remaining_before)
										{
											alert "Liquidate Quantity cannot be greater than remaining quantity (" + remaining_before + ") for product: " + row.Product_Name.Product_Name;
											row.Liquidate_Quantity=null;
											return;
										}
										new_already = already - prev_entered + entered;
										new_balance = qty - new_already;
										if(new_balance < 0)
										{
											new_balance = 0;
										}
										row.Already_Liquidate_Quantity=new_already;
										row.Balance_Quantity=new_balance;
										row.Prev_Liquidate_Quantity=entered;
										row.Liquidate_Done=true;
						)
					}
				}

			}
