 application "Gharda Chemical"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Kolkata"
 	time format = "24-hr"

 	forms
	{
		form Expense_Master
		{
			displayname = "Add Expense"
			success message = "Expense Master Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Plant
			(
				type = picklist	
				values  = Plants_Master.ID
    			displayformat = [Plant]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Expense_Category
			(
				type = picklist	
				displayname = "Expense Category"
				values  = Expense_Category[Type_field == "CNF"].ID
    			displayformat = [Category]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Enter_Quantity
			(
				type = number
				displayname = "Enter Quantity"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Expense_Date
			(
    			type = date
				displayname = "Expense Date"
				initial value = "${zoho.currentdate}"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Expense_Type
			(
				type = picklist	
				displayname = "Expense Type"
				values  = Expense_Category.ID
    			displayformat = [Expense_Type]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			GL_Code
			(
    			type = text
				displayname = "GL Code"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Description
			(
    			type = textarea
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			Expense_No
			(
    			type = text
				displayname = "Expense No."
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have CNF_Name
			(
				type = picklist	
				displayname = "CNF Name"
				values  = CNF_Master.ID
    			displayformat = [CNF_Name]
				sortorder = ascending
	 			row = 1
	 			column = 2   
				width = medium
			)
			must have Vendor_Name
			(
				type = picklist	
				displayname = "Vendor Name"
				datasource = zohocrm_vendors
    			displayformat = [vendor_name]
	 			row = 1
	 			column = 2   
				width = medium
			)
			Vendor_Name_Pro
			(
				type = picklist	
				displayname = "Vendor Name Pro"
				datasource = zohocrm_vendors_2
    			displayformat = [vendor_name]
	 			row = 1
	 			column = 2   
				width = medium
			)
			Amount1
			(
				displayname = "Amount"
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 2   
				width = medium
			)
			CGST
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			SGST
			(
    			type = text
	 			row = 1
	 			column = 2   
				width = medium
			)
			IGST
