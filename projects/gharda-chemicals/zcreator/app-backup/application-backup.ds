				 void SRFMaster.syncSRFmasterInCrm(int id)
                 {
                 	getSRFData = SRF_Master[ID == id];
                 	othermap = Map();
                 	if(getSRFData.count() > 0)
                 	{
                 		dataMap = Map();
                 		customerType = getSRFData.Customer_Type;
                 		if(customerType == "Pigment")
                 		{
                 			dataMap.put("Layout",{"id":"1000823000001174023"});
                 			/*******************************************************Get Sales Marketing Person**************************************************/
                 			if(getSRFData.Sales_Marketing_Person1 != null)
                 			{
                 				getUserData = Users[ID == getSRFData.Sales_Marketing_Person1];
                 				if(getUserData.count() > 0)
                 				{
                 					getUserId = getUserData.UserID.toLong();
                 					dataMap.put("Sales_Marketing_Person",{"id":getUserId});
                 				}
                 			}
                 			dataMap.put("ISO_Number",ifnull(getSRFData.ISO_Number,""));
                 			dataMap.put("SRF_Number",ifnull(getSRFData.SRF_Number,""));
                 			dataMap.put("Requested_By",ifnull(getSRFData.Requested_By,""));
                 			dataMap.put("Complete_Address",ifnull(getSRFData.Complete_Address,""));
                 			dataMap.put("Purpose",ifnull(getSRFData.Purpose,""));
                 			dataMap.put("STD_Submit",ifnull(getSRFData.STD_Submit,""));
                 			/*********************************************Get Subform Data *****************************************************************/
                 			getLineItems = SRF_Pigment_Line_Items[SRF_Master == id];
                 			if(getLineItems.count() > 0)
                 			{
                 				productList = List();
                 				for each  getProduct in getLineItems
                 				{
                 					productmap = Map();
                 					getPData = Product_Master[ID == getProduct.Sample_Details];
                 					if(getPData.count() > 0)
                 					{
                 						getCrmId = getPData.CRM_SO_ID;
                 						if(getCrmId.isEmpty() == false)
                 						{
                 							productmap.put("Sample_Details",getCrmId.toNumber());
                 						}
                 						else
                 						{
                 							searchPro = zoho.crm.searchRecords("Products","Creator_record_Id:equals:" + getProduct.Sample_Details.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 							if(searchPro.isEmpty() == false)
                 							{
                 								for each  serachpr in searchPro
                 								{
                 									prodid = serachpr.get("id");
                 									productmap.put("Sample_Details",prodid.toNumber());
                 								}
                 							}
                 						}
                 					}
                 					productmap.put("Quantity",ifnull(getProduct.Quantity,0));
                 					productmap.put("UOM",getProduct.Unit);
                 					productmap.put("Remarks",getProduct.Remarks);
                 					productmap.put("Application",getProduct.Application);
                 					productList.add(productmap);
                 				}
                 				dataMap.put("Details_of_Sample",productList);
                 			}
                 		}
                 		if(customerType == "Polymer")
                 		{
                 			dataMap.put("Layout",{"id":"1000823000001173572"});
                 			/*******************************************************Get GCL Representative**************************************************/
                 			if(getSRFData.GCL_Representative1 != null)
                 			{
                 				getUserData = Users[ID == getSRFData.GCL_Representative1];
                 				if(getUserData.count() > 0)
                 				{
                 					dataMap.put("GCL_Representative",{"id":getUserId});
                 				}
                 			}
                 			/*******************************************************Get Line Items**************************************************/
                 			getProducts = SRF_Polymer_Line_items[SRF_Master == id];
                 			if(getProducts.count() > 0)
                 			{
                 				productList = List();
                 				for each  getPro in getProducts
                 				{
                 					productmap = Map();
                 					getPData = Product_Master[ID == getPro.Product];
                 					if(getPData.count() > 0)
                 					{
                 						getPID = getPData.ID;
                 						getCrmId = getPData.CRM_SO_ID;
                 						if(getCrmId.isEmpty() == false)
                 						{
                 							productmap.put("Product",getCrmId.toNumber());
                 						}
                 						else
                 						{
                 							searchPro = zoho.crm.searchRecords("Products","Creator_record_Id:equals:" + getPID.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 							if(searchPro.isEmpty() == false)
                 							{
                 								for each  serachpr in searchPro
                 								{
                 									prodid = serachpr.get("id");
                 									productmap.put("Product",prodid.toNumber());
                 								}
                 							}
                 						}
                 					}
                 					productmap.put("Qty",ifnull(getPro.Qty_in_Kgs,0));
                 					productmap.put("Basic_Cost",ifnull(getPro.Basic_Cost,0));
                 					productmap.put("Other_Cost",ifnull(getPro.Other_Cost,0));
                 					productmap.put("Transport_Cost",ifnull(getPro.Transport_Cost,0));
                 					productmap.put("Total_Cost",ifnull(getPro.Total_Cost,0));
                 					productmap.put("Remarks",getPro.Remarks);
                 					productList.add(productmap);
                 				}
                 				dataMap.put("Free_Sample_Line_Items",productList);
                 			}
                 			/*********************************************Details of Competetor *********************************************************/
                 			dataMap.put("Competitor_Name",ifnull(getSRFData.Competitor_Name,""));
                 			dataMap.put("Competitor_Activity",ifnull(getSRFData.Competitor_Activity,""));
                 			dataMap.put("Testing_Details",ifnull(getSRFData.Testing_Details,""));
                 			dataMap.put("Grade_Product_Used",ifnull(getSRFData.Grade_Product_Used,""));
                 			dataMap.put("Business_NY",ifnull(getSRFData.Bus_NY,null));
                 			dataMap.put("Business_CY",ifnull(getSRFData.Bus_CY,null));
                 			dataMap.put("Submitted_Trials",ifnull(getSRFData.Submitted_Trials,""));
                 			dataMap.put("Potential",ifnull(getSRFData.Potential_Annum,0));
                 			dataMap.put("Potential_Next_Year",ifnull(getSRFData.Potential_Next_Year,0));
                 		}
                 		/*********************************************Common  Details ************************************************************/
                 		crmId = getSRFData.zoho_crm_id;
                 		//dataMap.put("Order_Number",ifnull(SRFDetails.getJson("So_No"),""));
                 		dataMap.put("Creator_Rec_Id",ifnull(id.toString(),""));
                 		dataMap.put("Document_Code",ifnull(getSRFData.STD_SRF_Number,""));
                 		dataMap.put("Contact_Number_Rep",ifnull(getSRFData.Contact_Number_Rep,""));
                 		dataMap.put("GCL_Project_Name",ifnull(getSRFData.GCL_Project_Name,""));
                 		dataMap.put("Status",ifnull(getSRFData.Approval_Status,""));
                 		/*********************************************Details of OEM / Customer *********************************************************/
                 		dataMap.put("Customer_Name",ifnull(getSRFData.OEM_Customer_Name,""));
                 		dataMap.put("Customer_Contact_Number",ifnull(getSRFData.Customer_Contact_Number,""));
                 		// 	dataMap.put("Customer_Email",ifnull(getSRFData.Customer_Email,""));
                 		dataMap.put("Company_Address",ifnull(getSRFData.Company_Address,""));
                 		dataMap.put("Company_Name",ifnull(getSRFData.Company_Name,""));
                 		dataMap.put("Billing_Address",ifnull(getSRFData.Billing_Address,""));
                 		dataMap.put("Application_Details",ifnull(getSRFData.Application_Details,""));
                 		rDate = "";
                 		if(getSRFData.Date_of_Requisition.isNull() == false)
                 		{
                 			rDate = getSRFData.Date_of_Requisition.toString("yyyy-MM-dd");
                 		}
                 		dataMap.put("Date",rDate);
                 		/*********************************************Get Contact Person *****************************************************************/
                 		if(getSRFData.Customer_Name != null)
                 		{
                 			contactPersonData = Customer[ID == getSRFData.Customer_Name];
                 			if(contactPersonData.count() > 0)
                 			{
                 				dataMap.put("Customer_Email",ifnull(contactPersonData.Email,""));
                 				dataMap.put("Customer_Contact_Number",ifnull(contactPersonData.Phone_Number,""));
                 				getCrmCId = contactPersonData.zoho_crm_id;
                 				if(getCrmCId.isEmpty() == false)
                 				{
                 					dataMap.put("Contact_Person",getCrmCId.toNumber());
                 				}
                 				else
                 				{
                 					searchCustomer = zoho.crm.searchRecords("Accounts","Creator_record_Id:equals:" + getSRFData.Customer_Name.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 					if(searchCustomer.isEmpty() == false)
                 					{
                 						for each  serachcm in searchCustomer
                 						{
                 							cid = serachcm.get("id");
                 							dataMap.put("Contact_Person",cid.toNumber());
                 						}
                 					}
                 				}
                 			}
                 		}
                 		info dataMap;
                 		/*********************************************Create Record in Crm *****************************************************************/
                 		datamap1 = Map();
                 		datamap1.put("data",{dataMap});
                 		insertresp = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/crm/v8/SRF_Master"
                 			type :POST
                 			parameters:datamap1.toString()
                 			connection:"zoho_oauth_connection"
                 		];
                 		info insertresp;
                 		craetemsg = insertresp.get("data").getJson("message");
                 		if(craetemsg == "record added")
                 		{
                 			details = insertresp.get("data").getJson("details");
                 			getSRFData.zoho_crm_id=details.get("id").toString();
                 		}
                 	}
                 }
				 void SyncExpenseAndExpenseCategory.syncExpenseCategoryInCreator(int id)
                 {
                 	/*******************************************************Get Expense Category Data**************************************************/
                 	getAPData = Expense_Category[ID == id];
                 	dataMap = Map();
                 	othermap = Map();
                 	if(getAPData.count() > 0)
                 	{
                 		dataMap.put("Name",ifnull(getAPData.Category,""));
                 		dataMap.put("Expense_Type",ifnull(getAPData.Expense_Type,""));
                 		dataMap.put("Description",ifnull(getAPData.Description,""));
                 		dataMap.put("Type",ifnull(getAPData.Type_field,""));
                 		dataMap.put("GL_Code",ifnull(getAPData.GL_Code,""));
                 		dataMap.put("Zoho_Expense_Id",ifnull(getAPData.CatID,""));
                 		/*******************************************************Search Record in Crm****************************************************/
                 		searchExpenseCategory = zoho.crm.searchRecords("Expense_Category","Creator_rec_id:equals:" + id.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 		if(searchExpenseCategory.isEmpty() == false)
                 		{
                 			for each  searchdata in searchExpenseCategory
                 			{
                 				crmLCID = searchdata.get("id");
                 			}
                 			if(crmLCID.isNull() == false)
                 			{
                 				info "updateresp";
                 				info zoho.crm.updateRecord("Expense_Category",crmLCID.toLong(),dataMap,othermap,"zoho_oauth_connection");
                 			}
                 		}
                 		else if(getAPData.zoho_crm_id != "")
                 		{
                 			info zoho.crm.updateRecord("Expense_Category",getAPData.zoho_crm_id.toLong(),dataMap,othermap,"zoho_oauth_connection");
                 			info "Update";
                 		}
                 		else
                 		{
                 			/*******************************************************Create Record in Crm****************************************************/
                 			dataMap.put("Creator_rec_id",id.toString());
                 			datamap1 = Map();
                 			datamap1.put("data",{dataMap});
                 			insertresp = invokeurl
                 			[
                 				url :"https://www.zohoapis.in/crm/v8/Expense_Category"
                 				type :POST
                 				parameters:datamap1.toString()
                 				connection:"zoho_oauth_connection"
                 			];
                 			info "insertresp" + insertresp;
                 			craetemsg = insertresp.get("data").getJson("message");
                 			if(craetemsg == "record added")
                 			{
                 				details = insertresp.get("data").getJson("details");
                 				getAPData.zoho_crm_id=details.get("id").toString();
                 			}
                 		}
                 	}
                 }
				 void SyncExpenseAndExpenseCategory.syncFAExpensesInCreator(int id)
                 {
                 	/*******************************************************Get Expense Category Data**************************************************/
                 	getAPData = Expense_For_Agent[ID == id];
                 	dataMap = Map();
                 	othermap = Map();
                 	if(getAPData.count() > 0)
                 	{
                 		dataMap.put("Payment_Type",ifnull(getAPData.Payment_Type,""));
                 		dataMap.put("Crop",ifnull(getAPData.Crop,""));
                 		dataMap.put("Name",ifnull(getAPData.Expense_No,""));
                 		dataMap.put("Amount",ifnull(getAPData.Amount,0));
                 		dataMap.put("Expense_Description",ifnull(getAPData.Expense_Description,""));
                 		if(getAPData.Expense_Date.isNull() == false)
                 		{
                 			dataMap.put("Expense_Date",getAPData.Expense_Date.toString("yyyy-MM-dd"));
                 		}
                 		getOfficer = getAPData.Officer;
                 		if(getOfficer.isNull() == false)
                 		{
                 			getUser = Users[ID == getOfficer];
                 			if(getUser.count() > 0)
                 			{
                 				getCRmMId = getUser.UserID;
                 				if(getCRmMId.isNull() == false)
                 				{
                 					dataMap.put("Owner",getCRmMId.toNumber());
                 				}
                 			}
                 		}
                 		/*******************************************************Get Meeting Data**************************************************/
                 		getMeeting = getAPData.Meeting_for_the_Raise_Expense;
                 		info "Get Meeting==>" + getMeeting;
                 		if(getMeeting.isNull() == false)
                 		{
                 			info "enterAgent";
                 			getMeetingData = Meeting[ID == getMeeting];
                 			if(getMeetingData.count() > 0)
                 			{
                 				getCRmMId = getMeetingData.CRMID;
                 				if(getCRmMId.isNull() == false)
                 				{
                 					dataMap.put("Meeting_Id",getCRmMId.toString());
                 					urll = "https://crm.zoho.in/crm/org60047780763/tab/Events/" + getCRmMId.toNumber();
                 					dataMap.put("Meeting_Url",urll);
                 				}
                 				else
                 				{
                 					searchMeeting = zoho.crm.searchRecords("Events","CreatorID:equals:" + getMeeting.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 					if(searchMeeting.isEmpty() == false)
                 					{
                 						for each  searchdata1 in searchMeeting
                 						{
                 							crmMID = searchdata1.get("id");
                 						}
                 						if(crmMID.isNull() == false)
                 						{
                 							dataMap.put("Meeting_Id",crmMID.toString());
                 							urll = "https://crm.zoho.in/crm/org60047780763/tab/Events/" + crmMID.toNumber();
                 							dataMap.put("Meeting_Url",urll);
                 							//dataMap.put("Meeting_Url", "https://crm.zoho.in/crm/org60047780763/tab/Events/"+crmMID);
                 						}
                 					}
                 				}
                 			}
                 		}
                 		/*******************************************************Get Receipt File**************************************************/
                 		fileContent = invokeurl
                 		[
                 			url :"https://creator.zoho.in/api/v2/zohoadmin_gharda782/distributor-management-gharda-chemical/report/Expense_For_Agent_Report/" + id + "/Upload_Receipt/download"
                 			type :GET
                 			connection:"zoho_oauth_connection"
                 		];
                 		fileContent.setparamname("file");
                 		resp = invokeurl
                 		[
                 			url :" https://www.zohoapis.in/crm/v2/files"
                 			type :POST
                 			files:fileContent
                 			connection:"zoho_oauth_connection"
                 		];
                 		fileid = resp.get("data").get(0).get("details").get("id");
                 		info fileid;
                 		fmp = Map();
                 		fmp.put("File_Id__s",fileid);
                 		fileList = List();
                 		fileList.add(fmp);
                 		dataMap.put("Upload_Receipt",fileList);
                 		/*******************************************************Get Liquidaion Agent**************************************************/
                 		getLAgent = getAPData.Liquidation_Agent_Name;
                 		info "Get Agent==>" + getLAgent;
                 		if(getLAgent.isNull() == false)
                 		{
                 			info "enterAgent";
                 			getAgentData = Liquidation_Agent[ID == getLAgent];
                 			if(getAgentData.count() > 0)
                 			{
                 				getCRmLAId = getAgentData.CRMID;
                 				if(getCRmLAId.isNull() == false)
                 				{
                 					dataMap.put("Liquidation_Agent_Name",getCRmLAId.toLong());
                 					emptymap = Map();
                 					liquidationdata = zoho.crm.getRecordById("Liquidation_Agent_Master",getCRmLAId.toLong(),emptymap,"zoho_oauth_connection");
                 					liquidationownerid = liquidationdata.get("Owner").get("id");
                 					dataMap.put("Owner",liquidationownerid);
                 				}
                 				else
                 				{
                 					searchLiqAgent = zoho.crm.searchRecords("Liquidation_Agent_Master","Creator_record_Id:equals:" + getLAgent.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 					if(searchLiqAgent.isEmpty() == false)
                 					{
                 						for each  searchdata1 in searchLiqAgent
                 						{
                 							crmLCID = searchdata1.get("id");
                 							liquidationownerid = searchdata1.getJSON("Owner").get("id");
                 						}
                 						if(crmLCID.isNull() == false)
                 						{
                 							dataMap.put("Liquidation_Agent_Name",crmLCID.toLong());
                 							dataMap.put("Owner",liquidationownerid);
                 						}
                 					}
                 				}
                 			}
                 		}
                 		/*******************************************************Get Expense Category**************************************************/
                 		getExpense_Category = getAPData.Expense_Category;
                 		info "Get Leave Type==>" + getExpense_Category;
                 		if(getExpense_Category.isNull() == false)
                 		{
                 			info "enterAgent";
                 			getExpense_CategoryData = Expense_Category[ID == getExpense_Category];
                 			if(getExpense_CategoryData.count() > 0)
                 			{
                 				getCRmLECId = getExpense_CategoryData.zoho_crm_id;
                 				if(getCRmLECId.isNull() == false)
                 				{
                 					dataMap.put("Expense_Category",getCRmLECId.toLong());
                 				}
                 				else
                 				{
                 					searchExpType = zoho.crm.searchRecords("Expense_Category","Creator_rec_id:equals:" + getExpense_Category.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 					if(searchExpType.isEmpty() == false)
                 					{
                 						for each  searchExpdata in searchExpType
                 						{
                 							crmExpID = searchExpdata.get("id");
                 						}
                 						if(crmExpID.isNull() == false)
                 						{
                 							dataMap.put("Expense_Category",crmExpID.toLong());
                 						}
                 					}
                 				}
                 			}
                 		}
                 		info dataMap;
                 		/*******************************************************Search Record in Crm****************************************************/
                 		if(getAPData.zoho_crm_id.isEmpty() == true)
                 		{
                 			searchExpenseCategory = zoho.crm.searchRecords("FA_Expense_Master","Creator_rec_id:equals:" + id.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 			if(searchExpenseCategory.isEmpty() == false)
                 			{
                 				for each  searchdata in searchExpenseCategory
                 				{
                 					crmLCID = searchdata.get("id");
                 				}
                 				if(crmLCID.isNull() == false)
                 				{
                 					info "updateresp";
                 					info zoho.crm.updateRecord("FA_Expense_Master",crmLCID.toLong(),dataMap,othermap,"zoho_oauth_connection");
                 				}
                 			}
                 			else
                 			{
                 				/*******************************************************Create Record in Crm****************************************************/
                 				dataMap.put("Creator_rec_id",id.toString());
                 				datamap1 = Map();
                 				datamap1.put("data",{dataMap});
                 				insertresp = invokeurl
                 				[
                 					url :"https://www.zohoapis.in/crm/v8/FA_Expense_Master"
                 					type :POST
                 					parameters:datamap1.toString()
                 					connection:"zoho_oauth_connection"
                 				];
                 				info "insertresp" + insertresp;
                 				info "datamap1" + datamap1;
                 				craetemsg = insertresp.get("data").getJson("message");
                 				if(craetemsg == "record added")
                 				{
                 					details = insertresp.get("data").getJson("details");
                 					getAPData.zoho_crm_id=details.get("id").toString();
                 					info "zoho_crm_id" + getAPData.zoho_crm_id;
                 				}
                 			}
                 		}
                 		else
                 		{
                 			info zoho.crm.updateRecord("FA_Expense_Master",getAPData.zoho_crm_id.toLong(),dataMap,othermap,"zoho_oauth_connection");
                 			info "Update";
                 		}
                 	}
                 }
