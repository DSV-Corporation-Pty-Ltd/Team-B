			Populate_Options_in_From_ as "Populate Options in From and To Field"
			{
				type =  form
				form = RFQ

				record event = on add or edit

				on user input of Type_field
				{
					actions 
					{
						custom deluge script
						(
											if(input.Type_field != null && input.Type_field != "")
										{
											fromList = List();
											toList = List();
											show From;
											show To;
											// ===============================
											// DEPO TO DEPO
											// ===============================
											if(input.Type_field == "Depo To Depo")
											{
												depoList = {"Akola","Pune","Indore","Raipur","Aslali","Bhatinda","Ludhiana","SGNR","Jaipur","Karnal","Lucknow","Ghaziabad","Rudrapur","Patna","Coimbatore","Kerala","Bellary","Hyderabad","Kurnool","Kolkata","Siliguri","Guntur","Padamala","Mokshi"};
												fromList.addAll(depoList);
												toList.addAll(depoList);
											}
											// ===============================
											// DEPO TO FACTORY
											// ===============================
											else if(input.Type_field == "Depo To Factory")
											{
												depoList = {"Akola","Pune","Indore","Raipur","Aslali","Bhatinda","Ludhiana","SGNR","Jaipur","Karnal","Lucknow","Ghaziabad","Rudrapur","Patna","Coimbatore","Kerala","Bellary","Hyderabad","Kurnool","Kolkata","Siliguri","Guntur","Padamala"};
												factoryList = {"Kherdi","Jammu","Lote","Mokshi","Nandeshwari"};
												fromList.addAll(depoList);
												toList.addAll(factoryList);
											}
											// ===============================
											// FACTORY TO DEPO
											// ===============================
											else if(input.Type_field == "Factory To Depo")
											{
												factoryList = {"Kherdi","Jammu","Lote","Mokshi","Nandeshwari","Dahej","Sykha","Ankleshwar","Panoli"};
												depoList = {"Akola","Pune","Indore","Raipur","Aslali","Bhatinda","Ludhiana","SGNR","Jaipur","Karnal","Lucknow","Ghaziabad","Rudrapur","Patna","Coimbatore","Kerala","Bellary","Hyderabad","Kurnool","Kolkata","Siliguri","Guntur","Padamala","Zirakpur","Nandeshwari"};
												fromList.addAll(factoryList);
												toList.addAll(depoList);
											}
											// ===============================
											// FACTORY TO FACTORY
											// ===============================
											else if(input.Type_field == "Factory To Factory")
											{
												factoryList = {"Kherdi","Jammu","Lote","Mokshi","Nandeshwari","Dahej","Sykha","Ankleshwar","Panoli"};
												fromList.addAll(factoryList);
												toList.addAll(factoryList);
											}
											// Clear previous values
											clear From;
											clear To;
											// Set dropdown values
											input.From:ui.add(fromList);
											input.To:ui.add(toList);
										}
						)
					}
				}

			}
