		reports
		{
			report View_Orders
			{
				quickview
				(
					layout
					(
		 				type = Custom
		 				selectedlayout = "Custom Layout 2"
					)
						menu
						(
							header
							(
							)
						record
						(
							"View Order"
							"Download PDF"
    					)
						)
    				action
    				(
						on tap
						(
							View Record   	   
    					)
						on long press
						(
							View Record   	   
							"View Order"
							"Download PDF"
    					)
     				)
				)

				detailview
				(
					layout
					(
		 				type = 2
						datablock1
						(
		     				title = "Overview"
							fields
							(
								Order_Number as "Order Number"
								Order_Date as "Order Date"
								Due_Date as "Due Date"
								Distributor_Name as "Distributor Name"
								Email
								Contact_Name as "Contact Name"
								Status
								Order_Description as "Order Description"
							)
						)
						datablock3
						(
		     				title = "Line Items"
