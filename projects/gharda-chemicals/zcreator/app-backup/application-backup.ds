			Populate_invoice_data as "Populate invoice data"
			{
				type =  form
				form = Return_Sales_Order

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											input.Return_Date = zoho.currentdate;
										input.Return_Quantity = null;
										input.Remarks = "";
										input.CNF_Name = null;
										getInvItemData = Invoice_Line_Items[ID == input.Invoice_Line_Items];
										if(getInvItemData.count() > 0)
										{
											input.Order_Quantity = getInvItemData.Quantity;
											input.Product_Name = getInvItemData.Product_Name;
											input.Batch_Number = getInvItemData.Batch_Number;
											input.Order_Quantity = getInvItemData.Quantity;
											input.Invoice = getInvItemData.Invoice_Details;
											getinvData = Invoice[ID == getInvItemData.Invoice_Details];
											if(getinvData.count() > 0)
											{
												input.Sales_Order = getinvData.Sales_Order;
												input.Distributor_Email = getinvData.Distributor_Name;
												input.Distributor_Name = getinvData.Distributor_Name;
												getDist = Distributor_Master[ID == input.Distributor_Name];
												cnflist = List();
												if(getDist.count() > 0)
												{
													getPlant = getDist.Plant;
													getCNF = CNF_Master[Plant == getPlant];
													if(getCNF.count() > 0)
													{
														cnflist.add(getCNF.ID);
														input.CNF_Name = cnflist;
													}
												}
											}
										}
						)
					}
				}

			}
