                 		product_table = "<table border='1' cellpadding='6' cellspacing='0' style='border-collapse:collapse;width:100%;'><tr style='background-color:#2563eb;color:white;'><th>Product Name</th><th>Product Code</th><th>Technical Name</th><th>Quantity</th><th>Gross Weight</th><th>Nos of Box</th><th>Total Gross Weight</th><th>Freight Rate</th></tr>";
                 		for each  item in line_items
                 		{
                 			product_table = product_table + "<tr><td>" + item.Product_Name.Product_Name + "</td><td>" + item.Product_Code + "</td><td>" + item.Technical_Name + "</td><td>" + item.Quantity + "</td><td>" + item.Gross_Weight + "</td><td>" + item.Nos_of_Box + "</td><td>" + item.Total_Gross_Weight + "</td>" + item.Freight_Rate.toString() + "</td></tr>";
                 		}
                 		product_table = product_table + "</table>";
                 		email_content = "<html><body style='font-family:Arial,sans-serif;'><h2 style='color:#2563eb;'>New Quotation Created</h2><p>Dear " + disName + ",</p><p>A new quotation has been created by transporter <b>" + getQuoteData.Transporter_Name.Transporter_Name + "</b> for your reference. Please find the details below:</p><table style='width:100%;margin-bottom:20px;'><tr><td><b>Quotation No:</b></td><td>" + getQuoteData.Quotation_No.toString() + "</td></tr><tr><td><b>Quotation Date:</b></td><td>" + getQuoteData.Quotation_Date.toDate("dd-MMM-yyyy").toString("dd-MMM-yyyy") + "</td></tr><tr><td><b>RFQ No:</b></td><td>" + getQuoteData.RFQ.RFQ_No + "</td></tr><tr><td><b>Freight Type:</b></td><td>" + ifnull(getQuoteData.Freight_Type,"-") + "</td></tr><tr><td><b>Remarks:</b></td><td>" + ifnull(getQuoteData.Remarks,"-") + "</td></tr></table><h3>Quotation Line Items</h3>" + product_table + "<br><p>You can review the complete quotation by clicking the link below:</p><p><a href='https://ghardasalesportal.gharda.com/#Report:Quotations_CNF' style='background-color:#2563eb;color:white;padding:10px 20px;text-decoration:none;border-radius:5px;'>View Quotation</a></p><p>Best regards,<br>" + getQuoteData.Transporter_Name.Transporter_Name + "</p></body></html>";
                 		sendmail
                 		[
                 			from :zoho.loginuserid
                 			to :disEmail
                 			subject :"New Quotation Created - " + getQuoteData.Quotation_No
                 			message :email_content
                 		]
                 	}
                 }
