			on_the_user_input_of_frei1 as "on the user input of freight rate"
			{
				type =  form
				form = Quotation

				record event = on add or edit

				on user input of Freight_Rate
				{
					actions 
					{
						custom deluge script
						(
											if(input.Freight_Rate.isNull() == false)
										{
											taxAmount = 0;
											grandTotal = 0;
											gstCal = 0;
											igstCal = 0;
											sgstCal = 0;
											if(input.Line_Items.isEmpty() == false)
											{
												validate = false;
												for each  items in input.Line_Items
												{
													items.Freight_Rate=ifnull(items.Quantity,0) / ifnull(input.Freight_Rate,0);
													items.TotalFreight=ifnull(items.Quantity,0) * ifnull(items.Freight_Rate,0);
													if(input.Freight_Rate > items.Quantity)
													{
														validate = true;
													}
												}
												// 		if(validate == true)
												// 		{
												// 			alert "Freight rate should not be greator than Product Qty.";
												// 			input.Freight_Rate = null;
												// 		}
												// 		else
												// 		{
												input.Sub_Total = ifnull(input.Freight_Rate,0);
												CGST_Perc = 0;
												SGST_Perc = 0;
												IGST_Perc = 0;
												input.CGST_Val = 0;
												input.SGST_Val = 0;
												input.IGST_Val = 0;
												input.CGST = 0;
												input.SGST = 0;
												input.IGST = 0;
												getlogistic = Logistic_Master[ID == input.Transporter_Name];
												if(getlogistic.count() > 0)
												{
													CGST_Perc = getlogistic.CGST;
													SGST_Perc = getlogistic.SGST;
													IGST_Perc = getlogistic.IGST;
													input.CGST = getlogistic.CGST;
													input.SGST = getlogistic.SGST;
													input.IGST = getlogistic.IGST;
												}
												if(CGST_Perc.isEmpty() == false && CGST_Perc > 0)
												{
													gstCal = (ifnull(input.Sub_Total,0) * CGST_Perc) / 100;
													input.CGST_Val = gstCal;
												}
												if(SGST_Perc.isEmpty() == false && SGST_Perc > 0)
												{
													sgstCal = (ifnull(input.Sub_Total,0) * SGST_Perc) / 100;
													input.SGST_Val = sgstCal;
												}
												if(IGST_Perc.isEmpty() == false && IGST_Perc > 0)
												{
													igstCal = (ifnull(input.Sub_Total,0) * IGST_Perc) / 100;
													input.IGST_Val = igstCal;
												}
												input.Tax_Amount = ifnull(input.CGST_Val,0) + ifnull(input.SGST_Val,0) + ifnull(input.IGST_Val,0);
												input.Grand_Total = ifnull(input.Tax_Amount,0) + ifnull(input.Sub_Total,0);
												//}
											}
										}
						)
					}
				}

			}
