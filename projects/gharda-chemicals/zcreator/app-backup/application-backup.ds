						custom deluge script
						(
											if(input.Liquidation_Agent_Name != null && input.From != null)
										{
											existingMeetings = Meeting[Liquidation_Agent_Name == input.Liquidation_Agent_Name && From == input.From && Meeting_Status != "Cancelled"];
											if(existingMeetings.count() > 0)
											{
												for each  rec in existingMeetings
												{
													if(input.ID == null || rec.ID != input.ID)
													{
														alert "You already has a meeting at this time. Please choose another time.";
