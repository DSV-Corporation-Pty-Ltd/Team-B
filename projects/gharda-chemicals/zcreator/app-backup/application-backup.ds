			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'SRF_Number'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '20px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#4E96F4'\n    borderWidth = '0px'\n\n	  value = 'Date_of_Requisition'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	padding = '0px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '27'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#132437'\n    borderWidth = '0px'\n\n	  value = 'Customer_Name.Customer_Name'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '20'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#2D3C4D'\n    borderWidth = '0px'\n\n	  value = 'Customer_Name.Email'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
		}
		list Proforma_Invoices
		{
			displayName = "Proforma Invoices"
			show all rows from Proforma_Invoice  [Customer.Email == zoho.loginuserid]  
			(
				PI_Number as "PI Number"
				PI_Date as "PI Date"
				PO_No as "PO No."
				Customer
				Status
				Validity_Days as "Validity (Days)"
				Billing_Street as "Billing Street"
				Shipping_Street as "Shipping Street"
				Billing_City as "Billing City"
				Shipping_City as "Shipping City"
				Billing_State as "Billing State"
				Shipping_State as "Shipping State"
				Billing_Country as "Billing Country"
				Shipping_Country as "Shipping Country"
				Billing_Code as "Billing Code"
				Shipping_Code as "Shipping Code"
				Mode_of_Transport as "Mode of Transport"
				Port_of_Loading as "Port of Loading"
				Port_of_Discharge as "Port of Discharge"
				Final_Destination as "Final Destination"
				Country_of_Origin as "Country of Origin"
				Place_of_Receipt as "Place of Receipt"
				Expected_Shipment_Date as "Expected Shipment Date"
				Shipment_Terms_Incoterms as "Shipment Terms Incoterms"
				Currency_Type as "Currency Type"
				Exchange_Rate_Base_Currency as "Currency Exchange Rate"
				Payment_Terms as "Payment Terms"
				Payment_Method as "Payment Method"
				Credit_Days as "Credit Days"
				Bank_Name as "Bank Name"
				Account_No as "Account No."
				IFSC_SWIFT_Code as "IFSC / SWIFT Code"
				Billing_Phone as "Billing Phone"
				(
					displayformat = plainnumber 
				)
				Shipping_Phone as "Shipping Phone"
				(
					displayformat = plainnumber 
				)
				Sub_Total as "Sub Total"
				Tax as "Tax%"
				Tax_Amount as "Tax Amount"
				Grand_Total as "Grand Total"
				PO_Date as "PO Date"
				custom action "Approve"
				(
	  			workflow = PI_Creation_form_CRM
				show action in view header = true
				show action in edit record menu = true
				column header = "Approve"
				condition = (PI_Sync_From_CRM == true && Status != "Approved" && Status != "Rejected")
				confirmation before execution
				(
					message for individual record = "Are you sure you want to Approve this PI?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "Reject"
				(
	  			workflow = PI_Creation_from_CRM_on_R
				show action in view header = true
				show action in edit record menu = true
				column header = "Reject"
				condition = (PI_Sync_From_CRM == true && Status != "Approved" && Status != "Rejected")
				confirmation before execution
				(
					message for individual record = "Are you sure to reject this PI?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				custom action "View PI"
				(
	  			workflow = view_PI
				show action in view header = true
				show action in edit record menu = true
				column header = "View PI"
				)
				custom action "Download Docs"
				(
	  			workflow = Download_Docs
				show action in edit record menu = true
				column header = "Download Docs"
				condition = (Attachments.File_Name is not null)
				)
				custom action "Download PDF"
				(
	  			workflow = Download_PI_record
				show action in view header = true
				show action in edit record menu = true
				column header = "Download PDF"
				)
				PI_Sync_From_CRM as "PI Sync From CRM"
				Terms_and_Conditions as "Terms and Conditions"
			)
			conditional formatting
			(
				"New Formatting"
				{
				condition = (Status == "Pending")
				fields = [Status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting"
				{
				condition = (Status == "Approved")
				fields = [Status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting"
				{
				condition = (Status == "Rejected")
				fields = [Status]
				format = "color:#333;background-color:#f1c40f;"
				}
				"New Formatting"
				{
				condition = (Status == "Delivered")
				fields = [Status]
				format = "text-decoration:line-through;color:#ffffff;background-color:#3598db;"
				}
				"New Formatting"
				{
				condition = (Status == "Revised")
				fields = [Status]
				format = "text-decoration:line-through;color:#ffffff;background-color:#bd588b;"
				}
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Customer'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '20px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'PI_Number'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '28'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'PI_Date'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '3'\n\n\n\n\n\n	  value = 'Terms_and_Conditions'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
		}
