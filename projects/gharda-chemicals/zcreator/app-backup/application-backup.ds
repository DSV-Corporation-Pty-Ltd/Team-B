			PI_Creation_form_CRM as "PI Creation form CRM"
			{
				type =  functions
				form = Proforma_Invoice
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						input.Status = "Approved";
										thisapp.Notifications.PIApprovalNotifyToUsers(input.ID,"Approved");
