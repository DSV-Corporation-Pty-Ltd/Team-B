		reports
		{
			report View_Orders
			{
				quickview
				(
					layout
					(
		 				type = Custom
		 				selectedlayout = "Custom Layout 2"
					)
						menu
						(
							header
							(
								Edit 
								Delete 
							)
						record
						(
							"View Order"
							"Download PDF"
    					)
						)
    				action
    				(
						on tap
						(
							View Record   	   
    					)
						on long press
						(
							View Record   	   
							"View Order"
							"Download PDF"
    					)
     				)
				)

				detailview
				(
					layout
					(
		 				type = 2
						datablock1
						(
		     				title = "Overview"
							fields
							(
								Order_Number as "Order Number"
								Order_Date as "Order Date"
								Due_Date as "Due Date"
								Distributor_Name as "Distributor Name"
								Email
								Contact_Name as "Contact Name"
								Status
								Order_Description as "Order Description"
							)
						)
						datablock3
						(
		     				title = "Line Items"
		     				related field = Line_Items
							fields
							(
								Product_Name as "Product Name"
								SKU
								Batch_Number as "Batch Number"
								Discount_Price as "Discount Price"
								Quantity
								Discount as "Discount %"
								Discount_Value as "Discount Value"
								Total
							)
						)
						datablock4
						(
		     				title = "Total Price Details"
							fields
							(
								Due_Date as "Due Date"
								Subtotal
								CGST
								IGST
								Tax_Amount as "Tax Amount"
								Grand_Total as "Grand Total"
							)
						)
					)
						menu
						(
							header
							(
								Edit 
								Duplicate 
								Delete 
							)
						)
				)
			}
