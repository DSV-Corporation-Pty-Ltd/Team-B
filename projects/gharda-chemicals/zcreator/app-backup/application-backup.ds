			on_edit_success2 as "on edit success"
			{
				type =  form
				form = Order_Management

				record event = on edit
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(SyncFrom == false)
										{
											thisapp.SalesOrder.updateSOInCRM(input.ID);
											//condityions checkjavascript:;
											if(input.Order_Type == "Credit Limit Order")
											{
												today = zoho.currentdate;
												distname = input.Distributor_Name;
												input.Status = "Order Process";
												overdue = false;
												cond1 = "";
												cond2 = "";
												cond3 = "";
												invoices = Invoice[Distributor_Name == input.Distributor_Name && Status == "Unpaid"] sort by Added_Time desc;
												if(invoices.count() > 0)
												{
													for each  inv in invoices
													{
														inv_date = inv.Invoice_Date;
														age = daysBetween(inv_date,today);
														if(age > 90)
														{
															overdue = true;
														}
													}
													if(overdue)
													{
														input.Status = "Pending";
														cond1 = "You have invoices overdue by more than 90 days. Please clear outstanding dues to proceed with a new order.<br><br>";
													}
												}
												dstributor = Distributor_Master[ID == input.Distributor_Name];
												if(dstributor.count() > 0)
												{
													gardtotal = ifnull(input.Grand_Total,0) * 70 / 100;
													if(gardtotal > dstributor.Credit_Limit)
													{
														input.Status = "Pending";
														cond2 = "Credit Limit is less then the 70% Order Amount.<br><br>";
													}
													grandtotal1 = ifnull(input.Grand_Total,0) * 30 / 100;
													if(grandtotal1 > dstributor.Advance_Deposit)
													{
														input.Status = "Pending";
														cond3 = "Advance Deposit is less than 30% of the order amount. Order is 'Awaiting Advance Payment'.<br><br>";
													}
												}
												email_body = "Dear " + input.Distributor_Name.Distributor_Name + ",<br><br>";
												email_body = email_body + "An order attempt has been marked as <b>" + input.Status + "</b>.<br><br>";
												email_body = email_body + "<b>Reason:</b>" + cond1 + cond2 + cond3;
												email_body = email_body + "<b>Date:</b> " + today.toString("dd-MMM-yyyy") + "<br>";
												email_body = email_body + "Best regards,<br>Gharda Chemicals";
												sendmail
												[
													from :zoho.adminuserid
													to :zoho.loginuserid
													subject :"Recent Order " + input.Order_Number + " – Action Required"
													message :email_body
												]
											}
										}
						)
					}
				}

			}
