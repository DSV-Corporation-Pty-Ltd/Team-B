			on_the_user_input_of_retu as "on the user input of return qty"
			{
				type =  form
				form = Return_Sales_Order

				record event = on add or edit

				on user input of Return_Quantity
				{
					actions 
					{
						custom deluge script
						(
											if(input.Return_Quantity <= 0)
										{
											alert "Return Quantity Should not be negative or zero.";
											input.Return_Quantity = null;
										}
										if(input.Return_Quantity > 0)
										{
											if(input.Return_Quantity > input.Order_Quantity)
											{
												alert "Return Quantity Should not be greator than order Quantity.";
												input.Return_Quantity = null;
											}
											if(input.Return_Quantity < input.Order_Quantity)
											{
												alert "Return Quantity Should not be less than order Quantity.";
												input.Return_Quantity = null;
											}
										}
						)
					}
				}

			}
