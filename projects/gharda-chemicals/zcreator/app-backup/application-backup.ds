			Hide_and_Populate_Fields_ as "Hide and Populate Fields Data"
			{
				type =  form
				form = Sample_Collection_Report

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Distributor_Dealer_Name;
										profName = thisapp.portal.profileForUser(zoho.loginuserid);
										if(profName == "CNF Portal")
										{
											enable Distributor_Dealer_Name;
											loginuserid = zoho.loginuserid;
											// 	getCNF = CNF_Master[GCL_Accountant_Email_Id == loginuserid];
											getCNF = CNF_Master[Billing_Person_Email_Id == loginuserid];
											// 	input.Remarks_Notes = getCNF.toString();
											if(getCNF.count() > 0)
											{
												getplant = getCNF.Plant;
												getDist = Distributor_Master[Plant == getplant];
												distList = List();
												if(getDist.count() > 0)
												{
													for each  dist in getDist
													{
														distList.add(dist.ID);
													}
												}
												input.Distributor_Dealer_Name:ui.add(distList);
											}
										}
										else
										{
											getDistrinutorData = Distributor_Master[Email == zoho.loginuserid];
											if(getDistrinutorData.count() > 0)
											{
												input.Distributor_Dealer_Name = getDistrinutorData.ID;
												input.Region = getDistrinutorData.Region;
												input.Territory = getDistrinutorData.Territory;
												input.State = getDistrinutorData.Billing_State;
											}
											else
											{
												getDealerData = Dealer_Master[Email == zoho.loginuserid];
												if(getDealerData.count() > 0)
												{
													input.Distributor_Dealer_Name = getDealerData.ID;
													input.Region = getDealerData.Region;
													input.Territory = getDealerData.Territory;
													input.State = getDealerData.State;
												}
											}
										}
										hide Backend_Fields;
										hide Sample_Collection_ID;
										disable Territory;
										disable State;
										disable Region;
						)
					}
				}

			}
