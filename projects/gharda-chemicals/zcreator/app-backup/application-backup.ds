			on_the_user_input_of_quan2 as "on the user input of quantity"
			{
				type =  form
				form = Purchase_Order

				record event = on add or edit

				on user input of Line_Items.Quantity
				{
					actions 
					{
						custom deluge script
						(
											if(row.Quantity.isNull() == false)
										{
											if(row.Quantity <= 0)
											{
												alert "Quantity should not be 0 or negative value.";
												row.Quantity=null;
												row.Total=null;
												input.Tax = null;
												input.Tax_Amount = null;
												input.Grand_Total = null;
												input.Sub_Total = null;
											}
											else
											{
												row.Total=ifnull(row.Quantity,0) * ifnull(row.Price,0);
												subTotal = 0;
												taxAmount = 0;
												grandTotal = 0;
												taxval = 0;
												if(input.Line_Items.isEmpty() == false)
												{
													for each  items in input.Line_Items
													{
														subTotal = subTotal + ifnull(items.Total,0);
													}
													taxval = (ifnull(subTotal,0) * ifnull(input.Tax,0)) / 100;
													input.Sub_Total = ifnull(subTotal,0);
													input.Tax_Amount = ifnull(taxval,0);
													input.Grand_Total = ifnull(input.Tax_Amount,0) + ifnull(input.Sub_Total,0);
												}
											}
										}
						)
					}
				}

			}
			on_the_user_input_of_purc as "on the user input of purchase order"
			{
				type =  form
				form = Purchase_Order

				record event = on add or edit

				on user input of Line_Items.Product_Name
				{
					actions 
					{
						custom deluge script
						(
											duplicateFound = false;
										currentProduct = row.Product_Name;
										row.Product_Code=row.Product_Name.Product_Code;
										getsku = Product_Master[Product_Code == row.Product_Name.Product_Code];
										skulist = List();
										if(getsku.count() > 0)
										{
											for each  skuget in getsku
											{
												skulist.add(skuget.ID);
											}
											row.SKU:ui.add(skulist);
										}
										getproData = Product_Master[ID == row.Product_Name];
										if(getproData.count() > 0)
										{
											getdynamic = Dynamic_Price_Master[Product_Name == row.Product_Name];
											if(getdynamic.count() > 0)
											{
												row.Price=getdynamic.Unit_Price;
											}
											else
											{
												row.Price=getproData.Unit_Price;
											}
										}
										for each  lineItem in input.Line_Items
										{
											if(lineItem != row)
											{
												if(lineItem.Product_Name == currentProduct)
												{
													duplicateFound = true;
													break;
												}
											}
										}
										if(duplicateFound)
										{
											alert "Product already selected.Kindly select different product.";
											row.Product_Name=null;
											row.Product_Code=null;
											row.Total=null;
											row.Price=null;
											row.Quantity=null;
										}
						)
					}
				}

			}
