			on_the_user_input_of_SKU as "on the user input of SKU"
			{
				type =  form
				form = Sample_Collection_Report

				record event = on add or edit

				on user input of Products.SKU
				{
					actions 
					{
						custom deluge script
						(
											duplicateFound = false;
										currentProduct = row.Product;
										currentSKU = row.SKU;
										for each  lineItem in input.Products
										{
											if(lineItem != row)
											{
												if(lineItem.Product == currentProduct && lineItem.SKU == currentSKU)
												{
													duplicateFound = true;
													break;
												}
											}
										}
										if(duplicateFound)
										{
											alert "This product with same SKU is already added.";
											row.Product=null;
											row.SKU=null;
										}
						)
					}
				}

			}
			on_success4 as "on success"
			{
				type =  form
				form = Return_Sales_order_Line_Items

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											getinv = Invoice_Line_Items[ID == input.Invoice_Line_Items];
										if(getinv.count() > 0)
										{
											getinv.Return_Done=true;
										}
										input.Return_Date = zoho.currentdate;
										input.Product_Code = input.SKU.Product_Code;
										getinvData = Invoice[ID == input.Invoice];
										if(getinvData.count() > 0)
										{
											plantcode = ifnull(getinvData.Plant,"");
											productcode = ifnull(input.Product_Code,"");
											criteria = "((Name:equals:" + productcode.toString() + ") and (Plant:equals:" + plantcode.toString() + "))";
											othermap = Map();
											//searchRec = zoho.crm.searchRecords("Product_Inventory",criteria,0,200,othermap,"zohocrm_connection");
											searchRec = zoho.crm.searchRecords("Product_Inventory",criteria,0,200,othermap,"zoho_oauth_connection");
											if(searchRec != null && searchRec.isEmpty() == false)
											{
												for each  rec in searchRec
												{
													batch = ifnull(rec.get("Batch"),"");
													input.Batch_Number = batch;
												}
											}
										}
						)
					}
				}

			}
