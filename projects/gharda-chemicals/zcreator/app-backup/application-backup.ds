				values = {"Green onion","Bengal Gram","Brinjal","Cabbage","Cauliflower","Chillies","Clusterbean","Cole Crops","Cucurbits","Cumin","Flower","Garlic","Greengram","Groundnut","Guar","Lady Finger","Maize (Rabi)","Maize (Summer)","Mustard","Okra","Onion","Paddy","Pomegranate","Potato","Red Gram","Soyabean","Tomato","Wheat"}
