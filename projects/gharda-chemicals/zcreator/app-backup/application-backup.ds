			on_the_user_input_of_Quan1 as "on the user input of Quantity received"
			{
				type =  form
				form = GRN_Master

				record event = on add or edit

				on user input of Line_Items.Quantity_Received
				{
					actions 
					{
						custom deluge script
						(
											if(row.Quantity_Received.isNull() == false)
										{
											if(row.Quantity_Received > row.Quantity_Returned)
											{
												alert "Quantity Received should not be greater than Quantity Returned";
												row.Quantity_Received=null;
											}
											if(row.Quantity_Received <= 0)
											{
												alert "Quantity Received should not be less than or equal to zero";
												row.Quantity_Received=null;
											}
										}
						)
					}
				}

			}
