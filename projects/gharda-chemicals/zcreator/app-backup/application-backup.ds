		page RFQ_CNF_Report
		{
			displayname = "RFQ Report"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet151' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet151()\ncontent\n&lt;%{\n\tgetCNFdata = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid];\n\tcnfList = List();\n\tif(getCNFdata.count() &gt; 0)\n\t{\n\t\tfor each  cnf in getCNFdata\n\t\t{\n\t\t\tcnfList.add(cnf.Plant.Plant);\n\t\t}\n\t}\n\tif(cnfList.isEmpty() == false)\n\t{\n\t\tcnfString = cnfList.toString(&quot;,&quot;);\n\t}\n\tif(cnfList.isEmpty() == true)\n\t{\n\t\tcnfList1 = {&quot;0080808&quot;};\n\t\tcnfString = cnfList1.toString(&quot;,&quot;);\n\t}\n\t%&gt;\n&lt;div elName=&quot;zc-component&quot; viewLinkName=&quot;RFQ_CNF&quot; params=&quot;Plant=[&lt;%=cnfString%&gt;]&quot;&gt; Loading Report...&lt;/div&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Quarterly_Balance_Confirmation
		{
			displayname = "Quarterly Balance Confirmation"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet50' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet50()\ncontent\n&lt;%{\n\t// \uD83D\uDD39 Step 1: Get logged-in user email\n\tuserEmail = zoho.loginuserid;\n\t//userEmail = &quot;zohotest768@gmail.com&quot;;\n\t// \uD83D\uDD39 Step 2: Fetch distributor record\n\tdistributorRec = Distributor_Master[Email == userEmail];\n\tcurrentMonth = zoho.currentdate.getMonth();\n\tcurrentYear = zoho.currentdate.getYear();\n\tsignQuarter = &quot;&quot;;\n\tsignYear = currentYear;\n\t//  Decide which quarter to sign\n\tif(currentMonth &gt;= 7 &amp;&amp; currentMonth &lt;= 9)\n\t{\n\t\t// Q2\n\t\tsignQuarter = &quot;Q1&quot;;\n\t}\n\telse if(currentMonth &gt;= 10 &amp;&amp; currentMonth &lt;= 12)\n\t{\n\t\t// Q3\n\t\tsignQuarter = &quot;Q2&quot;;\n\t}\n\telse if(currentMonth &gt;= 1 &amp;&amp; currentMonth &lt;= 3)\n\t{\n\t\t// Q4\n\t\tsignQuarter = &quot;Q3&quot;;\n\t}\n\telse if(currentMonth &gt;= 4 &amp;&amp; currentMonth &lt;= 6)\n\t{\n\t\t// Q1\n\t\tsignQuarter = &quot;Q4&quot;;\n\t\tsignYear = currentYear - 1;\n\t\t// previous FY\n\t}\n\tdistributorId = &quot;&quot;;\n\tdistributorName = &quot;&quot;;\n\tsapCode = &quot;&quot;;\n\tstreet = &quot;&quot;;\n\tcity = &quot;&quot;;\n\tstate = &quot;&quot;;\n\tcountry = &quot;&quot;;\n\tpincode = &quot;&quot;;\n\tsignedId = null;\n\tdid = null;\n\tcustomDate = &quot;04.&quot; + zoho.currentdate.toString(&quot;MM.yyyy&quot;);\n\tif(distributorRec.count() &gt; 0)\n\t{\n\t\trec = distributorRec;\n\t\tdistributorId = rec.ID.toString();\n\t\tdid = rec.ID;\n\t\tif(distributorId != &quot;&quot;)\n\t\t{\n\t\t\talreadySigned = false;\n\t\t\tsignedRec = Sign_Test[Distributor_Name == distributorId.toLong() &amp;&amp; Quarter == signQuarter &amp;&amp; Year_field == signYear.toString()];\n\t\t\tif(signedRec.count() &gt; 0)\n\t\t\t{\n\t\t\t\talreadySigned = true;\n\t\t\t}\n\t\t}\n\t\tdistributorName = rec.Distributor_Name;\n\t\t// \uD83D\uDD39 SAP Code\n\t\tsapCode = ifnull(rec.Distributor_SAP_ID,&quot;&quot;);\n\t\t// \uD83D\uDD39 Address Logic\n\t\tif(rec.Billing_Street != null &amp;&amp; rec.Billing_Street != &quot;&quot;)\n\t\t{\n\t\t\tstreet = rec.Billing_Street;\n\t\t}\n\t\telse\n\t\t{\n\t\t\tstreet = ifnull(rec.Street_2,&quot;&quot;);\n\t\t}\n\t\tcity = ifnull(rec.Billing_City,&quot;&quot;);\n\t\tstate = ifnull(rec.Billing_State,&quot;&quot;);\n\t\tcountry = ifnull(rec.Billing_Country,&quot;&quot;);\n\t\tpincode = ifnull(rec.Billing_Code,&quot;&quot;);\n\t\ttotalAmount = 0;\n\t\t// Fetch invoices\n\t\tinvoiceList = Invoice[Distributor_Name == distributorId.toLong() &amp;&amp; Status == &quot;Open&quot; || Status == &quot;Payment Pending&quot; || Status == &quot;Unpaid&quot;];\n\t\tif(invoiceList.count() &gt; 0)\n\t\t{\n\t\t\tfor each  inv in invoiceList\n\t\t\t{\n\t\t\t\ttotalAmount = totalAmount + ifnull(inv.Grand_Total,0);\n\t\t\t}\n\t\t}\n\t}\n\tformattedAmount = totalAmount.toDecimal().round(2);\n\t// \uD83D\uDD39 Step 3: Prepare form URL\n\tformURL = &quot;https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/form-embed/Sign_Test/YRNhpSyCpVzJ6MHBBpSq7snKJ46KnWUmQzsYQK4S66gptNN687B94DY3E8Y7VWgXq7zzq4v1qmJD1DNMB6PDaNWCWD4WxynSnErM?Distributor_Name=&quot; + distributorId;\n\t// \uD83D\uDD39 Step 4: Get Logo\n\tgetLogo = Logo_Master[ID != 0] sort by Added_Time desc;\n\timgURL = &quot;&quot;;\n\tif(getLogo.count() &gt; 0)\n\t{\n\t\tlogoRec = getLogo.get(0);\n\t\timgURL = thisapp.Image.getImage(&quot;All_Logo_Masters&quot;,&quot;Logo_Image&quot;,&quot;2evtmB0nOpWrnYOQFsez5rj0R1WDysAC4Qnrd4JzX9pX9ATzHMPheJRaJSeaTqmqSwQukNqU6ZRGjTWwU7gBFdUPyZdNUQAx3U2W&quot;,getLogo.Logo_Image);\n\t}\n\trecId = &quot;&quot;;\n\tif(alreadySigned == true)\n\t{\n\t\tif(signedRec.count() &gt; 0)\n\t\t{\n\t\t\trecId = signedRec.ID.toString();\n\t\t\tsignedId = signedRec.ID;\n\t\t}\n\t\t%&gt;\n&lt;div style=&quot;font-family: Arial; text-align:center; margin-top:100px;&quot;&gt;\n\n    &lt;h2 style=&quot;color:green;&quot;&gt;You have already signed this document.&lt;/h2&gt;\n\n    &lt;p style=&quot;margin-top:15px;&quot;&gt;\n        Click below to view your signed document\n    &lt;/p&gt;\n\n&lt;a href=&quot;https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/page-perma/Signed_Document/E9ZYO9pmETmwPRHTFeREu6kajqDUwM48npJbr1WgTEs2FEFT5rdK5XEK2davmNM7uE0DPMynpzt6QtVG4jJOdhTtOw1gg7ghCOJx?idd=&lt;%=did%&gt;&amp;signed_id=&lt;%=signedId%&gt;&quot;\n   style=&quot;display:inline-block; margin-top:20px; padding:10px 20px; background:#007bff; color:#fff; text-decoration:none; border-radius:5px;&quot;&gt;\n        View Signed Document\n    &lt;/a&gt;\n&lt;br&gt;&lt;br&gt;\n&lt;/div&gt;\n&lt;%\n\t}\n\telse\n\t{\n\t\t%&gt;\n&lt;div style=&quot;font-family: &apos;Times New Roman&apos;, serif; max-width: 850px; margin: auto; padding: 20px; border: 1px solid #000;&quot;&gt;\n\n    &lt;!-- HEADER WITH LOGO --&gt;\n    &lt;div style=&quot;display:flex; justify-content:space-between; align-items:center;&quot;&gt;\n\n        &lt;!-- LEFT SIDE --&gt;\n        &lt;div&gt;\n            &lt;h2 style=&quot;margin:0;&quot;&gt;GHARDA CHEMICALS LIMITED&lt;/h2&gt;\n            &lt;p style=&quot;font-size:12px; margin:5px 0;&quot;&gt;\n                Regd.Office : Gharda House, 48, Hill Road, Bandra(W), Mumbai-400050, INDIA.&lt;br&gt;\n                Tel.: +91-22-3306 5600 | Fax : +91-22-2640 42 24&lt;br&gt;\n                Website: www.gharda.com\n            &lt;/p&gt;\n        &lt;/div&gt;\n\n        &lt;!-- RIGHT SIDE LOGO --&gt;\n        &lt;div&gt;\n&lt;%\n\t\tif(imgURL != &quot;&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;img src=&quot;&lt;%=imgURL%&gt;&quot; style=&quot;height:70px; width:auto;&quot; /&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;/div&gt;\n\n    &lt;/div&gt;\n\n    &lt;hr&gt;\n\n    &lt;!-- DATE + SAP --&gt;\n    &lt;div style=&quot;display:flex; justify-content:space-between;&quot;&gt;\n        &lt;p&gt;&lt;b&gt;Date:&lt;/b&gt; &lt;%=customDate%&gt;&lt;/p&gt;\n        &lt;p&gt;&lt;b&gt;SAP Code:&lt;/b&gt; &lt;%=sapCode%&gt;&lt;/p&gt;\n    &lt;/div&gt;\n\n    &lt;!-- TO ADDRESS (DYNAMIC) --&gt;\n    &lt;p&gt;\n        &lt;b&gt;TO,&lt;/b&gt;&lt;br&gt;\n        &lt;%=if(distributorName != &quot;&quot;,distributorName,&quot;Distributor Name&quot;)%&gt;&lt;br&gt;\n\n        &lt;%=street%&gt;&lt;br&gt;\n\n        &lt;%=if(city != &quot;&quot;,city + &quot;, &quot;,&quot;&quot;)%&gt;\n        &lt;%=state%&gt;&lt;br&gt;\n\n        &lt;%=country%&gt;&lt;br&gt;\n\n        &lt;%=if(pincode != &quot;&quot;,pincode,&quot;&quot;)%&gt;\n    &lt;/p&gt;\n\n    &lt;!-- SUBJECT --&gt;\n    &lt;p&gt;\n        &lt;b&gt;Sub:- Confirmation of Outstanding Balance as at &lt;%=customDate%&gt;&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;!-- BODY --&gt;\n    &lt;p&gt;\n        In connection with the audit of our financial statements as at \n        &lt;b&gt;&lt;%=customDate%&gt;&lt;/b&gt;,\n        our auditors wants you to confirm the amount receivable from you as of\n        today being &lt;b&gt;Rs.&lt;%=formattedAmount%&gt; .&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;p&gt;\n        &lt;b&gt;Please confirm the amount in the format given below under your Signature and Seal of the Company.&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;p&gt;Your prompt attention to this request will be appreciated.&lt;/p&gt;\n\n    &lt;!-- SIGNATORY --&gt;\n    &lt;p&gt;\n        Yours truly,&lt;br&gt;\n        &lt;b&gt;For Gharda Chemicals Limited&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;p&gt;&lt;b&gt;Authorized Signatory&lt;/b&gt;&lt;/p&gt;\n\n    &lt;hr&gt;\n\n    &lt;!-- CONFIRMATION SECTION --&gt;\n    &lt;p&gt;\n        To,&lt;br&gt;\n        Gharda Chemicals Ltd.&lt;br&gt;\n        Mumbai.\n    &lt;/p&gt;\n\n    &lt;p&gt;\n        The balance receivable from us of Rs.&lt;%=formattedAmount%&gt;\n        as of &lt;b&gt;&lt;%=zoho.currentdate.toString(&quot;dd.MM.yyyy&quot;)%&gt;&lt;/b&gt; is correct except as noted below:\n    &lt;/p&gt;\n\n    &lt;br&gt;&lt;br&gt;\n    &lt;div style=&quot;border-bottom:1px solid #000; height:30px;&quot;&gt;&lt;/div&gt;\n    &lt;div style=&quot;border-bottom:1px solid #000; height:30px; margin-top:10px;&quot;&gt;&lt;/div&gt;\n\n    &lt;br&gt;&lt;br&gt;\n\n    &lt;!-- DATE &amp; COMPANY --&gt;\n    &lt;div style=&quot;display:flex; justify-content:space-between;&quot;&gt;\n        &lt;p&gt;Date:&lt;%=zoho.currentdate.toString(&quot;dd.MM.yyyy&quot;)%&gt;&lt;/p&gt;\n        &lt;p&gt;Company: &lt;%=distributorName%&gt;&lt;/p&gt;\n    &lt;/div&gt;\n\n    &lt;br&gt;\n\n    &lt;!-- SIGNATURE SECTION --&gt;\n    &lt;p&gt;&lt;b&gt;Customer Signature:&lt;/b&gt;&lt;/p&gt;\n&lt;%\n\t\tif(distributorId != &quot;&quot;)\n\t\t{\n\t\t\t%&gt;\n&lt;!-- SIGNATURE FORM --&gt;\n        &lt;iframe \n            height=&quot;300px&quot; \n            width=&quot;100%&quot; \n            frameborder=&quot;0&quot; \n            style=&quot;border:1px solid #000; border-radius:5px;&quot;\n            src=&quot;&lt;%=formURL%&gt;&quot;&gt;\n        &lt;/iframe&gt;\n&lt;%\n\t\t}\n\t\telse\n\t\t{\n\t\t\t%&gt;\n&lt;p style=&quot;color:red;&quot;&gt;\n            Distributor not found. Please contact admin.\n        &lt;/p&gt;\n&lt;%\n\t\t}\n\t\t%&gt;\n&lt;/div&gt;\n&lt;%\n\t}\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Invoice_Report
		{
			displayname = "Invoice Report"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet48' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet48()\ncontent\n&lt;%{\n\t// \tgetCNFdata = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid];\n\tgetCNFdata = CNF_Master[Billing_Person_Email_Id == zoho.loginuserid];\n\tcnfList = List();\n\tif(getCNFdata.count() &gt; 0)\n\t{\n\t\tfor each  cnf in getCNFdata\n\t\t{\n\t\t\tcnfList.add(cnf.Plant.Plant);\n\t\t}\n\t}\n\tif(cnfList.isEmpty() == false)\n\t{\n\t\tcnfString = cnfList.toString(&quot;,&quot;);\n\t}\n\tif(cnfList.isEmpty() == true)\n\t{\n\t\tcnfList1 = {&quot;0080808&quot;};\n\t\tcnfString = cnfList1.toString(&quot;,&quot;);\n\t}\n\t%&gt;\n&lt;div elName=&quot;zc-component&quot; viewLinkName=&quot;Invoices_CNF&quot; params=&quot;Plant=[&lt;%=cnfString%&gt;]&quot;&gt; Loading Report...&lt;/div&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Expense_Report
		{
			displayname = "Expense Report"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet1511' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet1511()\ncontent\n&lt;%{\n\tgetCNFdata = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid];\n\tcnfList = List();\n\tif(getCNFdata.count() &gt; 0)\n\t{\n\t\tfor each  cnf in getCNFdata\n\t\t{\n\t\t\tcnfList.add(cnf.Plant.Plant);\n\t\t}\n\t}\n\tif(cnfList.isEmpty() == false)\n\t{\n\t\tcnfString = cnfList.toString(&quot;,&quot;);\n\t}\n\tif(cnfList.isEmpty() == true)\n\t{\n\t\tcnfList1 = {&quot;0080808&quot;};\n\t\tcnfString = cnfList1.toString(&quot;,&quot;);\n\t}\n\t%&gt;\n&lt;div elName=&quot;zc-component&quot; viewLinkName=&quot;Expenses_CNF&quot; params=&quot;Plant1=[&lt;%=cnfString%&gt;]&quot;&gt; Loading Report...&lt;/div&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Dispatch_CNF_Report
		{
			displayname = "Dispatch Report"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet1512' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet1512()\ncontent\n&lt;%{\n\t// \tgetCNFdata = CNF_Master[GCL_Accountant_Email_Id == zoho.loginuserid];\n\tgetCNFdata = CNF_Master[Billing_Person_Email_Id == zoho.loginuserid];\n\tcnfList = List();\n\tif(getCNFdata.count() &gt; 0)\n\t{\n\t\tfor each  cnf in getCNFdata\n\t\t{\n\t\t\tcnfList.add(cnf.Plant.Plant);\n\t\t}\n\t}\n\tif(cnfList.isEmpty() == false)\n\t{\n\t\tcnfString = cnfList.toString(&quot;,&quot;);\n\t}\n\tif(cnfList.isEmpty() == true)\n\t{\n\t\tcnfList1 = {&quot;0080808&quot;};\n\t\tcnfString = cnfList1.toString(&quot;,&quot;);\n\t}\n\t%&gt;\n&lt;div elName=&quot;zc-component&quot; viewLinkName=&quot;Dispatches_CNF&quot; params=&quot;Plant=[&lt;%=cnfString%&gt;]&quot;&gt; Loading Report...&lt;/div&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Signed_Document(int idd, int signed_id)
		{
			displayname = "Signed Document"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet52' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet52()\ncontent\n&lt;%{\n\t// Get record ID from URL\n\t// \trecId = 341335000001624011;\n\trecId = input.idd;\n\tinfo recId;\n\tsid = input.signed_id;\n\t// Fetch record\n\trecList = Sign_Test[ID == sid];\n\tdistributorName = &quot;&quot;;\n\tsignedDate = &quot;&quot;;\n\tsignatureURL = &quot;&quot;;\n\tif(recList.count() &gt; 0)\n\t{\n\t\trec = recList.get(0);\n\t\tinfo rec;\n\t}\n\tdistributorRec = Distributor_Master[ID == recId];\n\tdistributorId = &quot;&quot;;\n\tdistributorName = &quot;&quot;;\n\tsapCode = &quot;&quot;;\n\tstreet = &quot;&quot;;\n\tcity = &quot;&quot;;\n\tstate = &quot;&quot;;\n\tcountry = &quot;&quot;;\n\tpincode = &quot;&quot;;\n\tcustomDate = &quot;04.&quot; + zoho.currentdate.toString(&quot;MM.yyyy&quot;);\n\tif(distributorRec.count() &gt; 0)\n\t{\n\t\trec = distributorRec;\n\t\tdistributorId = rec.ID.toString();\n\t\tdistributorName = distributorRec.Distributor_Name;\n\t\t// \uD83D\uDD39 SAP Code\n\t\tsapCode = ifnull(rec.Distributor_SAP_ID,&quot;&quot;);\n\t\t// \uD83D\uDD39 Address Logic\n\t\tif(rec.Billing_Street != null &amp;&amp; rec.Billing_Street != &quot;&quot;)\n\t\t{\n\t\t\tstreet = rec.Billing_Street;\n\t\t}\n\t\telse\n\t\t{\n\t\t\tstreet = ifnull(rec.Street_2,&quot;&quot;);\n\t\t}\n\t\tcity = ifnull(rec.Billing_City,&quot;&quot;);\n\t\tstate = ifnull(rec.Billing_State,&quot;&quot;);\n\t\tcountry = ifnull(rec.Billing_Country,&quot;&quot;);\n\t\tpincode = ifnull(rec.Billing_Code,&quot;&quot;);\n\t\ttotalAmount = 0;\n\t\t// Fetch invoices\n\t\tinvoiceList = Invoice[Distributor_Name == distributorId.toLong() &amp;&amp; Status == &quot;Open&quot; || Status == &quot;Payment Pending&quot; || Status == &quot;Unpaid&quot;];\n\t\tif(invoiceList.count() &gt; 0)\n\t\t{\n\t\t\tfor each  inv in invoiceList\n\t\t\t{\n\t\t\t\ttotalAmount = totalAmount + ifnull(inv.Grand_Total,0);\n\t\t\t}\n\t\t}\n\t}\n\tformattedAmount = 0;\n\tif(totalAmount &gt; 0)\n\t{\n\t\tformattedAmount = totalAmount.toDecimal().round(2);\n\t}\n\t// Prepare Signature Block\n\tsignatureBlock = &quot;&quot;;\n\tif(recList.count() &gt; 0)\n\t{\n\t\tsignatureFilename = recList.Signature;\n\t\timageUrl = &quot;https://creator.zoho.in/zohoadmin_gharda782/distributor-management-gharda-chemical/All_Sign_Tests/&quot; + recList.ID + &quot;/Signature/image-download/pmAwZK5QRFPqTmhTagQz4uMb8yZan1BNFUrbDQsud6fzZQtadVHv5sTqH70gB0temGXXhaVkOhMXM0uZdbRURbZwvSkEgpyf4xHN/&quot; + signatureFilename;\n\t\t// Create the HTML image tag\n\t\tsignatureBlock = &quot;&lt;img src=&apos;&quot; + imageUrl + &quot;&apos; alt=&apos;Signature&apos; style=&apos;height: 100px; border: 1px solid black;&apos;/&gt;&quot;;\n\t\t// \t\t//signatureBlock = rec.Signature;\n\t}\n\telse\n\t{\n\t\tsignatureBlock = &quot;&lt;p style=&apos;color:red;&apos;&gt;No signature found.&lt;/p&gt;&quot;;\n\t}\n\t// Get Logo\n\tgetLogo = Logo_Master[ID != 0] sort by Added_Time desc;\n\timgURL = &quot;&quot;;\n\tif(getLogo.count() &gt; 0)\n\t{\n\t\tlogoRec = getLogo.get(0);\n\t\timgURL = thisapp.Image.getImage(&quot;All_Logo_Masters&quot;,&quot;Logo_Image&quot;,&quot;2evtmB0nOpWrnYOQFsez5rj0R1WDysAC4Qnrd4JzX9pX9ATzHMPheJRaJSeaTqmqSwQukNqU6ZRGjTWwU7gBFdUPyZdNUQAx3U2W&quot;,getLogo.Logo_Image);\n\t}\n\t%&gt;\n&lt;div style=&quot;font-family: &apos;Times New Roman&apos;, serif; max-width: 850px; margin: auto; padding: 20px; border: 1px solid #000;&quot;&gt;\n    &lt;!-- HEADER WITH LOGO --&gt;\n    &lt;div style=&quot;display:flex; justify-content:space-between; align-items:center;&quot;&gt;\n\n        &lt;!-- LEFT SIDE --&gt;\n        &lt;div&gt;\n            &lt;h2 style=&quot;margin:0;&quot;&gt;GHARDA CHEMICALS LIMITED&lt;/h2&gt;\n            &lt;p style=&quot;font-size:12px; margin:5px 0;&quot;&gt;\n                Regd.Office : Gharda House, 48, Hill Road, Bandra(W), Mumbai-400050, INDIA.&lt;br&gt;\n                Tel.: +91-22-3306 5600 | Fax : +91-22-2640 42 24&lt;br&gt;\n                Website: www.gharda.com\n            &lt;/p&gt;\n        &lt;/div&gt;\n\n        &lt;!-- RIGHT SIDE LOGO --&gt;\n        &lt;div&gt;\n&lt;%\n\tif(imgURL != &quot;&quot;)\n\t{\n\t\t%&gt;\n&lt;img src=&quot;&lt;%=imgURL%&gt;&quot; style=&quot;height:70px; width:auto;&quot; /&gt;\n&lt;%\n\t}\n\t%&gt;\n&lt;/div&gt;\n\n    &lt;/div&gt;\n\n    &lt;hr&gt;\n\n    &lt;!-- DATE + SAP --&gt;\n    &lt;div style=&quot;display:flex; justify-content:space-between;&quot;&gt;\n        &lt;p&gt;&lt;b&gt;Date:&lt;/b&gt; &lt;%=customDate%&gt;&lt;/p&gt;\n        &lt;p&gt;&lt;b&gt;SAP Code:&lt;/b&gt; &lt;%=sapCode%&gt;&lt;/p&gt;\n    &lt;/div&gt;\n\n    &lt;!-- TO ADDRESS (DYNAMIC) --&gt;\n    &lt;p&gt;\n        &lt;b&gt;TO,&lt;/b&gt;&lt;br&gt;\n        &lt;%=if(distributorName != &quot;&quot;,distributorName,&quot;Distributor Name&quot;)%&gt;&lt;br&gt;\n\n        &lt;%=street%&gt;&lt;br&gt;\n\n        &lt;%=if(city != &quot;&quot;,city + &quot;, &quot;,&quot;&quot;)%&gt;\n        &lt;%=state%&gt;&lt;br&gt;\n\n        &lt;%=country%&gt;&lt;br&gt;\n\n        &lt;%=if(pincode != &quot;&quot;,pincode,&quot;&quot;)%&gt;\n    &lt;/p&gt;\n\n    &lt;!-- SUBJECT --&gt;\n    &lt;p&gt;\n        &lt;b&gt;Sub:- Confirmation of Outstanding Balance as at &lt;%=customDate%&gt;&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;!-- BODY --&gt;\n    &lt;p&gt;\n        In connection with the audit of our financial statements as at \n        &lt;b&gt;&lt;%=customDate%&gt;&lt;/b&gt;,\n        our auditors wants you to confirm the amount receivable from you as of\n        today being &lt;b&gt;Rs.&lt;%=formattedAmount%&gt; .&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;p&gt;\n        &lt;b&gt;Please confirm the amount in the format given below under your Signature and Seal of the Company.&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;p&gt;Your prompt attention to this request will be appreciated.&lt;/p&gt;\n\n    &lt;!-- SIGNATORY --&gt;\n    &lt;p&gt;\n        Yours truly,&lt;br&gt;\n        &lt;b&gt;For Gharda Chemicals Limited&lt;/b&gt;\n    &lt;/p&gt;\n\n    &lt;p&gt;&lt;b&gt;Authorized Signatory&lt;/b&gt;&lt;/p&gt;\n\n    &lt;hr&gt;\n\n    &lt;!-- CONFIRMATION SECTION --&gt;\n    &lt;p&gt;\n        To,&lt;br&gt;\n        Gharda Chemicals Ltd.&lt;br&gt;\n        Mumbai.\n    &lt;/p&gt;\n\n    &lt;p&gt;\n        The balance receivable from us of Rs.&lt;%=formattedAmount%&gt;\n        as of &lt;b&gt;&lt;%=zoho.currentdate.toString(&quot;dd.MM.yyyy&quot;)%&gt;&lt;/b&gt; is correct except as noted below:\n    &lt;/p&gt;\n\n    &lt;br&gt;&lt;br&gt;\n    &lt;div style=&quot;border-bottom:1px solid #000; height:30px;&quot;&gt;&lt;/div&gt;\n    &lt;div style=&quot;border-bottom:1px solid #000; height:30px; margin-top:10px;&quot;&gt;&lt;/div&gt;\n\n    &lt;br&gt;&lt;br&gt;\n\n    &lt;!-- DATE &amp; COMPANY --&gt;\n    &lt;div style=&quot;display:flex; justify-content:space-between;&quot;&gt;\n        &lt;p&gt;Date:&lt;%=zoho.currentdate.toString(&quot;dd.MM.yyyy&quot;)%&gt;&lt;/p&gt;\n        &lt;p&gt;Company: &lt;%=distributorName%&gt;&lt;/p&gt;\n    &lt;/div&gt;\n\n    &lt;br&gt;\n\n    &lt;!-- SIGNATURE SECTION --&gt;\n    &lt;p&gt;&lt;b&gt;Customer Signature:&lt;/b&gt;&lt;/p&gt;\n\n    &lt;!-- \uD83D\uDD39 Inject Signature --&gt;\n    &lt;%=signatureBlock%&gt;\n\n&lt;/div&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page Thank_You(string SignID, int signed_id)
		{
			displayname = "Thank You"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet53' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet53()\ncontent\n&lt;%{\n\t%&gt;\n&lt;!DOCTYPE html&gt;\n&lt;html lang=&quot;en&quot;&gt;\n&lt;head&gt;\n  &lt;meta charset=&quot;UTF-8&quot;&gt;\n  &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;\n  &lt;title&gt;Thank You&lt;/title&gt;\n  &lt;style&gt;\n  \n\n    .container {\n      background: #ffffff;\n      padding: 40px;\n      border-radius: 12px;\n      text-align: center;\n      width: 400px;\n      box-shadow: 0 10px 25px rgba(0,0,0,0.2);\n    }\n\n    .icon {\n      font-size: 60px;\n      color: #28a745;\n    }\n\n    h1 {\n      margin: 20px 0 10px;\n      color: #333;\n    }\n\n    p {\n      color: #666;\n      font-size: 16px;\n      margin-bottom: 30px;\n    }\n\n    .btn1 {\n      display: inline-block;\n      padding: 12px 25px;\n      background: #007bff;\n      color: #fff;\n      text-decoration: none;\n      border-radius: 6px;\n      transition: 0.3s;\n      font-weight: bold;\n    }\n\n    .btn1:hover {\n      background: #0056b3;\n    }\n\n    .link-text {\n      display: block;\n      margin-top: 15px;\n      font-size: 14px;\n    }\n\n    .link-text a {\n      color: #007bff;\n      text-decoration: none;\n      font-weight: bold;\n    }\n\n    .link-text a:hover {\n      text-decoration: underline;\n    }\n  &lt;/style&gt;\n&lt;/head&gt;\n&lt;body&gt;\n&lt;div style=&quot;height:600px;&quot;&gt;\n  &lt;div class=&quot;container&quot; &gt;\n    &lt;div class=&quot;icon&quot;&gt;\u2714&lt;/div&gt;\n    &lt;h1&gt;Thank You!&lt;/h1&gt;\n    &lt;p&gt;Your have signed the document successfully.&lt;/p&gt;\n\n    &lt;!-- Button Redirect\n    &lt;a href=&quot;https://your-report-link.com&quot; class=&quot;btn1&quot;&gt;View Document Report&lt;/a&gt; --&gt;\n\n    &lt;!-- Optional Text Link --&gt;\n    &lt;div class=&quot;link-text&quot;&gt;\n     &lt;a href=&quot;https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/page-perma/Signed_Document/E9ZYO9pmETmwPRHTFeREu6kajqDUwM48npJbr1WgTEs2FEFT5rdK5XEK2davmNM7uE0DPMynpzt6QtVG4jJOdhTtOw1gg7ghCOJx?idd=&lt;%=input.SignID%&gt;&amp;signed_id=&lt;%=input.signed_id%&gt;&quot;&gt;click here to view the document report&lt;/a&gt;\n    &lt;/div&gt;\n  &lt;/div&gt;\n  &lt;/div&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
