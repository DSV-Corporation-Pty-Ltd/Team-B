			on_the_user_input_of_quan as "on the user input of quantity"
			{
				type =  form
				form = Order_Management

				record event = on add or edit

				on user input of Line_Items.Quantity
				{
					actions 
					{
						custom deluge script
						(
											todaydate = zoho.currentdate;
										//material tax code start here 
										distributor = Distributor_Master[ID == input.Distributor_Name];
										if(distributor.count() > 0)
										{
											SAPID = distributor.Distributor_SAP_ID;
											PlantCode = distributor.Plant.Plant;
											//PlantCode = "1201";
											material_Code = row.Product_Code;
											//material_Code = "TRSEEDPLS250ML";
											othermap = Map();
											if(SAPID.isEmpty() == false)
											{
												othermap = Map();
												regionCode = "";
												getreg = "";
												IGST9 = null;
												//searchRec = zoho.crm.searchRecords("Accounts","SAP_ID:equals:" + SAPID.toString(),0,200,othermap,"zohocrm_connection");
												searchRec = zoho.crm.searchRecords("Accounts","SAP_ID:equals:" + SAPID.toString(),0,200,othermap,"zoho_oauth_connection");
												if(searchRec.size() > 0)
												{
													regionCode = searchRec.get(0).get("RG").toString();
													//alert regionCode;
													if(regionCode.isEmpty() == false)
													{
														criteria = "((Plant:equals:" + PlantCode.toString() + ") and (Name:equals:" + material_Code.toString() + ") and (Region_Code:equals:" + regionCode.toString() + "))";
														//searchReg = zoho.crm.searchRecords("Material_Tax",criteria,0,200,othermap,"zohocrm_connection");
														searchReg = zoho.crm.searchRecords("Material_Tax",criteria,0,200,othermap,"zoho_oauth_connection");
														//alert PlantCode;alert material_Code;alert regionCode;
														if(searchReg.size() > 0)
														{
															for each  searchRe in searchReg
															{
																if(searchRe.get("CGST") != null)
																{
																	input.CGST1 = ifnull(searchRe.getJson("CGST"),null);
																	//alert searchRe.getJson("CGST");
																}
																if(searchRe.get("SGST") != null)
																{
																	input.SGST1 = ifnull(searchRe.getJson("SGST"),null);
																}
																if(searchRe.get("IGST") != null)
																{
																	IGST9 = ifnull(searchRe.getJson("IGST"),null);
																}
															}
														}
														//searchPlant = zoho.crm.searchRecords("Plants_Master","Name:equals:" + PlantCode,0,200,othermap,"zohocrm_connection");
														searchPlant = zoho.crm.searchRecords("Plants_Master","Name:equals:" + PlantCode,0,200,othermap,"zoho_oauth_connection");
														if(searchPlant.size() > 0)
														{
															getreg = searchPlant.get(0).get("Region").toString();
														}
														//alert "regionCode"+regionCode;alert "getreg"+getreg;
														if(regionCode != getreg)
														{
															//alert regionCode;alert getreg;
															input.IGST1 = IGST9;
														}
													}
												}
											}
										}
										//material tax code end here 
										row.Discount_Value=0;
										if(row.Quantity > 0)
										{
											discountprice = 0;
											totalamt = 0;
											if(row.Discount_Price > 0)
											{
												discountprice = ifnull(row.Discount_Price,0);
												finalPrice = ifnull(row.Billing_Price,0) - ifnull(row.Discount_Price,0);
												//discountprice = row.Quantity * ifnull(row.Discount_Price,0);
												//totalamt = row.Quantity * ifnull(row.finalPrice,0);
												row.Total=row.Quantity * ifnull(finalPrice,0);
												//row.Total=ifnull(totalamt,0) - ifnull(discountprice,0);
											}
											else
											{
												totalamt = row.Quantity * ifnull(row.Billing_Price,0);
												row.Total=totalamt;
											}
										}
										else
										{
											alert "Quantity will not be zero or negative";
											row.Quantity=null;
											input.IGST1 = null;
											input.SGST1 = null;
											input.CGST1 = null;
										}
										total = 0;
										if(row.Quantity > 0)
										{
											for each  products in input.Line_Items
											{
												totalp = ifnull(products.Total,0);
												total = totalp + total;
											}
										}
										else
										{
											row.Total=0;
										}
										input.Subtotal = total;
										subtotal = ifnull(input.Subtotal,0);
										gst_percent = ifnull(input.CGST,0);
										gst_amt = subtotal * gst_percent / 100;
										igstamount = ifnull(input.IGST,0);
										igst = subtotal * igstamount / 100;
										sgstamount = ifnull(input.SGST,0);
										sgst = subtotal * sgstamount / 100;
										//material Tax start here
										sgtamt = ifnull(input.SGST1,0);
										sgtval = subtotal * sgtamt / 100;
										cgtamt = ifnull(input.CGST1,0);
										cgtval = subtotal * cgtamt / 100;
										igtamt = ifnull(input.IGST1,0);
										igtval = subtotal * igtamt / 100;
										//material tax end here 
										input.Tax_Amount = ifnull(gst_amt,0) + ifnull(igst,0) + ifnull(sgst,0) + ifnull(sgtval,0) + ifnull(cgtval,0) + ifnull(igtval,0);
										input.Grand_Total = ifnull(subtotal,0) + ifnull(input.Tax_Amount,0);
										if(row.SKU.isEmpty() == true)
										{
											alert "You have not selected sku yet .Kindly select SKU first.";
											row.Quantity=null;
											input.IGST1 = null;
											input.SGST1 = null;
											input.CGST1 = null;
										}
										//check stock
										stock = 0;
										productcode = row.SKU.Product_Code;
										// alert productcode;
										plantcode = input.Plant.Plant;
										// alert plantcode;
										stock = 0;
										latestRecord = Map();
										latestCreatedTime = "";
										latestCreatedKey = 0;
										criteria = "((Name:equals:" + productcode.toString() + ") and (Plant:equals:" + plantcode.toString() + "))";
										othermap = Map();
										searchRec = zoho.crm.searchRecords("Product_Inventory",criteria,0,200,othermap,"zoho_oauth_connection");
										// alert searchRec;
										//searchRec = zoho.crm.searchRecords("Product_Inventory",criteria,0,200,othermap,"zohocrm_connection");
										if(searchRec != null && searchRec.isEmpty() == false)
										{
											// 	alert searchRec.size();
											sum = 0;
											for each  rec in searchRec
											{
												sum = sum + rec.get("Unrestricted_Stock");
												// 		createdTime = ifnull(rec.get("Created_Time"),"");
												// 		if(createdTime != "")
												// 		{
												// 			createdTimeOnly = createdTime.getPrefix("+");
												// 			createdKeyStr = createdTimeOnly.replaceAll("-","");
												// 			createdKeyStr = createdKeyStr.replaceAll("T","");
												// 			createdKeyStr = createdKeyStr.replaceAll(":","");
												// 			createdKey = createdKeyStr.toLong();
												// 			if(latestCreatedKey == 0 || createdKey > latestCreatedKey)
												// 			{
												// 				latestCreatedKey = createdKey;
												// 				latestCreatedTime = createdTime;
												// 				latestRecord = rec;
												// 			}
												// 		}
											}
										}
										// if(latestRecord.isEmpty() == false)
										// {
										// 	stock = ifnull(latestRecord.get("Unrestricted_Stock"),"0").toLong();
										// }
										if(sum <= 0)
										{
											alert "Stock is not available for this product.";
											row.Quantity=null;
											input.IGST1 = null;
											input.SGST1 = null;
											input.CGST1 = null;
										}
										else
										{
											if(row.Quantity > sum)
											{
												// 		alert "Stock is not sufficient for this product. Available stock is " + sum.toString();
												alert "Stock is not sufficient for this product.";
												row.Quantity=null;
												input.IGST1 = null;
												input.SGST1 = null;
												input.CGST1 = null;
											}
										}
										getProdData = Product_Master[ID == row.SKU];
										if(getProdData.count() > 0)
										{
											if(row.Quantity < getProdData.Case_Size)
											{
												alert "Min Quantity should be " + getProdData.Case_Size.toNumber();
												row.Quantity=null;
												input.IGST1 = null;
												input.SGST1 = null;
												input.CGST1 = null;
											}
											if(getProdData.Case_Size.isNull() == false)
											{
												Case_Size = getProdData.Case_Size.toNumber();
												if(row.Quantity != null && row.Quantity % Case_Size != 0)
												{
													alert "Quantity must be multiple of " + Case_Size;
													row.Quantity=null;
													input.IGST1 = null;
													input.SGST1 = null;
													input.CGST1 = null;
												}
											}
										}
										if(input.Order_Type == "Cash Advance Order")
										{
											getdisData = Distributor_Master[ID == input.Distributor_Name];
											if(getdisData.count() > 0)
											{
												if(input.Grand_Total > abs(getdisData.Advance_Deposit))
												{
													alert "Cash depoit is not sufficient for this order, reduce quantity or create credit order";
													// 			openUrl("#Page:Payment?","popup window","height=200px,width=550px");
													row.Quantity=null;
												}
											}
										}
						)
					}
				}

			}
