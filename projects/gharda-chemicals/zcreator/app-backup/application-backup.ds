			on_the_user_input_of_ente as "on the user input of enter otp"
			{
				type =  form
				form = Verify_OTP

				record event = on add

				on user input of Enter_OTP
				{
					actions 
					{
						custom deluge script
						(
											// getdispatchData = OTP_Module[DispatchID == input.DispatchID && OTP == input.Enter_OTP] sort by Added_Time desc;
										// if(getdispatchData.count() <= 0)
										// {
										// 	alert "You have entered the wrong OTP";
										// }
										getdispatchData = Dispatch[ID == input.DispatchID];
										if(getdispatchData.count() > 0)
										{
											getdisadata = Distributor_Master[ID == getdispatchData.Distributor];
											if(getdisadata.count() > 0)
											{
												disphone = getdisadata.Contact_Number;
												if(disphone.isEmpty() == false)
												{
													last10 = right(disphone,10);
													otp = input.Enter_OTP;
													if(otp.isEmpty() == false)
													{
														resp = thisapp.OTP.VerifyOTP(last10.toString(),otp.toString());
														if(resp.get("type") == "error")
														{
															alert resp.get("message");
															input.Enter_OTP = null;
														}
													}
												}
											}
										}
						)
					}
				}

			}
			on_success1 as "on success"
			{
				type =  form
				form = Verify_OTP

				record event = on add

				on success
				{
					actions 
					{
						openURL("#Report:Dispatches_Logistic","new window");
					}
					actions 
					{
						custom deluge script
						(
											getdispatchData = Dispatch[ID == input.DispatchID];
										if(getdispatchData.count() > 0)
										{
											getdispatchData.Status="Delivered";
											getdispatchData.Delivery_Date=zoho.currentdate;
											getdispatchData.ePOD=input.Upload_Consignee_Copy;
											// 	getGRNData = GRN_Master[Sales_Order == getdispatchData.Sales_Order];
											// 	if(getGRNData.count() > 0)
											// 	{
											// 		getGRNData.Consignee_Copy=input.Upload_Consignee_Copy;
											// 		getGRNData.Delivery_Status="Delivered";
											// 	}
											getSOData = Order_Management[ID == getdispatchData.Sales_Order];
											if(getSOData.count() > 0)
											{
												getAllSO = Dispatch[Sales_Order == getSOData.ID].Status.getAll();
												if(getAllSO.contains("Pending") == true)
												{
													getSOData.Status="Delivered";
													updateMap = Map();
													if(getdispatchData.zoho_crm_id.isEmpty() == false)
													{
														updateMap.put("Dispatch_Status","Delivered");
														CRMID = getdispatchData.zoho_crm_id;
														othermap = Map();
														updateInZoho = zoho.crm.updateRecord("Dispatch_Master",CRMID.toLong(),updateMap,othermap,"zoho_oauth_connection");
														//updateInZoho = zoho.crm.updateRecord("Dispatch_Master",CRMID.toLong(),updateMap,othermap,"zohocrm_connection");
													}
												}
											}
										}
										thisapp.EPOD.syncEPODInCrm(input.ID);
										openUrl("#Script:page.reload ","same window");
						)
					}
				}

			}
