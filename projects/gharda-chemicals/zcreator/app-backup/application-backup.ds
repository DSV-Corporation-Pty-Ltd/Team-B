			disable_fields as "disable fields"
			{
				type =  form
				form = Order_Management

				record event = on add or edit

				on add row of Line_Items
				{
					actions 
					{
						custom deluge script
						(
											disable row.Discount_Price;
										disable row.Discount;
										disable row.Total;
										row.Discount=0.0;
										//new code star here
										emptyMap = Map();
										uniqueProductCodeMap = Map();
										uniqueProductCodeList = List();
										plant = input.Plant.Plant;
										// plant="1207";
										criteria = "(Plant:equals:" + plant + ")";
										// Run 5 times: page 1 to page 5
										pageList = List();
										pageList.add(1);
										pageList.add(2);
										pageList.add(3);
										pageList.add(4);
										pageList.add(5);
										for each  pageNo in pageList
										{
											//productInventoryList = zoho.crm.searchRecords("Product_Inventory",criteria,pageNo,200,emptyMap,"zohocrm_connection");
											productInventoryList = zoho.crm.searchRecords("Product_Inventory",criteria,pageNo,200,emptyMap,"zoho_oauth_connection");
											if(productInventoryList != null && productInventoryList.size() > 0)
											{
												for each  productInventoryData in productInventoryList
												{
													productCode = productInventoryData.get("Name");
													if(productCode != null && productCode != "")
													{
														productCode = productCode.toString().trim();
														if(uniqueProductCodeMap.get(productCode) == null)
														{
															uniqueProductCodeMap.put(productCode,true);
															uniqueProductCodeList.add(productCode);
														}
													}
												}
											}
										}
										//new code end here 
										getBrandList = Product_Master[ID != 0 && Brand_Name != null && Product_Code in uniqueProductCodeList && Sales_Organization == "1000" && SKU1 != "LOOSE"].Brand_Name.getAll();
										getBrands = getBrandList.distinct();
										//alert getBrandList;
										getBrList = List();
										if(getBrands.isEmpty() == false)
										{
											for each  brand in getBrands
											{
												getBr = Product_Master[Brand_Name == brand && Sales_Organization == "1000" && Product_Code in uniqueProductCodeList && SKU1 != "LOOSE"];
												if(getBr.count() > 0)
												{
													// 			if(getBr.Product_Code.startsWith("FG") == true)
													// 			{
													getBrList.add(getBr.ID);
													//}
												}
											}
										}
										//alert getBrList;
										for each  items in input.Line_Items
										{
											items.Product_Name:ui.add(getBrList);
											items.Product_Name=items.Product_Name;
										}
										emptytList = List();
										row.SKU:ui.add(emptytList);
						)
					}
				}

			}
			calculate_subtotal as "calculate subtotal"
			{
				type =  form
				form = Order_Management

				record event = on add or edit

				on delete row of Line_Items
				{
					actions 
					{
						custom deluge script
						(
											// Step 1: Subtract deleted row's total from subtotal
										row_total = ifnull(row.Total,0);
										new_subtotal = ifnull(input.Subtotal,0) - row_total;
										input.Subtotal = new_subtotal;
										// Step 2: Calculate tax based on new subtotal
										gst_rate = ifnull(input.CGST,0);
										igst_rate = ifnull(input.IGST,0);
										sgst_rate = ifnull(input.SGST,0);
										gst_amt = new_subtotal * gst_rate / 100;
										igst_amt = new_subtotal * igst_rate / 100;
										sgst_amt = new_subtotal * sgst_rate / 100;
										//material Tax start here
										sgtamt = ifnull(input.SGST1,0);
										sgtval = new_subtotal * sgtamt / 100;
										cgtamt = ifnull(input.CGST1,0);
										cgtval = new_subtotal * cgtamt / 100;
										igtamt = ifnull(input.IGST1,0);
										igtval = new_subtotal * igtamt / 100;
										//material tax end here 
										tax_amt = ifnull(gst_amt,0) + ifnull(igst_amt,0) + ifnull(sgst_amt,0) + ifnull(sgtval,0) + ifnull(cgtval,0) + ifnull(igtval,0);
										input.Tax_Amount = tax_amt;
										input.Grand_Total = new_subtotal + tax_amt;
						)
					}
				}

			}
			Hide_fields as "Hide fields"
			{
				type =  form
				form = Order_Management

				record event = on add or edit

