			Validations_on_submission as "Validations on submissions"
			{
				type =  form
				form = Meeting

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.From.isNull() == false && input.To.isNull() == false)
										{
											if(input.From > input.To)
											{
												alert "From Date should not greator then To date.";
												cancel submit;
											}
										}
										if(input.From.isNull() == false && input.To.isNull() == false)
										{
											if(input.To < input.From)
											{
												alert "To Date should not be earlier then From date.";
												cancel submit;
											}
										}
						)
					}
				}

			}
