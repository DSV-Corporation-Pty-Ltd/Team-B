			Approve1 as "Approve"
			{
				type =  functions
				form = Quotation
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						userEmail = zoho.loginuserid;
										// Define approvers
										level1List = List();
										level1List.add("amiya.pandey@gilgharda.com");
										level1List.add("ravi.pole86@gmail.com");
										level1List.add("sgbodas66@gmail.com");
										level2Email = "vvparkar@rediffmail.com";
										// level1List.add("zohotest768@gmail.com");
										// level2Email = "maninder@fristinetech.com";
										// ---------------- LEVEL 1 ----------------
										if(input.Current_Level == "1")
										{
											input.Level1_Approved = "Yes";
											input.Approved_By = userEmail;
											input.Current_Level = "2";
											// Send to Level 2
											message = "<p>Dear Sir,</p>" + "<p>Quotation " + input.Quotation_No + " approved by " + userEmail + " (Level 1).</p>" + "<p>Now pending your approval.</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Quotations'>View</a></p>";
											sendmail
											[
												from :zoho.adminuserid
												to :level2Email
												subject :"Quotation " + input.Quotation_No + " Approval - Level 2"
												message :message
											]
											getRFQ = RFQ[ID == input.RFQ];
											if(getRFQ.count() > 0)
											{
												getRFQ.Status="Closed";
											}
											getAllquote = Quotation[RFQ == input.RFQ && Transporter_Name != input.Transporter_Name];
											if(getAllquote.count() > 0)
											{
												for each  quotedata in getAllquote
												{
													quotedata.Quotation_Approved=true;
													quotedata.Status="Rejected";
													message22 = "<p>Dear " + quotedata.Transporter_Name.Transporter_Name + ",</p>" + "<p>Quotation " + quotedata.Quotation_No + " rejected by " + userEmail + "</p>" + "<p>Kindly click on below email to view the Quote.</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Quotations'>View</a></p>";
													sendmail
													[
														from :zoho.adminuserid
														to :quotedata.Transporter_Name.Email
														subject :"Quotation " + input.Quotation_No + " has been rejected"
														message :message22
													]
												}
											}
										}
										else if(input.Current_Level == "2")
										{
											// Approve Level 2
											input.Level2_Approved = "Yes";
											input.Status = "Approved";
											input.Approved_By = userEmail;
											message1 = "<p>Dear Sir,</p>" + "<p>Quotation " + input.Quotation_No + " approved by " + userEmail + "</p>" + "<p>Kindly click on below email to view the Quote.</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Quotations_Logistic'>View</a></p>";
											sendmail
											[
												from :zoho.adminuserid
												to :input.Transporter_Name.Email
												subject :"Quotation " + input.Quotation_No + " has been approved"
												message :message1
											]
											message2 = "<p>Dear " + input.Transporter_Name.Transporter_Name + ",</p>" + "<p>Quotation " + input.Quotation_No + " approved by " + userEmail + "</p>" + "<p>Kindly click on below email to view the Quote.</p>" + "<p><a href='https://ghardasalesportal.gharda.com/#Report:Quotations'>View</a></p>";
											sendmail
											[
												from :zoho.adminuserid
												to :level1List
												subject :"Quotation " + input.Quotation_No + " has been approved"
												message :message2
											]
											message3 = "<p>Dear " + input.CNF_Name.CNF_Name + ",</p>" + "<p>Quotation " + input.Quotation_No + " has been approved by " + userEmail + "</p>" + "</p>";
											sendmail
											[
												from :zoho.adminuserid
												to :input.CNF_Name.GCL_Accountant_Email_Id
												subject :"Quotation " + input.Quotation_No + " has been approved"
												message :message3
											]
											thisapp.SMS.QuotationApprovedSMS(input.ID);
										}
					)
					}
				}
			}
