				 void TestingDownloadPdf()
                 {
                 	distId = 341335000001624011;
                 	signedId = 341335000001976004;
                 	pdfURL = "https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/page-perma/Signed_Document/E9ZYO9pmETmwPRHTFeREu6kajqDUwM48npJbr1WgTEs2FEFT5rdK5XEK2davmNM7uE0DPMynpzt6QtVG4jJOdhTtOw1gg7ghCOJx?idd=" + distId + "&signed_id=" + signedId + "&zc_Print=true";
                 	// 🔹 Step 3: Fetch PDF
                 	pdfFile = invokeurl
                 	[
                 		url :pdfURL
                 		type :GET
                 	];
                 	//info pdfFile;
                 	pdfFile1 = zoho.file.convertToPDF(pdfFile);
                 	// 4. Send email with all PDFs attached
                 	sendmail
                 	[
                 		from :zoho.adminuserid
                 		to :"zohotest768@gmail.com"
                 		subject :"Your Order Documents - Order #"
                 		message :"Dear please find your documents attached."
                 		Attachments :file:pdfFile1
                 	]
                 	if(pdfFile1.isEmpty() == false)
                 	{
                 		pdfFile1.setParamName("file");
                 		upload_url = "https://creatorapp.zoho.in/api/v2/zohoadmin_gharda782/distributor-management-gharda-chemical/report/All_Sign_Tests/" + signedId + "/Signed_PDF/upload";
                 		response = invokeurl
                 		[
                 			url :upload_url
                 			type :POST
                 			files:pdfFile1
                 			connection:"zoho_oauth_connection"
                 		];
                 		info response;
                 	}
                 }
				 void TEstingTranslatorAPI()
                 {
                 	headersMap = Map();
                 	headersMap.put("Authorization","Bearer ta_0f86401deefdcf9490eed9d560ae9ab0f26e0db7e87fa6c97e589cefe02a9c81");
                 	headersMap.put("Content-Type","application/json");
                 	bodyMap = Map();
                 	bodyMap.put("text","<div><h2>Product Complaint Update</h2><p>Thank you for registering your complaint with our support team.</p><p>Your request is currently under review by our technical department.</p><p><b>Reference Number:</b> CMP-90507310415</p></div>");
                 	langList = List();
                 	langList.add("Spanish");
                 	langList.add("French");
                 	langList.add("German");
                 	langList.add("Hindi");
                 	langList.add("Bengali");
                 	langList.add("Marathi");
                 	langList.add("Urdu");
                 	langList.add("Punjabi");
                 	bodyMap.put("target_languages",langList);
                 	response = invokeurl
                 	[
                 		url :"https://translate-api.com/v1/translate"
                 		type :POST
                 		parameters:bodyMap.toString()
                 		headers:headersMap
                 	];
                 	info response;
                 	translatedHtml = response.get("translations").get("Hindi");
                 	// remove all tags
                 	plainText = translatedHtml.replaceAll("<[^>]*>","");
                 	info plainText;
                 }
				 string AnnualPlans.deleteNullAnnualPlans(String ID)
                 {
                 	//delete subform rows those have null annual plan
                 	getAnnualPlan = Annual_Plan_Subform[Annual_Plans == null];
                 	// 	info getAnnualPlan;
                 	if(getAnnualPlan.count() > 0)
                 	{
                 		msgcount = getAnnualPlan.count();
                 		delete from Annual_Plan_Subform[Annual_Plans == null];
                 	}
                 	return "Records are deleted";
                 }
				 string AnnualPlans.getApprovalConfig(String sessionID, String DistID)
                 {
                 	getDistData = Distributor_Master[ID == DistID.toLong()];
                 	if(getDistData.count() > 0)
                 	{
                 		othermap = Map();
                 		//getApproval = zoho.crm.searchRecords("Approval_Flow_Config","(Name:equals:" + sessionID + ")",1,200,othermap,"zohocrm_connection");
                 		getApproval = zoho.crm.searchRecords("Approval_Flow_Config","(Name:equals:" + sessionID + ")",1,200,othermap,"zoho_oauth_connection");
                 		returnlist = List();
                 		returnMap = Map();
                 		if(getApproval.isEmpty() == false)
                 		{
                 			status = getApproval.getJson("Status");
                 			approveID = getApproval.getJson("id");
                 			returnMap.put("Status",status);
                 			returnMap.put("approveID",approveID);
                 			returnlist.add(returnMap);
                 		}
                 		else
                 		{
                 			returnMap.put("Status","Open");
                 			returnMap.put("approveID",null);
                 			returnlist.add(returnMap);
                 		}
                 	}
                 	return returnlist.toString();
                 }
				 string AnnualPlans.SendForApprovalAP(String DistID, String FY)
                 {
                 	getDistData = Distributor_Master[ID == DistID.toLong()];
                 	if(getDistData.count() > 0)
                 	{
                 		sessionID = "AP-FY-" + FY + "-" + getDistData.Distributor_SAP_ID;
                 		othermap = Map();
                 		//getApproval = zoho.crm.searchRecords("Approval_Flow_Config","(Name:equals:" + sessionID + ")",1,200,othermap,"zohocrm_connection");
                 		getApproval = zoho.crm.searchRecords("Approval_Flow_Config","(Name:equals:" + sessionID + ")",1,200,othermap,"zoho_oauth_connection");
                 		if(getApproval.isEmpty() == false)
                 		{
                 			status = getApproval.getJson("Status");
                 			approveID = getApproval.getJson("id");
                 			updateMap = Map();
                 			updateMap.put("Status","Pending");
                 			//update = zoho.crm.updateRecord("Approval_Flow_Config",approveID.toLong(),updateMap,othermap,"zohocrm_connection");
                 			update = zoho.crm.updateRecord("Approval_Flow_Config",approveID.toLong(),updateMap,othermap,"zoho_oauth_connection");
                 		}
                 		else
                 		{
                 			insertMap = Map();
                 			insertMap.put("Status","Pending");
                 			crmID = getDistData.Account_CRM_record_ID;
                 			if(crmID.isEmpty() == false)
                 			{
                 				insertMap.put("Submitted_By_Distributor",crmID.toLong());
                 			}
                 			EmployeeID = getDistData.Employee_ID;
                 			if(EmployeeID.isEmpty() == false)
                 			{
                 				insertMap.put("Current_Approver",EmployeeID.toLong());
                 				insertMap.put("Submitted_By",EmployeeID.toLong());
                 			}
                 			insertMap.put("Widget_Type","Annual Plan");
                 			insertMap.put("Entity_Name","Annual Plan");
                 			insertMap.put("Current_Level","1");
                 			insertMap.put("Financial_Year",FY);
                 			insertMap.put("Name",sessionID);
                 			insertMap.put("SAP_Code",getDistData.Distributor_SAP_ID);
                 			//inserData = zoho.crm.createRecord("Approval_Flow_Config",insertMap,othermap,"zohocrm_connection");
                 			inserData = zoho.crm.createRecord("Approval_Flow_Config",insertMap,othermap,"zoho_oauth_connection");
                 		}
                 	}
                 	result = "success";
                 	return result;
                 }
				 void AnnualPlans.SyncAnnualPlansInCRM(int planId)
                 {
                 	//create/update annual plan start here
                 	othermap = Map();
                 	/******************************** Get Annual Plan ********************************/
                 	getAPData = Annual_Plans[ID == planId];
                 	if(getAPData.count() == 0)
                 	{
                 		return;
                 	}
                 	/******************************** Build Parent Map ********************************/
                 	dataMap = Map();
                 	dataMap.put("Name",ifnull(getAPData.Annual_Plan_Name,""));
                 	dataMap.put("Financial_Year",ifnull(getAPData.Financial_Year,""));
                 	dataMap.put("Product_Category",ifnull(getAPData.Product_Category,""));
                 	dataMap.put("Star_Rating",ifnull(getAPData.Star_Type,""));
                 	dataMap.put("Total_Amt",ifnull(getAPData.Total_Amt,""));
                 	dataMap.put("Total_Qty",ifnull(getAPData.Total_Qty,""));
                 	dataMap.put("Creator_Rec_Id",planId.toString());
                 	/******************************** Distributor ********************************/
                 	if(getAPData.Distributor != null)
                 	{
                 		getDistributorData = Distributor_Master[ID == getAPData.Distributor];
                 		if(getDistributorData.count() > 0 && getDistributorData.Account_CRM_record_ID != "")
                 		{
                 			dataMap.put("Distributor",getDistributorData.Account_CRM_record_ID);
                 			if(getDistributorData.Employee_ID.isEmpty() == false)
                 			{
                 				dataMap.put("Owner",toLong(getDistributorData.Employee_ID));
                 				getAPData.SoID=getDistributorData.Employee_ID;
                 			}
                 			else
                 			{
                 				emptymap = Map();
                 				//Accountsdata = zoho.crm.getRecordById("Accounts",getDistributorData.Account_CRM_record_ID.toLong(),emptymap,"zohocrm_connection");
                 				Accountsdata = zoho.crm.getRecordById("Accounts",getDistributorData.Account_CRM_record_ID.toLong(),emptymap,"zoho_oauth_connection");
                 				accountsOwnerid = Accountsdata.get("Owner").get("id");
                 				dataMap.put("Owner",accountsOwnerid);
                 			}
                 		}
                 	}
                 	/******************************** Brand ********************************/
                 	if(getAPData.Brand_Name != null)
                 	{
                 		getBrandData = Brand_Master[ID == getAPData.Brand_Name];
                 		if(getBrandData.count() > 0 && getBrandData.zoho_crm_id != "")
                 		{
                 			dataMap.put("Brand_Name",getBrandData.zoho_crm_id);
                 		}
                 	}
                 	/******************************** Build Subform ********************************/
                 	productList = List();
                 	getProducts = Annual_Plan_Subform[Annual_Plans == planId];
                 	for each  getPro in getProducts
                 	{
                 		productmap = Map();
                 		// 🔹 CRM subform row update
                 		if(getPro.CRM_subform_id != null && getPro.CRM_subform_id != "")
                 		{
                 			productmap.put("id",getPro.CRM_subform_id);
                 		}
                 		// 🔹 Product lookup
                 		if(getPro.Product != null)
                 		{
                 			getProductData = Product_Master[ID == getPro.Product];
                 			if(getProductData.count() > 0 && getProductData.CRM_SO_ID != "")
                 			{
                 				productmap.put("Product",getProductData.CRM_SO_ID);
                 			}
                 		}
                 		productmap.put("SKU",ifnull(getPro.SKU,""));
                 		productmap.put("January",ifnull(getPro.January,""));
                 		productmap.put("February",ifnull(getPro.February,""));
                 		productmap.put("March",ifnull(getPro.March,""));
                 		productmap.put("April",ifnull(getPro.April,""));
                 		productmap.put("May",ifnull(getPro.May,""));
                 		productmap.put("June",ifnull(getPro.June,""));
                 		productmap.put("July",ifnull(getPro.July,""));
                 		productmap.put("August",ifnull(getPro.August,""));
                 		productmap.put("September",ifnull(getPro.September,""));
                 		productmap.put("October",ifnull(getPro.October,""));
                 		productmap.put("November",ifnull(getPro.November,""));
                 		productmap.put("December",ifnull(getPro.December,""));
                 		productList.add(productmap);
                 	}
                 	dataMap.put("Product_Details",productList);
                 	/******************************** Find CRM Record ********************************/
                 	crmId = null;
                 	//searchRec = zoho.crm.searchRecords("Annual_Plans","Creator_Rec_Id:equals:" + planId.toString(),0,1,othermap,"zohocrm_connection");
                 	searchRec = zoho.crm.searchRecords("Annual_Plans","Creator_Rec_Id:equals:" + planId.toString(),0,1,othermap,"zoho_oauth_connection");
                 	if(searchRec.isEmpty() == false)
                 	{
                 		crmId = searchRec.get(0).get("id");
                 	}
                 	/******************************** UPDATE (CRM v3 BULK API) ********************************/
                 	if(crmId != null)
                 	{
                 		dataMap.put("id",crmId);
                 		dataList = List();
                 		dataList.add(dataMap);
                 		param = Map();
                 		param.put("data",dataList);
                 		updateresp = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/crm/v3/Annual_Plans"
                 			type :PUT
                 			parameters:param.toString()
                 			connection:"zoho_oauth_connection"
                 		];
                 		// 			connection:"zoho_oauth_connection"
                 		info updateresp;
                 	}
                 	/******************************** CREATE ********************************/
                 	else
                 	{
                 		dataMap.put("sync_from_creator",true);
                 		dataMap.put("Status","Submitted by Distributor");
                 		dataList = List();
                 		dataList.add(dataMap);
                 		param = Map();
                 		param.put("data",dataList);
                 		insertresp = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/crm/v3/Annual_Plans"
                 			type :POST
                 			parameters:param.toString()
                 			connection:"zoho_oauth_connection"
                 		];
                 		info "CREATE RESPONSE ---> " + insertresp;
                 		if(insertresp.get("data").getJson("message") == "record added")
                 		{
                 			crmId = insertresp.get("data").getJson("details").get("id");
                 			getAPData.CRMID=crmId;
                 		}
                 	}
                 	/******************************** Store CRM Subform IDs back to Creator ********************************/
                 	if(crmId != null)
                 	{
                 		//crmData = zoho.crm.getRecordById("Annual_Plans",crmId.toLong(),othermap,"zohocrm_connection");
                 		crmData = zoho.crm.getRecordById("Annual_Plans",crmId.toLong(),othermap,"zoho_oauth_connection");
                 		crmSubform = crmData.get("Product_Details");
                 		for each  crmRow in crmSubform
                 		{
                 			crmProdId = crmRow.get("Product").get("id");
                 			crmSubId = crmRow.get("id");
                 			creatorSub = Annual_Plan_Subform[Annual_Plans == planId && Product.CRM_SO_ID == crmProdId];
                 			if(creatorSub.count() > 0)
                 			{
                 				creatorSub.CRM_subform_id=crmSubId;
                 			}
                 		}
                 	}
                 }
				 void Attendance.loginceckInTime()
                 {
                 	today = zoho.currentdate;
                 	fet = Attendance_Module[Check_In_Time == today && Email == zoho.loginuserid];
                 	rec = Liquidation_Agent[Email == zoho.loginuserid];
                 	if(fet.count() == 0)
                 	{
                 		new = insert into Attendance_Module
                 		[
                 			Added_User=zoho.loginuser
                 			Email=zoho.loginuserid
                 			Current_Date=zoho.currentdate
                 			Liquidation_Agent_Name=rec.ID
                 			Check_In_Time=zoho.currenttime
                 			Status="Checked In"
                 		];
                 	}
                 	openUrl("#Page:Attendance_Page","same window");
                 }
				 void Attendance.loginceckOutTime()
                 {
                 	today = zoho.currentdate;
                 	fet = Attendance_Module[Check_In_Time == today && Check_Out_Time == null && Email == zoho.loginuserid];
                 	if(fet.ID > 0)
                 	{
                 		fet.Check_Out_Time=zoho.currenttime;
                 		mil_sec = (fet.Check_Out_Time - fet.Check_In_Time);
                 		total_seconds = mil_sec / 1000;
                 		seconds = total_seconds.toLong() % 60;
                 		minutes = (total_seconds / 60).toLong() % 60;
                 		hours = (total_seconds / 3600).toLong();
                 		time_string = hours + "hh" + minutes + "mm" + seconds + "ss";
                 		fet.Total_Working_Hours=time_string;
                 		total_hours = mil_sec / (1000 * 60 * 60.0);
                 		if(total_hours >= 10)
                 		{
                 			fet.Working_Days=1;
                 		}
                 		else if(total_hours <= 5)
                 		{
                 			fet.Working_Days=0.5;
                 		}
                 		else
                 		{
                 			fet.Working_Days=0.0;
                 		}
                 		fet.Status="Checked Out";
                 	}
                 	else
                 	{
                 		fet1 = Attendance_Module[Check_In_Time == zoho.currentdate.subDay(1) && Check_Out_Time == null && Email == zoho.loginuserid];
                 		if(fet1.ID > 0)
                 		{
                 			fet1.Check_Out_Time=zoho.currenttime;
                 			mil_sec = (fet1.Check_Out_Time - fet1.Check_In_Time);
                 			actual_minutes = mil_sec / (1000 * 60);
                 			mins = actual_minutes.toLong() % 60;
                 			hours = (actual_minutes / 60).toLong();
                 			time_string = hours + " : " + mins;
                 			fet1.Total_Working_Hours=time_string;
                 			fet1.Status="Checked Out";
                 		}
                 	}
                 	openUrl("#Page:Attendance_Page","same window");
                 }
				 void AutoNumber.generateAutoNumber(string module, int moduleID)
                 {
                 	if(module == "Order Management")
                 	{
                 		getOrderData = Order_Management[ID == moduleID];
                 		if(getOrderData.count() > 0)
                 		{
                 			soCount = 1;
                 			getDistData = Distributor_Master[ID == getOrderData.Distributor_Name];
                 			if(getDistData.count() > 0)
                 			{
                 				if(getDistData.SO_Count.isNull() == false)
                 				{
                 					soCount = ifnull(getDistData.SO_Count,0) + 1;
                 				}
                 			}
                 			// 			if(getDistData.Distributor_SAP_ID.isEmpty() == false)
                 			// 			{
                 			// 				getOrderData.Order_Number="SO-" + ifnull(getDistData.Distributor_SAP_ID.subString(6,10),"1234") + "-" + soCount.toString();
                 			// 			}
                 			// 			else
                 			// 			{
                 			getOrderData.Order_Number="SO-" + ifnull(getDistData.ID.subString(14,18),"1234") + "-" + soCount.toString();
                 			//}
                 			getDistData.SO_Count=soCount;
                 			// 			info getDistData.Distributor_SAP_ID;
                 			// 			info getDistData;
                 		}
                 	}
                 	if(module == "Return Sales")
                 	{
                 		getRSData = Return_Sales_Order[ID == moduleID];
                 		if(getRSData.count() > 0)
                 		{
                 			rsCount = 1;
                 			getDisData = Distributor_Master[ID == getRSData.Distributor_Name];
                 			if(getDisData.count() > 0)
                 			{
                 				if(getDisData.RS_Count.isNull() == false)
                 				{
                 					rsCount = ifnull(getDisData.RS_Count,0) + 1;
                 				}
                 			}
                 			// 			if(getDisData.Distributor_SAP_ID.isEmpty() == false)
                 			// 			{
                 			// 				getRSData.Return_No="RS-" + ifnull(getDisData.Distributor_SAP_ID.subString(6,10),"1234") + "-" + rsCount.toString();
                 			// 			}
                 			// 			else
                 			// 			{
