			Redirect_to_Report9 as "Redirect to Report"
			{
				type =  form
				form = Sign_Test

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											openUrl("#Script:page.close","same window");
										redirectURL = "https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/page-perma/Thank_You/nVggaPQVvw9UmrZNhgs8GjqmxyGhFv1Wa61MPU61jCGMv5jxJYSjvY2ryKnn626zmYBNe54a9XXwdb1R2jaXkjhKahjj7jqmAF3Y?SignID=" + input.Distributor_Name.ID + "&signed_id=" + input.ID;
										openUrl(redirectURL,"parent window");
										openUrl(redirectURL,"parent window");
										soemail = "zohotest768@gmail.com";
										//  Step 1: Signed Record ID
										signedId = input.ID.toString();
										getDistributorSOId = input.Distributor_Name.Employee_ID;
										if(getDistributorSOId != "" && getDistributorSOId != null)
										{
											opt = Map();
											getUser = zoho.crm.getRecordById("users",getDistributorSOId.toLong(),opt,"zoho_oauth_connection");
											info getUser;
											if(getUser.isEmpty() == false)
											{
												getUserData = getUser.get("users").get(0);
												info getUserData;
												if(getUserData.isEmpty() == false && getUserData.getJSON("email").isEmpty() == false)
												{
													soemail = getUserData.getJSON("email");
												}
											}
										}
										//  Step 2: Generate PDF URL
										pdfURL = "https://creatorapp.zohopublic.in/zohoadmin_gharda782/distributor-management-gharda-chemical/page-perma/Signed_Document/E9ZYO9pmETmwPRHTFeREu6kajqDUwM48npJbr1WgTEs2FEFT5rdK5XEK2davmNM7uE0DPMynpzt6QtVG4jJOdhTtOw1gg7ghCOJx?idd=" + input.Distributor_Name.ID + "&signed_id=" + signedId + "&zc_Print=true";
										//  Step 3: Fetch PDF
										pdfFile = invokeurl
										[
											url :pdfURL
											type :GET
										];
										pdfFile1 = zoho.file.convertToPDF(pdfFile);
										//  Send Email
										sendmail
										[
											from :zoho.adminuserid
											to :input.Distributor_Name.Email
											cc:soemail
											subject :"Signed Balance Confirmation Document"
											message :"Dear " + input.Distributor_Name.Distributor_Name + ",<br><br>Your signed balance confirmation document is attached.<br><br>Regards,<br>Gharda Chemicals Limited"
											Attachments :file:pdfFile1
										]
										pdfFile1.setParamName("file");
										upload_url = "https://creatorapp.zoho.in/api/v2/zohoadmin_gharda782/distributor-management-gharda-chemical/report/All_Sign_Tests/" + input.ID + "/Signed_PDF/upload";
										response = invokeurl
										[
											url :upload_url
											type :POST
											files:pdfFile1
											connection:"zoho_oauth_connection"
										];
										info response;
						)
					}
				}

			}
