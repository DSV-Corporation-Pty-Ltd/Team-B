                 		searchSO = zoho.crm.searchRecords("Proforma_Invoice","Creator_rec_id:equals:" + PIID.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 		if(searchSO.isEmpty() == true)
                 		{
                 			if(getProducts.count() > 0)
                 			{
                 				productList = List();
                 				for each  getPro in getProducts
                 				{
                 					productmap = Map();
                 					searchPro = zoho.crm.searchRecords("Products","Product_Code:equals:" + getPro.Product_Name.Product_Code + "",0,200,othermap,"zoho_oauth_connection");
                 					if(searchPro.isEmpty() == false)
