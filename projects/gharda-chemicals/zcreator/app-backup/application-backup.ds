		list View_Orders
		{
			displayName = "View Orders"
			show all rows from Order_Management  [Distributor_Name.Email == zoho.loginuserid]  
			(
				Order_Number as "Order Number"
				Distributor_Name as "Distributor Name"
				Contact_Number as "Contact Number"
				(
					displayformat = plainnumber 
				)
				Email
				Order_Date as "Order Date"
				Contact_Name as "Contact Name"
				Status
				Subtotal
				CGST
				IGST
				Tax_Amount as "Tax Amount"
				Grand_Total as "Grand Total"
				custom action "View Order"
				(
	  			workflow = View_Order_Detail
				show action in view header = true
				show action in edit record menu = true
				column header = "View Order"
				)
				Added_Time as "Created Time"
				custom action "Download PDF"
				(
	  			workflow = Download_Order_PDF
				show action in view header = true
				show action in edit record menu = true
				column header = "Download PDF"
				)
				Due_Date as "Due Date"
				Order_Description as "Order Description"
				Distributor_Name.Profile_Pic as "Profile Pic"
				Distributor_Name.Email
				Order_Type as "Order Type"
				SGST
				custom action "Update Order"
				(
	  			workflow = update_order
				show action in edit record menu = true
				column header = "Update Order"
				condition = (Status == "Rejected")
				)
				SAP_Number as "SAP Number"
			)
			conditional formatting
			(
				"Approved"
				{
				condition = (Status == "Approved")
				fields = [Status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"Pending"
				{
				condition = (Status == "Pending")
				fields = [Status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"Order Process"
				{
				condition = (Status == "Order Process")
				fields = [Status]
				format = "color:#ffffff;background-color:#107c91;"
				}
				"Rejected"
				{
				condition = (Status == "Rejected")
				fields = [Status]
				format = "color:#333;background-color:#f1c40f;"
				}
				"Delivered"
				{
				condition = (Status == "Delivered")
				fields = [Status]
				format = "color:#ffffff;background-color:#3598db;"
				}
				"dispatched"
				{
				condition = (Status == "Fully Dispatched" || Status == "Partial Dispatched")
				fields = [Status]
				format = "color:#ffffff;background-color:#bd588b;"
				}
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Order_Number'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '17px'\n\n		width = '100%'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Distributor_Name'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '28'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Order_Date'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '3'\n\n\n\n\n\n	  value = 'Order_Description'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr><pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		paddingTop = '0px'\n	paddingLeft = '17px'\n	paddingRight = '17px'\n	paddingBottom = '17px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	padding = '0px'\n	color = '#000000'\n	size = '20px'\n	type = 'field'\n\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n	cornerRadius = '0px'\n\n    lineHeight = '27'\n    numOfLines = '1'\n\n\n\n\n    borderColor = '#000000'\n    borderWidth = '0px'\n\n	  value = 'Grand_Total'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
				template
	 			(
	 	  			displayname="Custom Layout 2"
