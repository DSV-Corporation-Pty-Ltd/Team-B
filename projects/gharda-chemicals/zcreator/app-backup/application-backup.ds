				 string Pricing_Logic.getZNDPPrice(String productCodeParam, String customerCodeParam, String customerGroupParam, String plantParam, String conditionType)
                 {
                 	productCode = ifnull(productCodeParam,"").trim();
                 	customerCode = ifnull(customerCodeParam,"").trim();
                 	customerGroup = ifnull(customerGroupParam,"").trim();
                 	plantValue = plantParam;
                 	customerCountry = "IN";
                 	// 		productCode = "FGALF999999999";
                 	// 		customerCode = "4100065";
                 	// 		customerGroup = "02";
                 	// 		plantValue = "1201";
                 	// 		customerCountry = "IN";
                 	// 		conditionType = "ZK0";
                 	finalPrice = 0;
                 	priceFound = false;
                 	// Current date only
                 	todayDate = zoho.currentdate;
                 	if(productCode != "")
                 	{
                 		allPriceRecords = Price_Master[Product_Code == productCode && Condition_Type == conditionType];
                 		// Get unique sequence numbers dynamically
                 		sequenceList = List();
                 		for each  rec in allPriceRecords
                 		{
                 			if(rec.Sequence_Number != null && !sequenceList.contains(rec.Sequence_Number))
                 			{
                 				sequenceList.add(rec.Sequence_Number);
                 			}
                 		}
                 		sequenceList.sort(true);
                 		// Check sequence by sequence
                 		for each  seq in sequenceList
                 		{
                 			seqRecords = Price_Master[Sequence_Number == seq && Product_Code == productCode && Condition_Type == conditionType];
                 			for each  rec in seqRecords
                 			{
                 				isMatch = false;
                 				isDateValid = false;
                 				combinationType = ifnull(rec.Combination_Type,"").trim();
                 				// Skip row if combination type is blank
                 				if(combinationType == "")
                 				{
                 					continue;
                 				}
                 				// ---------------------------
                 				// Step 1: Check combination
                 				// ---------------------------
                 				// PLANT + Product Code
                 				if(combinationType == "Plant")
                 				{
                 					if(rec.Plant_Code != null && plantValue != null && rec.Plant_Code == plantValue)
                 					{
                 						isMatch = true;
                 					}
                 				}
                 				// CUSTOMER_GROUP + Product Code
                 				else if(combinationType == "CUSTOMER_GROUP")
                 				{
                 					if(ifnull(rec.Customer_Group,"").trim() != "" && rec.Customer_Group == customerGroup)
                 					{
                 						isMatch = true;
                 					}
                 				}
                 				// CUSTOMER_NUMBER_COUNTRY + Product Code
                 				else if(combinationType == "CUSTOMER_NUMBER_COUNTRY")
                 				{
                 					if(ifnull(rec.Customer_Number,"").trim() != "" && ifnull(rec.Customer_Country,"").trim() != "" && rec.Customer_Number == customerCode && rec.Customer_Country == customerCountry)
                 					{
                 						isMatch = true;
                 					}
                 				}
                 				// ---------------------------
                 				// Step 2: Check valid from / valid to
                 				// ---------------------------
                 				if(isMatch)
                 				{
                 					if(rec.Valid_From1 != null && rec.Valid_To1 != null)
                 					{
                 						validFromDate = rec.Valid_From1.toDate();
                 						validToDate = rec.Valid_To1.toDate();
                 						// 						if(todayDate >= validFromDate && todayDate <= validToDate)
                 						// 						{
                 						if(todayDate <= validToDate)
                 						{
                 							isDateValid = true;
                 						}
                 					}
                 				}
                 				// ---------------------------
                 				// Step 3: Finalize price
                 				// ---------------------------
                 				if(isMatch && isDateValid)
                 				{
                 					finalPrice = ifnull(rec.Amount,0);
                 					priceFound = true;
                 					break;
                 				}
                 			}
                 			if(priceFound)
                 			{
                 				break;
                 			}
                 		}
                 	}
                 	return finalPrice;
                 }
				 void ProformaInvoice.SyncProformaInvoiceInCrm(int PIID)
                 {
                 	getPIData = Proforma_Invoice[ID == PIID.toLong()];
                 	othermap = Map();
                 	if(getPIData.count() > 0)
                 	{
                 		dataMap = Map();
                 		dataMap.put("PO_No",ifnull(getPIData.PO_No.PO_NO,""));
                 		dataMap.put("Creator_rec_id",ifnull(PIID.toString(),""));
                 		dataMap.put("PI_Date",ifnull(getPIData.PI_Date.toString("yyyy-MM-dd"),""));
                 		dataMap.put("PO_Date",ifnull(getPIData.PO_Date.toString("yyyy-MM-dd"),""));
                 		dataMap.put("Validity_Days",ifnull(getPIData.Validity_Days,""));
                 		dataMap.put("Terms_and_Conditions",ifnull(getPIData.Terms_and_Conditions,""));
                 		dataMap.put("Bank_Name",ifnull(getPIData.Bank_Name,""));
                 		dataMap.put("Account_No",ifnull(getPIData.Account_No,""));
                 		dataMap.put("Country_of_Origin",ifnull(getPIData.Country_of_Origin,""));
                 		dataMap.put("Credit_Days",ifnull(getPIData.Credit_Days,""));
                 		dataMap.put("Currency_Exchange_Rate",ifnull(getPIData.Exchange_Rate_Base_Currency,""));
                 		dataMap.put("Currency_Name",ifnull(getPIData.Currency_Type,0.0));
                 		dataMap.put("Expected_Shipment_Date",ifnull(getPIData.Expected_Shipment_Date.toString("yyyy-MM-dd"),""));
                 		dataMap.put("Final_Destination",ifnull(getPIData.Final_Destination,""));
                 		dataMap.put("IFSC_SWIFT_Code",ifnull(getPIData.IFSC_SWIFT_Code,""));
                 		dataMap.put("Payment_Method",ifnull(getPIData.Payment_Method,""));
                 		dataMap.put("Payment_Terms",ifnull(getPIData.Payment_Terms,""));
                 		dataMap.put("PI_Number",ifnull(getPIData.PI_Number,""));
