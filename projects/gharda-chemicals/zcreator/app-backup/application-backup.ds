		schedule
		{
			SyncUserData as "SyncUserData"
			{
				type =  schedule
				start = "2025-10-27 12:30:30"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						othermap = Map();
										getUsersResponse = zoho.crm.getRecords("users",0,200,othermap,"zoho_oauth_connection");
										if(getUsersResponse.isEmpty() == false)
										{
											userList = getUsersResponse.toJsonList().get(0);
											for each  user in userList.get("users")
											{
												getuser = Users[Email == user.get("email")];
												firstName = ifnull(user.get("first_name"),"");
												territory_name = "";
												territory_list = List();
												if(firstName != "zohoadmin")
												{
													if(user.get("territories").isEmpty() == false)
													{
														territories = user.get("territories");
														for each  terr in territories
														{
															if(terr.get("manager") == false)
															{
																getter = Territory[Territory_Name == terr.get("name")];
																if(getter.count() > 0)
																{
																	territory_list.add(getter.ID);
																}
															}
														}
													}
												}
												dataMap = Map();
												dataMap.put("First_Name",ifnull(user.get("first_name"),""));
												dataMap.put("Last_Name",ifnull(user.get("last_name"),""));
												dataMap.put("Email",ifnull(user.get("email"),""));
												dataMap.put("Mobile",ifnull(user.get("mobile"),""));
												dataMap.put("Street",ifnull(user.get("street"),""));
												dataMap.put("City",ifnull(user.get("city"),""));
												dataMap.put("Zipcode",ifnull(user.get("zip"),""));
												dataMap.put("State",ifnull(user.get("state"),""));
												dataMap.put("Country",ifnull(user.get("country"),""));
												dataMap.put("UserID",ifnull(user.get("id").toString(),""));
												dataMap.put("Status",ifnull(user.get("status"),""));
												dataMap.put("Profile",ifnull(user.get("profile").get("name"),""));
												dataMap.put("Role",ifnull(user.get("role").get("name"),""));
												dataMap.put("Territory_Name",territory_list);
												if(getuser.count() <= 0)
												{
													createUser = zoho.creator.createRecord("zohoadmin_gharda782","distributor-management-gharda-chemical","Users",dataMap,othermap,"zoho_oauth_connection");
												}
												else
												{
													getuser.First_Name=ifnull(user.get("first_name"),"");
													getuser.Last_Name=ifnull(user.get("last_name"),"");
													getuser.Email=ifnull(user.get("email"),"");
													getuser.Mobile=ifnull(user.get("mobile"),"");
													getuser.Street=ifnull(user.get("street"),"");
													getuser.City=ifnull(user.get("city"),"");
													getuser.Zipcode=ifnull(user.get("zip"),"");
													getuser.State=ifnull(user.get("state"),"");
													getuser.Country=ifnull(user.get("country"),"");
													getuser.UserID=ifnull(user.get("id").toString(),"");
													getuser.Status=ifnull(user.get("status"),"");
													getuser.Profile=ifnull(user.get("profile").get("name"),"");
													getuser.Role=ifnull(user.get("role").get("name"),"");
													getuser.Territory_Name=territory_list;
												}
											}
										}
										else
										{
											info "No users found.";
										}
					)
					}
				}
			}
			MarkAttendancecheckout as "MarkAttendancecheckout"
			{
				type =  schedule
				start = "2025-10-27 22:58:52"
				frequency = daily
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						fetchStatus = Attendance_Module[Status != null && Status != "Checked Out" && Status != "Completed" && Current_Date == zoho.currentdate];
										if(fetchStatus.count() > 0)
										{
											for each  agentstatus in fetchStatus
											{
												startDate = zoho.currentdate.toDateTime();
												endDate = startDate.addDay(1);
												getmeeting = Meeting[Liquidation_Agent_Name == agentstatus.Liquidation_Agent_Name && Added_Time >= startDate && Added_Time < endDate] sort by Added_Time desc;
												if(getmeeting.count() > 0)
												{
													agentstatus.End_Journey_Longitude=getmeeting.Meeting_Longitude;
													agentstatus.End_Journey_Latitude=getmeeting.Meeting_Latitude;
												}
												agentstatus.Status="Completed";
												agentstatus.Check_Out_Time=zoho.currenttime;
											}
										}
					)
					}
				}
			}
			Send_Quarterly_Report_to_ as "Send Quarterly Report to Distributors"
			{
				type =  schedule
					status = inactive
				start = "2026-04-04 09:00:00"
				frequency = monthly
				time zone = "Asia/Kolkata"
				on start
				{
