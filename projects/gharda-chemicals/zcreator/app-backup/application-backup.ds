			fetch_line_items as "fetch line items"
			{
				type =  form
				form = Liquidation_Capture

				record event = on add

				on user input of Distributor_Name
				{
					actions 
					{
						custom deluge script
						(
											input.Product_Line_Items.clear();
										fromDate = zoho.currentdate.addMonth(-2);
										salesOrders = Order_Management[Distributor_Name == input.Distributor_Name && Order_Date >= fromDate].ID.getAll();
										if(salesOrders.isEmpty())
										{
											alert "No Sales Order Available";
											return;
										}
										openLineItems = Order_Line_Items[Order_Management in salesOrders && Liquidate_Done == false];
										doneLineItems = Order_Line_Items[Order_Management in salesOrders && Liquidate_Done == true];
										if(openLineItems.count() <= 0)
										{
											alert "No Product Available please add the Product";
											return;
										}
										openQtyMap = Map();
										nameMap = Map();
										for each  li in openLineItems
										{
											code = ifnull(li.Product_Code,"");
											openQtyMap.put(code,ifnull(openQtyMap.get(code),0) + ifnull(li.Quantity,0));
											if(nameMap.get(code) == null)
											{
												nameMap.put(code,li.Product_Name);
											}
										}
										doneQtyMap = Map();
										for each  di in doneLineItems
										{
											code = ifnull(di.Product_Code,"");
											doneQtyMap.put(code,ifnull(doneQtyMap.get(code),0) + ifnull(di.Quantity,0));
										}
										liqMap = Map();
										prev_caps = Liquidation_Capture[Liquidation_Agent_Email == zoho.loginuserid && Distributor_Name == input.Distributor_Name && ID != input.ID];
										for each  cap in prev_caps
										{
											for each  prow in cap.Product_Line_Items
											{
												code = ifnull(prow.Product_Code,"");
												liqMap.put(code,ifnull(liqMap.get(code),0) + ifnull(prow.Liquidate_Quantity,0));
											}
										}
										rowCollection = Collection();
										for each  code in openQtyMap.keys()
										{
											open_qty = ifnull(openQtyMap.get(code),0);
											done_qty = ifnull(doneQtyMap.get(code),0);
											total_liq = ifnull(liqMap.get(code),0);
											effective_liq_for_open = total_liq - done_qty;
											if(effective_liq_for_open < 0)
											{
												effective_liq_for_open = 0;
											}
											balance = open_qty - effective_liq_for_open;
											if(balance < 0)
											{
												balance = 0;
											}
											if(balance > 0)
											{
												sfrow = Liquidation_Capture.Product_Line_Items();
												sfrow.Product_Name=nameMap.get(code);
												sfrow.Product_Code=code;
												sfrow.Quantity=open_qty;
												sfrow.Already_Liquidate_Quantity=effective_liq_for_open;
												sfrow.Balance_Quantity=balance;
												sfrow.Liquidate_Quantity=null;
												sfrow.Prev_Liquidate_Quantity=0;
												rowCollection.insert(sfrow);
											}
										}
										if(rowCollection.size() > 0)
										{
											input.Product_Line_Items.insert(rowCollection);
										}
										else
										{
											alert "No Product Available please add the Product";
										}
										if(Distributor_Name == null)
										{
											return;
										}
						)
					}
				}

			}
