			populate_products as "populate products"
			{
				type =  form
				form = Invoice

				record event = on add or edit
					status = inactive

				on add row of Line_Items
				{
					actions 
					{
						custom deluge script
						(
											disable row.Price;
										disable row.Discount;
										disable row.Total;
										row.Discount=0.0;
										getProduct = Product_Master[ID != 0];
										if(getProduct.count() > 0)
										{
											proList = List();
											for each  productList in getProduct
											{
												proList.add(productList.Product_Code);
											}
										}
										finalproductList = proList.distinct();
										if(finalproductList.size() > 0)
										{
											listfinalproduct = List();
											for each  prolistfinal in finalproductList
											{
												getcode = Product_Master[Product_Code == prolistfinal];
												listfinalproduct.add(getcode.ID);
											}
											for each  pro in input.Line_Items
											{
												pro.Product_Name:ui.add(listfinalproduct);
												pro.Product_Name=pro.Product_Name;
											}
										}
						)
					}
				}

			}
			fetch_products2 as "fetch products"
			{
				type =  form
				form = Invoice

				record event = on add or edit
					status = inactive

				on load
				{
					actions 
					{
						custom deluge script
						(
											getProduct = Product_Master[ID != 0];
										if(getProduct.count() > 0)
										{
											proList = List();
											for each  productList in getProduct
											{
												proList.add(productList.Product_Code);
											}
										}
										finalproductList = proList.distinct();
										if(finalproductList.size() > 0)
										{
											listfinalproduct = List();
											for each  prolistfinal in finalproductList
											{
												getcode = Product_Master[Product_Code == prolistfinal];
												listfinalproduct.add(getcode.ID);
											}
											for each  pro in input.Line_Items
											{
												pro.Product_Name:ui.add(listfinalproduct);
												pro.Product_Name=pro.Product_Name;
											}
										}
										if(input.Line_Items != null)
										{
											skulist = List();
											for each  procode in input.Line_Items
											{
												getSKU = Product_Master[Product_Code == procode.Product_Name.Product_Code];
												for each  rec in getSKU
												{
													if(!skulist.contains(rec.ID))
													{
														skulist.add(getSKU.ID);
													}
												}
												procode.SKU:ui.add(skulist);
												procode.SKU=procode.SKU;
											}
										}
						)
					}
				}

			}
			fetch_SKU_List as "fetch SKU List"
			{
				type =  form
				form = Invoice

				record event = on add or edit
					status = inactive

				on user input of Line_Items.Product_Name
				{
					actions 
					{
						custom deluge script
						(
											today = zoho.currentdate;
										getsku = Product_Master[Product_Code == row.Product_Name.Product_Code];
										skulist = List();
										if(getsku.count() > 0)
										{
											for each  skuget in getsku
											{
												skulist.add(skuget.ID);
											}
											row.SKU:ui.add(skulist);
										}
										distributor = Distributor_Master[Email == zoho.loginuserid];
										region = null;
										if(distributor.count() > 0)
										{
											region = ifnull(distributor.Region,null);
										}
										if(row.Product_Name == null)
										{
											row.Price=null;
											row.SKU=null;
											row.Discount=null;
											row.Discount_Value=null;
											row.Total=null;
											row.Quantity=null;
											row.Batch_Number=null;
											row.Product_Code=null;
										}
										getProCod = Product_Master[ID == row.Product_Name];
										if(getProCod.count() > 0)
										{
											row.Product_Code=getProCod.Product_Code;
										}
						)
					}
				}

			}
			On_quantity as "On quantity"
			{
				type =  form
				form = Invoice

				record event = on add or edit
					status = inactive

				on user input of Line_Items.Quantity
				{
					actions 
					{
						custom deluge script
						(
											distributor = Distributor_Master[Email == zoho.loginuserid];
										region = null;
										if(distributor.count() > 0)
										{
											region = ifnull(distributor.Region,null);
										}
										if(row.Product_Name != null && row.Quantity != null)
										{
											getproscheme = Product_Schemes[Product_Name == row.Product_Name && SKU.SKU1 == row.SKU.SKU1 && Min_Order_Qty <= row.Quantity];
											row.Discount=0;
											if(getproscheme.count() > 0)
											{
												activeSchemes = Scheme_Master[Scheme_Type == "Product Type Scheme" && Applicable_Region == region && Start_Date <= zoho.currentdate && End_Date >= zoho.currentdate && Status == "Active" && ID == getproscheme.Schemes] sort by Added_Time desc;
												if(activeSchemes.count() > 0)
												{
													row.Discount=getproscheme.Discount;
												}
											}
										}
										todaydate = zoho.currentdate;
										row.Discount_Value=0;
										if(row.Quantity > 0)
										{
											discountprice = 0;
											totalprice = 0;
											totalprice = row.Quantity * ifnull(row.Price,0);
											if(row.Discount > 0)
											{
												discountprice = ifnull(totalprice,0) * row.Discount / 100;
												row.Total=totalprice - ifnull(discountprice,0);
												row.Discount_Value=ifnull(discountprice,0);
											}
											else
											{
												row.Total=totalprice;
											}
										}
										else
										{
											alert "Quantity will not be zero or negative";
											row.Quantity=null;
										}
										total = 0;
										if(row.Quantity > 0)
										{
											for each  products in input.Line_Items
											{
												totalp = ifnull(products.Total,0);
												total = totalp + total;
											}
										}
										else
										{
											row.Total=0;
										}
										input.Subtotal = total;
										subtotal = ifnull(input.Subtotal,0);
										gst_percent = ifnull(input.GST,0);
										gst_amt = subtotal * gst_percent / 100;
										sgst_percent = ifnull(input.GST,0);
										sgst = subtotal * sgst_percent / 100;
										igstamount = ifnull(input.IGST,0);
										igst = subtotal * igstamount / 100;
										input.Tax_Amount = gst_amt + igst + sgst;
										input.Grand_Total = subtotal + gst_amt + igst + sgst;
						)
					}
				}

			}
			on_sku as "on sku"
			{
				type =  form
				form = Invoice

				record event = on add or edit
					status = inactive

				on user input of Line_Items.SKU
				{
					actions 
					{
						custom deluge script
						(
											productCat = "";
										if(row.SKU != null)
										{
											selectedProduct = Product_Master[ID == row.SKU];
											if(selectedProduct.count() > 0)
											{
												row.Batch_Number=selectedProduct.Batch_Number;
												productCat = selectedProduct.Product_Category;
											}
											else
											{
												row.Batch_Number=null;
											}
										}
										else
										{
											row.Batch_Number=null;
										}
										if(row.Product_Name != null)
										{
											pricingRecord = Price_Master[SKU == row.SKU];
											if(pricingRecord.count() > 0)
											{
												row.Price=ifnull(pricingRecord.Final_Price,0);
											}
											else
											{
												getProd = Product_Master[ID == row.SKU];
												if(getProd.count() > 0)
												{
													row.Price=ifnull(getProd.Unit_Price,0);
												}
											}
										}
										duplicateFound = false;
										currentProduct = row.Product_Name;
										currentSKU = row.SKU;
										for each  lineItem in input.Line_Items
										{
											if(lineItem != row)
											{
												if(lineItem.Product_Name == currentProduct && lineItem.SKU == currentSKU)
												{
													duplicateFound = true;
													break;
												}
											}
										}
										if(duplicateFound)
										{
											alert "This product with same SKU is already added. Please increase the quantity in the existing row.";
											row.Product_Name=null;
											row.SKU=null;
											row.Batch_Number=null;
											row.Batch_Number=null;
											row.Discount=null;
											row.Discount_Value=null;
											row.Total=null;
											row.Price=null;
										}
						)
					}
				}

			}
			deletion_of_row as "deletion of row"
			{
				type =  form
				form = Invoice

				record event = on add or edit

				on delete row of Line_Items
				{
					actions 
					{
						custom deluge script
						(
											// Step 1: Subtract deleted row's total from subtotal
										row_total = ifnull(row.Total,0);
										new_subtotal = ifnull(input.Subtotal,0) - row_total;
										input.Subtotal = new_subtotal;
										// Step 2: Calculate tax based on new subtotal
										gst_rate = ifnull(input.GST,0);
										igst_rate = ifnull(input.IGST,0);
										sgst_rate = ifnull(input.SGST,0);
										gst_amt = new_subtotal * gst_rate / 100;
										igst_amt = new_subtotal * igst_rate / 100;
										sgst_amt = new_subtotal * sgst_rate / 100;
										tax_amt = gst_amt + igst_amt + sgst_amt;
										input.Tax_Amount = tax_amt;
										input.Grand_Total = new_subtotal + tax_amt;
						)
					}
				}

			}
