		list Distributor_Meetings
		{
			displayName = "Meetings"
			show all rows from Meeting  [Email == zoho.loginuserid]  
			(
				Liquidation_Agent_Name as "Liquidation Agent Name"
				Liquidation_Agent_Email as "Liquidation Agent Email"
				Title
				Location
				From
				To
				Description
				Host_By as "Host By"
				Distributor
				Sales_Officer as "Sales Officer"
				Meeting_Notes as "Meeting Notes"
				Meeting_Distance_KM as "Meeting Distance KM"
				(
					display = total	
				)
				Total_Distance_KM as "Total Distance KM"
				(
					display = total	
				)
				Meeting_Status as "Meeting Status"
				Email
			)
			custom actions
			(
				"Cancelled Meeting"
				(
	  			workflow = liquidation_agent_meeting
				show action in view header = true
				show action in edit record menu = true
				condition = (Meeting_Status.contains("Open"))
				confirmation before execution
				(
					message for individual record = "Are you sure you want to cancel this meeting?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Add Distributor"
				(
	  			workflow = Meeting_create_from_crm_n
				show action in view header = true
				show action in edit record menu = true
				condition = (Meeting_Create_from_CRM == true && Distributor.Distributor_Name is null)
				)
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
	 	  			content="<panel  \n >\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '0px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '100%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='fill'\n		height='fill'\n>\n	<pc \n		padding = '20px'\n	bgColor = '#4E96F4'\n\n		width = '40%'\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '5px'\n\n		hAlign = 'center'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<image  \n	\n	color = '#FFFFFF'\n	type = 'icon'\n	value = 'ui-1-calendar-grid-58'\n	size = '22px'\n	iconType = 'solid'\n/>\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#FFFFFF'\n	size = '16px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '22'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Liquidation_Agent_Name'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n		padding = '20px'\n	bgColor = 'transparent'\n        bgColorType = 'noFill'\n\n		width = '60%'\n		hAlign = 'left'\n>\n	<pr \n			width='auto'\n		height='auto'\n>\n	<pc \n		padding = '0px'\n\n		hAlign = 'left'\n		vAlign = 'middle'\n>\n	<pr \n	>\n	<pc \n	\n>\n	<text \n\n	color = '#4E96F4'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'Title'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	marginLeft = '0px'\n	marginRight = '0px' \n	marginBottom = '8px'\n	marginTop = '15px'\n	color = '#132437'\n	size = '20px'\n	bold = 'true' \n	type = 'field'\n\n\n    lineHeight = '28'\n    numOfLines = '1'\n\n\n\n\n\n	  value = 'From'\n>\n</text>\n\n</pc>\n</pr><pr \n	>\n	<pc \n	\n>\n	<text \n\n	margin = '0px'\n	color = '#2D3C4D'\n	size = '15px'\n	type = 'field'\n\n\n    lineHeight = '21'\n    numOfLines = '3'\n\n\n\n\n\n	  value = 'Description'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>"
	    		)
			)
