			generate_Quote_No_ as "generate Quote No."
			{
				type =  form
				form = Quotation

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											thisapp.AutoNumber.generateAutoNumber("Quotation",input.ID);
										getRFQData = RFQ[ID == input.RFQ];
										if(getRFQData.count() > 0)
										{
											getRFQData.Quote_Created=true;
											getRFQData.Status="Quotation Received";
											logisticList = List();
											if(getRFQData.Logistic_List != null)
											{
												logisticList.addAll(getRFQData.Logistic_List);
											}
											logisticList.add(input.Transporter_Name);
											getRFQData.Logistic_List=logisticList;
										}
										thisapp.Notifications.SendQuotionCreateEmailtoCNF(input.ID);
										thisapp.SMS.QuotaionCreatedSMS(input.ID);
						)
					}
				}

			}
			populate_logistic_data as "populate logistic data"
			{
				type =  form
				form = Quotation

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											getLogisticData1 = Logistic_Master[Email == zoho.loginuserid];
										if(getLogisticData1.count() > 0)
										{
											input.Transporter_Name = getLogisticData1.ID;
										}
										checkCond = false;
										getRFQreport = RFQ[ID == input.RFQ];
										if(getRFQreport.count() > 0)
										{
											if(getRFQreport.Logistic_List.contains(input.Transporter_Name) == true)
											{
												checkCond = true;
											}
										}
										getRFQQuote = Quotation[RFQ == input.RFQ];
										if(getRFQQuote.count() > 0 && checkCond == true)
										{
											// 	openUrl("#Form:Quotation_Alert1?zc_BgClr=#34ebd2&zc_Header=false","popup window","height=154px,width=410px");
											input.CNF_Name = null;
											input.Transporter_Name = null;
										}
										else
										{
											getLogisticData = Logistic_Master[Email == zoho.loginuserid];
											if(getLogisticData.count() > 0)
											{
												input.Transporter_Name = getLogisticData.ID;
												getRFQData = RFQ[ID == input.RFQ];
												if(getRFQData.count() > 0)
												{
													input.Billing_State = getRFQData.Billing_State;
													input.Billing_City = getRFQData.Billing_City;
													input.Billing_Country = getRFQData.Billing_Country;
													input.Billing_Street = getRFQData.Billing_Street;
													input.Billing_Code = getRFQData.Billing_Code;
													input.Shipping_State = getRFQData.Shipping_State;
													input.Shipping_Street = getRFQData.Shipping_Street;
													input.Shipping_Country = getRFQData.Shipping_Country;
													input.Shipping_City = getRFQData.Shipping_City;
													input.Shipping_Code = getRFQData.Shipping_Code;
