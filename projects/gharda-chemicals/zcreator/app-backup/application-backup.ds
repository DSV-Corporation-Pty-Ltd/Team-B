			{
				type =  form
				form = Customer_Dispatch

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											getCustomer = Customer[Email == zoho.loginuserid];
										if(getCustomer.count() > 0)
										{
											input.Customer_Name = getCustomer.ID;
											input.Billing_State = getCustomer.Billing_State;
											input.Billing_Street = getCustomer.Billing_Street;
