				 void ReturnSalesOrder.syncReturnSalesOrderInCrm(int id)
                 {
                 	dataMap = Map();
                 	getRSOData = Return_Sales_Order[ID == id];
                 	if(getRSOData.count() > 0)
                 	{
                 		/*******************************************************Get Distributor**************************************************/
                 		getDistributor = getRSOData.Distributor_Name;
                 		if(getDistributor.isNull() == false)
                 		{
                 			info "enterdistributor";
                 			getDistributorData = Distributor_Master[ID == getDistributor];
                 			if(getDistributorData.count() > 0)
                 			{
                 				getCRmId = getDistributorData.Account_CRM_record_ID;
                 				if(getCRmId.isNull() == false)
                 				{
                 					dataMap.put("Distributor_Name",getCRmId.toLong());
                 				}
                 				if(getDistributorData.Employee_ID.isEmpty() == false)
                 				{
                 					dataMap.put("Owner",toLong(getDistributorData.Employee_ID));
                 				}
                 				else
                 				{
                 					emptymap = Map();
                 					//Accountsdata = zoho.crm.getRecordById("Accounts",getDistributorData.Account_CRM_record_ID.toLong(),emptymap,"zohocrm_connection");
                 					Accountsdata = zoho.crm.getRecordById("Accounts",getDistributorData.Account_CRM_record_ID.toLong(),emptymap,"zoho_oauth_connection");
                 					accountsOwnerid = Accountsdata.get("Owner").get("id");
                 					dataMap.put("Owner",accountsOwnerid);
                 				}
                 			}
                 		}
                 		//dataMap.put("Owner",1000823000000567001);
                 		/*******************************************************Get Sales Order**************************************************/
                 		getSalesOrder = getRSOData.Sales_Order;
                 		if(getSalesOrder.isNull() == false)
                 		{
                 			info "entersalesOrder";
                 			getSalesOrderData = Order_Management[ID == getSalesOrder];
                 			if(getSalesOrderData.count() > 0)
                 			{
                 				getCRmSOId = getSalesOrderData.CRM_SO_ID;
                 				if(getCRmSOId.isNull() == false)
                 				{
                 					dataMap.put("Sales_Order",getCRmSOId.toLong());
                 				}
                 			}
                 		}
                 		/*******************************************************Get CNF**************************************************/
                 		getCNF = getRSOData.CNF_Name;
                 		if(getCNF.isNull() == false)
                 		{
                 			info "enterCNF";
                 			getCNFData = CNF_Master[ID == getCNF];
                 			if(getCNFData.count() > 0)
                 			{
                 				getCRmCNFId = getCNFData.CRM_CNF_ID;
                 				if(getCRmCNFId.isNull() == false)
                 				{
                 					dataMap.put("CNF_Name",getCRmCNFId.toLong());
                 				}
                 			}
                 		}
                 		/*******************************************************Get Invoice**************************************************/
                 		getInvoice = getRSOData.Invoice;
                 		info "Get Invoice==>" + getInvoice;
                 		if(getInvoice.isNull() == false)
                 		{
                 			info "enterInvoice";
                 			getInvoiceData = Invoice[ID == getInvoice];
                 			if(getInvoiceData.count() > 0)
                 			{
                 				getCRmInvId = getInvoiceData.CRM_SO_ID;
                 				if(getCRmInvId.isNull() == false)
                 				{
                 					dataMap.put("Invoice",getCRmInvId.toLong());
                 				}
                 				// Invoice Number Mapping
                 				if(getInvoiceData.SAPID.isNull() == false)
                 				{
                 					info "Invoice SAP ID ==> " + getInvoiceData.SAPID;
                 					dataMap.put("Invoice_Number",getInvoiceData.SAPID);
                 					info dataMap;
                 				}
                 			}
                 		}
                 		info dataMap;
                 		getlineItems = Return_Sales_order_Line_Items[Return_Sales_Order == id];
                 		if(getlineItems.count() > 0)
                 		{
                 			dataMap.put("Creator_rec_id",id.toString());
                 			dataMap.put("Return_No",getRSOData.Return_No);
                 			dataMap.put("Status",getRSOData.Status);
                 			if(getRSOData.Return_Date.isNull() == false)
                 			{
                 				dataMap.put("Return_Date",getRSOData.Return_Date.toString("yyyy-MM-dd"));
                 			}
                 			if(getlineItems.count() < 2 && getRSOData.Status == "Pending")
                 			{
                 				info "Return sales Order will Create";
                 				prodList = List();
                 				for each  lineItem in getlineItems
                 				{
                 					getprod = lineItem.Product_Name;
                 					mps = Map();
                 					if(getprod != null)
                 					{
                 						getProdData = Product_Master[ID == getprod];
                 						if(getProdData.count() > 0)
                 						{
                 							getProdId = getProdData.CRM_SO_ID;
                 							if(getProdId.isNull() == false)
                 							{
                 								mps.put("Product_Name",getProdId.toLong());
                 							}
                 						}
                 					}
                 					// 					mps.put("Product_Code",lineItem.Product_Code);
                 					mps.put("Batch_Number",lineItem.Batch_Number);
                 					mps.put("Price",lineItem.Price);
                 					mps.put("Ordered_Quantity",lineItem.Order_Qty);
                 					mps.put("Return_Quantity",lineItem.Return_Qty);
                 					mps.put("Remarks",lineItem.Remarks);
                 					if(lineItem.Return_Date.isNull() == false)
                 					{
                 						mps.put("Return_Date",lineItem.Return_Date.toString("yyyy-MM-dd"));
                 					}
                 					prodList.add(mps);
                 				}
                 				dataMap.put("Return_Items",prodList);
                 				/*******************************************************Create Record In Crm**************************************************/
                 				datamap1 = Map();
                 				datamap1.put("data",{dataMap});
                 				// 				insertresp = invokeurl
                 				// 				[
                 				// 					url :"https://www.zohoapis.in/crm/v8/Return_Sales_Order"
                 				// 					type :POST
                 				// 					parameters:datamap1.toString()
                 				// 					connection:"zohocrm_connection"
                 				// 				];
                 				insertresp = invokeurl
                 				[
                 					url :"https://www.zohoapis.in/crm/v8/Return_Sales_Order"
                 					type :POST
                 					parameters:datamap1.toString()
                 					connection:"zoho_oauth_connection"
                 				];
                 				info "insertresp" + insertresp;
                 				craetemsg = insertresp.get("data").getJson("message");
                 				if(craetemsg == "record added")
                 				{
                 					details = insertresp.get("data").getJson("details");
                 					getRSOData.CRMID=details.get("id").toString();
                 				}
                 			}
                 			else
                 			{
                 				info "Return sales Order will Update";
                 				crmLCID = getRSOData.CRMID;
                 				if(crmLCID.isNull() == false)
                 				{
                 					othermap = Map();
                 					Prod = List();
                 					dataMap.put("Return_Items",Prod);
                 					//data = zoho.crm.updateRecord("Return_Sales_Order",crmLCID.toLong(),dataMap,othermap,"zohocrm_connection");
                 					data = zoho.crm.updateRecord("Return_Sales_Order",crmLCID.toLong(),dataMap,othermap,"zoho_oauth_connection");
                 					info data;
                 				}
                 				datamap1 = Map();
                 				/*******************************************************Get Product Name**************************************************/
                 				prodList = List();
                 				for each  lineItem in getlineItems
                 				{
                 					getprod = lineItem.Product_Name;
                 					mps = Map();
                 					if(getprod != null)
                 					{
                 						getProdData = Product_Master[ID == getprod];
                 						if(getProdData.count() > 0)
                 						{
                 							getProdId = getProdData.CRM_SO_ID;
                 							if(getProdId.isNull() == false)
                 							{
                 								mps.put("Product_Name",getProdId);
                 							}
                 						}
                 					}
                 					// 					mps.put("Product_Code",lineItem.Product_Code);
                 					mps.put("Batch_Number",lineItem.Batch_Number);
                 					mps.put("Price",lineItem.Price);
                 					mps.put("Ordered_Quantity",lineItem.Order_Qty);
                 					mps.put("Return_Quantity",lineItem.Return_Qty);
                 					mps.put("Remarks",lineItem.Remarks);
                 					if(lineItem.Return_Date.isNull() == false)
                 					{
                 						mps.put("Return_Date",lineItem.Return_Date.toString("yyyy-MM-dd"));
                 					}
                 					prodList.add(mps);
                 				}
                 				dataMap.put("Return_Items",prodList);
                 				datamap1 = Map();
                 				datamap1.put("data",{dataMap});
                 				info dataMap;
                 				info crmLCID + "=======>";
                 				if(crmLCID.isNull() == false && crmLCID != "")
                 				{
                 					info "Testing========>";
                 					/*******************************************************Update Record in Crm****************************************************/
                 					updateresp = invokeurl
                 					[
                 						url :"https://www.zohoapis.in/crm/v8/Return_Sales_Order/" + crmLCID
                 						type :PUT
                 						parameters:datamap1.toString()
                 						connection:"zoho_oauth_connection"
                 					];
                 					// 					updateresp = invokeurl
                 					// 					[
                 					// 						url :"https://www.zohoapis.in/crm/v8/Return_Sales_Order/" + crmLCID
                 					// 						type :PUT
                 					// 						parameters:datamap1.toString()
                 					// 						connection:"zohocrm_connection"
                 					// 					];
                 					info "updateresp" + updateresp;
                 				}
                 				else
                 				{
                 					dataMap.put("Creator_rec_id",id.toString());
                 					dataMap.put("Return_No",getRSOData.Batch_Number);
                 					dataMap.put("Status",getRSOData.Status);
                 					if(getRSOData.Return_Date.isNull() == false)
                 					{
                 						dataMap.put("Return_Date",getRSOData.Return_Date.toString("yyyy-MM-dd"));
                 					}
                 					// 					insertresp = invokeurl
                 					// 					[
                 					// 						url :"https://www.zohoapis.in/crm/v8/Return_Sales_Order"
                 					// 						type :POST
                 					// 						parameters:datamap1.toString()
                 					// 						connection:"zohocrm_connection"
                 					// 					];
                 					insertresp = invokeurl
                 					[
                 						url :"https://www.zohoapis.in/crm/v8/Return_Sales_Order"
                 						type :POST
                 						parameters:datamap1.toString()
                 						connection:"zoho_oauth_connection"
                 					];
                 					info "insertresp" + insertresp;
                 					craetemsg = insertresp.get("data").getJson("message");
                 					if(craetemsg == "record added")
                 					{
                 						details = insertresp.get("data").getJson("details");
                 						getRSOData.CRMID=details.get("id").toString();
                 					}
                 				}
                 			}
                 		}
                 	}
                 }
				 list SalesOrder.FetchSalesOrders(int id)
                 {
                 	brandMap = Map();
                 	totalBrands = List();
                 	if(id != null)
                 	{
                 		//  Fetch all schemes once for distributor
                 		allSchemes = Scheme_Master[Distributor_Name == id];
                 		searchSO = Order_Management[Distributor_Name == id];
                 		for each  rec in searchSO
                 		{
                 			salesOrderId = rec.ID;
                 			//  Fetch all returns once per sales order
                 			allReturns = Return_Sales_Order[Sales_Order == salesOrderId];
                 			for each  item in rec.Line_Items
                 			{
                 				if(item.Product_Name != null)
                 				{
                 					productId = item.Product_Name.ID;
                 					qty = ifnull(item.Quantity,0);
                 					amount = ifnull(item.Total,0);
                 					rate = 0;
                 					if(qty != 0)
                 					{
                 						rate = amount / qty;
                 					}
                 					productRec = Product_Master[ID == productId];
                 					brandLookup = productRec.Brand_Name_Backend;
                 					brandName = brandLookup;
                 					if(brandName != null && brandName != "")
                 					{
                 						//  RETURN CALCULATION
                 						returnQtyTotal = 0;
                 						returnAmountTotal = 0;
                 						for each  ret in allReturns
                 						{
                 							if(ret.Product_Name != null && ret.Product_Name.ID == productId)
                 							{
                 								retQty = ifnull(ret.Return_Quantity,0);
                 								returnQtyTotal = returnQtyTotal + retQty;
                 								returnAmountTotal = returnAmountTotal + retQty * rate;
                 							}
                 						}
                 						//  BRAND NOT EXISTS
                 						if(brandMap.get(brandName) == null)
                 						{
                 							newBrandData = Map();
                 							newBrandData.put("Brand_Name",brandName);
                 							newBrandData.put("Sales_Quantity",qty);
                 							newBrandData.put("Sales_Amount",amount);
                 							newBrandData.put("Return_Quantity",returnQtyTotal);
                 							newBrandData.put("Return_Amount",returnAmountTotal);
                 							//  SCHEME SUM CALCULATION
                 							schemePoint = 0;
                 							schemeQty = 0;
                 							schemeCD = 0;
                 							schemeTOD = 0;
                 							schemeDebit = 0;
                 							schemeCredit = 0;
                 							schemeCash = 0;
                 							for each  sch in allSchemes
                 							{
                 								if(sch.Brand_Name.Brand_name == brandLookup)
                 								{
                 									schemePoint = schemePoint + ifnull(sch.Point_Scheme,0);
                 									schemeQty = schemeQty + ifnull(sch.Quantitiy_Scheme,0);
                 									schemeCD = schemeCD + ifnull(sch.CD_Scheme,0);
                 									schemeTOD = schemeTOD + ifnull(sch.TOD_Scheme,0);
                 									schemeDebit = schemeDebit + ifnull(sch.Rate_Diff_Debit_Note,0);
                 									schemeCredit = schemeCredit + ifnull(sch.Rate_Diff_Credit_Note,0);
                 									schemeCash = schemeCash + ifnull(sch.Cash_Billing,0);
                 								}
                 							}
                 							newBrandData.put("Point_Scheme",schemePoint);
                 							newBrandData.put("Quantity_Scheme",schemeQty);
                 							newBrandData.put("CD_Scheme",schemeCD);
                 							newBrandData.put("TOD_Scheme",schemeTOD);
                 							newBrandData.put("Rate_Diff_Debit_Note",schemeDebit);
                 							newBrandData.put("Rate_Diff_Credit_Note",schemeCredit);
                 							newBrandData.put("Cash_Billing",schemeCash);
                 							brandMap.put(brandName,newBrandData);
                 						}
                 						else
                 						{
                 							existingBrandData = brandMap.get(brandName);
                 							existingBrandData.put("Sales_Quantity",existingBrandData.get("Sales_Quantity") + qty);
                 							existingBrandData.put("Sales_Amount",existingBrandData.get("Sales_Amount") + amount);
                 							existingBrandData.put("Return_Quantity",existingBrandData.get("Return_Quantity") + returnQtyTotal);
                 							existingBrandData.put("Return_Amount",existingBrandData.get("Return_Amount") + returnAmountTotal);
                 							brandMap.put(brandName,existingBrandData);
                 						}
                 					}
                 				}
                 			}
                 		}
                 	}
                 	for each  key in brandMap.keys()
                 	{
                 		totalBrands.add(brandMap.get(key));
                 	}
                 	return totalBrands;
                 }
