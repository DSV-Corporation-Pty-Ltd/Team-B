			Populate_Year_and_Quarter as "Populate Year and Quarter"
			{
				type =  form
				form = Sign_Test

				record event = on add

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Distributor_Name;
										hide Year_field;
										hide Date_field;
										hide Quarter;
										hide Signed_PDF;
										currentMonth = zoho.currentdate.getMonth();
										currentYear = zoho.currentdate.getYear();
										signQuarter = "";
										signYear = currentYear;
										//  Decide which quarter to sign
										if(currentMonth >= 7 && currentMonth <= 9)
										{
											// Q2
											signQuarter = "Q1";
										}
										else if(currentMonth >= 10 && currentMonth <= 12)
										{
											// Q3
											signQuarter = "Q2";
										}
										else if(currentMonth >= 1 && currentMonth <= 3)
										{
											// Q4
											signQuarter = "Q3";
										}
										else if(currentMonth >= 4 && currentMonth <= 6)
										{
											// Q1
											signQuarter = "Q4";
											signYear = currentYear - 1;
											// previous FY
										}
										input.Year_field = signYear.toString();
										input.Quarter = signQuarter;
						)
					}
				}

			}
