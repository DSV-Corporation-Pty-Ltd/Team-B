			on_the_user_input_Dispatc as "on the user input Dispatch quantity"
			{
				type =  form
				form = Dispatch

				record event = on add or edit

				on user input of Line_Items.Dispatched_Quantity
				{
					actions 
					{
						custom deluge script
						(
											if(row.Dispatched_Quantity.isNull() == false)
										{
											if(row.Dispatched_Quantity <= 0)
											{
												alert "Dispatched Quantity should not be 0 or negative value.";
												row.Dispatched_Quantity=null;
												row.Total=null;
												input.GST_Val = null;
												input.IGST_Val = null;
												input.Tax_Amount = null;
												input.Grand_Total = null;
												input.Sub_Total = null;
											}
											else if(row.Dispatched_Quantity > row.Order_Quantity)
											{
												alert "Dispatched Quantity should not greater than Order quantity.";
												row.Dispatched_Quantity=null;
												row.Total=null;
												input.GST_Val = null;
												input.IGST_Val = null;
												input.Tax_Amount = null;
												input.Grand_Total = null;
												input.Sub_Total = null;
											}
											else
											{
												row.Total=ifnull(row.Dispatched_Quantity,0) * ifnull(row.Price,0);
												subTotal = 0;
												taxAmount = 0;
												grandTotal = 0;
												gstCal = 0;
												igstCal = 0;
												if(input.Line_Items.isEmpty() == false)
												{
													for each  items in input.Line_Items
													{
														subTotal = subTotal + ifnull(items.Total,0);
													}
													gstCal = (ifnull(subTotal,0) * 18) / 100;
													igstCal = (ifnull(subTotal,0) * 13) / 100;
													input.Sub_Total = ifnull(subTotal,0);
													input.GST_Val = gstCal;
													input.IGST_Val = igstCal;
													input.Tax_Amount = ifnull(input.GST_Val,0) + ifnull(input.IGST_Val,0);
													input.Grand_Total = ifnull(input.Tax_Amount,0) + ifnull(input.Sub_Total,0);
												}
											}
										}
						)
					}
				}

			}
			on_success as "on success"
			{
				type =  form
				form = Dispatch

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											thisapp.AutoNumber.generateAutoNumber("Dispatch",input.ID);
										if(input.Line_Items.isEmpty() == false)
										{
											balQty = 0;
											for each  items in input.Line_Items
											{
												getOrderItemData = Order_Line_Items[ID == items.SO_Line_Item_ID];
												if(getOrderItemData.count() > 0)
												{
													getOrderItemData.Balance_Quantity=ifnull(items.Order_Quantity,0) - ifnull(items.Dispatched_Quantity,0);
													balQty = balQty + ifnull(getOrderItemData.Balance_Quantity,0);
												}
											}
											getOrderData = Order_Management[ID == input.Sales_Order];
											if(getOrderData.count() > 0)
											{
												if(balQty > 0)
												{
													getOrderData.Status="Partial Dispatched";
												}
												else
												{
													getOrderData.Status="Fully Dispatched";
												}
											}
										}
										thisapp.Notifications.SendDispatchEmailToTrans(input.ID);
										thisapp.SMS.DispatchCreationSMSToDistributor(input.ID);
										if(input.Sales_Order.isNull() == false)
										{
											getOrder = Order_Management[ID == input.Sales_Order];
											if(getOrder.count() > 0)
											{
												if(getOrder.Plant.isEmpty() == false)
												{
													input.Plant = getOrder.Plant.Plant;
												}
											}
										}
						)
					}
				}

			}
