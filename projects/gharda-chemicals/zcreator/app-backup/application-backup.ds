		list All_Meetings1
		{
			displayName = "Meetings"
			show all rows from Meeting  [Email == zoho.loginuserid]  
			(
				Liquidation_Agent_Name as "Liquidation Agent Name"
				Liquidation_Agent_Email as "Liquidation Agent Email"
				Title
				Location
				From
				To
				Description
				Host_By as "Host By"
				Distributor
				Sales_Officer as "Sales Officer"
				Check_In_Time as "Meeting Date Time"
				Meeting_Notes as "Meeting Notes"
				Meeting_Distance_KM as "Meeting Distance KM"
				(
					display = total	
				)
				Total_Distance_KM as "Total Distance KM"
				(
					display = total	
				)
				Meeting_Status as "Meeting Status"
				Meeting_Latitude as "Meeting Latitude"
				Meeting_Longitude as "Meeting Longitude"
				Village_Name as "Village Name"
				Distributor_Name as "Distributor Name"
				Email
				Farmer
			)
			custom actions
			(
				"Cancelled Meeting"
				(
	  			workflow = liquidation_agent_meeting
				show action in view header = true
				show action in edit record menu = true
				condition = (Meeting_Status.contains("Open"))
				confirmation before execution
				(
					message for individual record = "Are you sure you want to cancel this meeting?"
					confirm button text = "Yes"		
					cancel button text = "No"
				)
				)
				"Add Distributor"
				(
	  			workflow = Meeting_create_from_crm_n
				show action in view header = true
				show action in edit record menu = true
				condition = (Meeting_Create_from_CRM == true && Distributor.Distributor_Name is null)
				)
			)
			customlayouts
			(
				template
	 			(
	 	  			displayname="Custom Layout 1"
