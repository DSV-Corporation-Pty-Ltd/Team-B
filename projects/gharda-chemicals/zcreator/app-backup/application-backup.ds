				 void syncSampleCollectionReport.syncSampleCollectionReportInCrm(int id)
                 {
                 	/*******************************************************Get Sample Reques Data**************************************************/
                 	getAPData = Sample_Collection_Report[ID == id];
                 	dataMap = Map();
                 	othermap = Map();
                 	if(getAPData.count() > 0)
                 	{
                 		dataMap.put("Government_Officer_Name",ifnull(getAPData.Government_Officer_Name,""));
                 		dataMap.put("Govt_Letter_Reference_No",ifnull(getAPData.Govt_Letter_Reference_No,""));
                 		dataMap.put("Department_Authority",ifnull(getAPData.Department_Authority,""));
                 		dataMap.put("Officer_Contact_Number",ifnull(getAPData.Officer_Contact_Number,""));
                 		dataMap.put("Officer_Email",ifnull(getAPData.Officer_Email,""));
                 		dataMap.put("State",ifnull(getAPData.State,""));
                 		dataMap.put("Remarks_Notes",ifnull(getAPData.Remarks_Notes,""));
                 		if(getAPData.Collection_Date.isNull() == false)
                 		{
                 			dataMap.put("Collection_Date",getAPData.Collection_Date.toString("yyyy-MM-dd"));
                 		}
                 		/*******************************************************Get Distributor**************************************************/
                 		getDistributor = getAPData.Distributor_Dealer_Name;
                 		if(getDistributor != null)
                 		{
                 			getDistributorData = Distributor_Master[ID == getDistributor];
                 			if(getDistributorData.count() > 0)
                 			{
                 				getCRmId = getDistributorData.Account_CRM_record_ID;
                 				if(getCRmId != "")
                 				{
                 					dataMap.put("Distributor_Dealer_Name",getCRmId.toLong());
                 				}
                 				if(getDistributorData.Employee_ID.isEmpty() == false)
                 				{
                 					dataMap.put("Owner",toLong(getDistributorData.Employee_ID));
                 				}
                 				else
                 				{
                 					emptymap = Map();
                 					//Accountsdata = zoho.crm.getRecordById("Accounts",getDistributorData.Account_CRM_record_ID.toLong(),emptymap,"zohocrm_connection");
                 					Accountsdata = zoho.crm.getRecordById("Accounts",getDistributorData.Account_CRM_record_ID.toLong(),emptymap,"zoho_oauth_connection");
                 					accountsOwnerid = Accountsdata.getJSON("Owner").get("id");
                 					dataMap.put("Owner",accountsOwnerid);
                 				}
                 			}
                 		}
                 		if(getAPData.Govt_Letter_Upload != null && getAPData.Govt_Letter_Upload != "")
                 		{
                 			info getAPData.Govt_Letter_Upload;
                 			/*******************************************************Get Govt Letter File**************************************************/
                 			fileContent = invokeurl
                 			[
                 				url :"https://creator.zoho.in/api/v2/zohoadmin_gharda782/distributor-management-gharda-chemical/report/All_Sample_Collection_Reports/" + id + "/Govt_Letter_Upload/download"
                 				type :GET
                 				connection:"zoho_oauth_connection"
                 			];
                 			fileContent.setparamname("file");
                 			resp = invokeurl
                 			[
                 				url :" https://www.zohoapis.in/crm/v2/files"
                 				type :POST
                 				files:fileContent
                 				connection:"zoho_oauth_connection"
                 			];
                 			// 			resp = invokeurl
                 			// 			[
                 			// 				url :" https://www.zohoapis.in/crm/v2/files"
                 			// 				type :POST
                 			// 				files:fileContent
                 			// 				connection:"zohocrm_connection"
                 			// 			];
                 			fileid = resp.get("data").get(0).get("details").get("id");
                 			info fileid;
                 			fmp = Map();
                 			fmp.put("File_Id__s",fileid);
                 			fileList = List();
                 			fileList.add(fmp);
                 			dataMap.put("Govt_Letter_Upload",fileList);
                 		}
                 		/*******************************************************Get Territory Data**************************************************/
                 		getTerritory = getAPData.Territory;
                 		if(getTerritory != null)
                 		{
                 			getTerritoryData = Territory[ID == getTerritory];
                 			if(getTerritoryData.count() > 0)
                 			{
                 				getCRmTId = getTerritoryData.zoho_crm_id;
                 				if(getCRmTId != "")
                 				{
                 					dataMap.put("Territory_Name",getCRmTId.toLong());
                 				}
                 			}
                 		}
                 		/*******************************************************Get Region Data**************************************************/
                 		getRegion = getAPData.Region;
                 		if(getRegion != null)
                 		{
                 			getRegionData = Region_Master[ID == getRegion];
                 			if(getRegionData.count() > 0)
                 			{
                 				getCRmRId = getRegionData.CRM_Region_ID;
                 				if(getCRmRId != "")
                 				{
                 					dataMap.put("Region",getCRmRId.toLong());
                 				}
                 			}
                 		}
                 		/*******************************************************Get Subform Data**************************************************/
                 		getProducts = Sample_Collection_Line_Items[Sample_Collection_Report == id];
                 		if(getProducts.count() > 0)
                 		{
                 			productList = List();
                 			for each  getPro in getProducts
                 			{
                 				productmap = Map();
                 				/*******************************************************Get Brand Name**************************************************/
                 				getBrand = getPro.Product;
                 				if(getBrand != null)
                 				{
                 					getBrandData = Brand_Master[ID == getBrand];
                 					if(getBrandData.count() > 0)
                 					{
                 						getCRmBId = getBrandData.zoho_crm_id;
                 						if(getCRmBId != "")
                 						{
                 							productmap.put("Product",getCRmBId.toLong());
                 						}
                 						else
                 						{
                 							//searchBrand = zoho.crm.searchRecords("Brand_Master","Creator_rec_id:equals:" + getBrand.toString() + "",0,200,othermap,"zohocrm_connection");
                 							searchBrand = zoho.crm.searchRecords("Brand_Master","Creator_rec_id:equals:" + getBrand.toString() + "",0,200,othermap,"zoho_oauth_connection");
                 							if(searchBrand.isEmpty() == false)
                 							{
                 								for each  serachBr in searchBrand
                 								{
                 									brandId = serachBr.get("id");
                 									productmap.put("Product",brandId.toNumber());
                 								}
                 							}
                 						}
                 					}
                 				}
                 				productmap.put("SKU1",ifnull(getPro.SKU,""));
                 				productmap.put("Batch_Number1",ifnull(getPro.Batch_Number,""));
                 				productmap.put("Total_Quantity",ifnull(getPro.Quantity,0));
                 				productmap.put("Technical_Composition",ifnull(getPro.Technical_Composition,""));
                 				productmap.put("Remarks",ifnull(getPro.Remarks,""));
                 				productmap.put("Manufactured_by",ifnull(getPro.Manufactured_by,""));
                 				if(getPro.Expiry.isNull() == false)
                 				{
                 					productmap.put("Expiry",getPro.Expiry.toString("yyyy-MM-dd"));
                 				}
                 				if(getPro.Mfg_Date.isNull() == false)
                 				{
                 					productmap.put("Mfg_Date",getPro.Mfg_Date.toString("yyyy-MM-dd"));
                 				}
                 				productList.add(productmap);
                 			}
                 			dataMap.put("Product_Line_Items",productList);
                 		}
                 		dataMap.put("sync_from_Creator",true);
                 		//         dataMap.put("Name","Sample");
                 		dataMap.put("Creator_Rec_Id",id.toString());
                 		info dataMap;
                 		/*******************************************************Create Record in Crm****************************************************/
                 		datamap1 = Map();
                 		datamap1.put("data",{dataMap});
                 		info datamap1;
                 		// 		insertresp = invokeurl
                 		// 		[
                 		// 			url :"https://www.zohoapis.in/crm/v8/Sample_Collection_Report"
                 		// 			type :POST
                 		// 			parameters:datamap1.toString()
                 		// 			connection:"zohocrm_connection"
                 		// 		];
                 		insertresp = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/crm/v8/Sample_Collection_Report"
                 			type :POST
                 			parameters:datamap1.toString()
                 			connection:"zoho_oauth_connection"
                 		];
                 		info "insertresp" + insertresp;
                 		craetemsg = insertresp.get("data").getJson("message");
                 		if(craetemsg == "record added")
                 		{
                 			details = insertresp.get("data").getJson("details");
                 			getAPData.zoho_crm_id=details.get("id").toString();
                 		}
                 	}
                 }
				 void ZohoExpenseApi.PushExpenseToZohoExpense(int ExpID)
                 {
                 	getExpenseData = Expense_Master[ID == ExpID];
                 	if(getExpenseData.count() > 0)
                 	{
                 		getCNFData = CNF_Master[ID == getExpenseData.CNF_Name];
                 	}
                 	CustomerJson = {"merchant_name":ifnull(getCNFData.CNF_Name,""),"merchant_code":ifnull(getExpenseData.Expense_No,"")};
                 	query = Map();
                 	query.put("merchant_name",ifnull(getCNFData.CNF_Name,""));
                 	query.put("page",0);
                 	query.put("per_page",200);
                 	cnfUser = ifnull(getCNFData.CNF_Name,"");
                 	Merchant_ID = "";
                 	if(getExpenseData.MerchantID.isEmpty() == false)
                 	{
                 		Merchant_ID = getExpenseData.MerchantID;
                 	}
                 	if(Merchant_ID.isEmpty() == false)
                 	{
                 		getcustomer = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/expense/v1/merchants/" + Merchant_ID
                 			type :GET
                 			connection:"zoho_oauth_connection"
                 		];
                 		if(getcustomer.containkey("code") && getcustomer.get("code") == 0)
                 		{
                 			merchantResp = {"Module":"Merchant","Trigger":"GetMerchantData","Resp":getcustomer.get("message")};
                 			contactData = getcustomer.get("merchant");
                 			merchantID = "";
                 			if(contactData.isEmpty() == false)
                 			{
                 				merchantID1 = contactData.get("merchant_id");
                 				merchantID = merchantID1;
                 			}
                 		}
                 	}
                 	if(Merchant_ID.isEmpty() == true)
                 	{
                 		getcustomer = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/expense/v1/merchants"
                 			type :GET
                 			parameters:query
                 			connection:"zoho_oauth_connection"
                 		];
                 		if(getcustomer.containkey("code") && getcustomer.get("code") == 0)
                 		{
                 			merchantResp = {"Module":"Merchant","Trigger":"GetMerchantData","Resp":getcustomer.get("message")};
                 			cnfUserId = "";
                 			merchants = getcustomer.get("merchants");
                 			if(merchants.size() > 0)
                 			{
                 				for each  m in merchants
                 				{
                 					if(m.get("merchant_name") == cnfUser)
                 					{
                 						cnfUserId = m.get("merchant_id");
                 						break;
                 					}
                 				}
                 				merchantID = cnfUserId;
                 			}
                 		}
                 	}
                 	if(merchantID == "")
                 	{
                 		createCustomerInExpense = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/expense/v1/merchants"
                 			type :POST
                 			parameters:CustomerJson.toString()
                 			connection:"zoho_oauth_connection"
                 		];
                 		merchantResp = {"Module":"Merchant","Trigger":"Create","Resp":createCustomerInExpense.get("message")};
                 		if(createCustomerInExpense.containkey("code") && createCustomerInExpense.get("code") == 0)
                 		{
                 			contactData = createCustomerInExpense.get("merchants");
                 			merchantID = contactData.getJson("merchant_id");
                 		}
                 	}
                 	getExpenseData.Merchant_Response=merchantResp.toString();
                 	currentdate = zoho.currentdate;
                 	monthNum = currentdate.getMonth();
                 	yearNum = currentdate.getYear();
                 	monthMap = Map();
                 	monthMap.put(1,"January");
                 	monthMap.put(2,"February");
                 	monthMap.put(3,"March");
                 	monthMap.put(4,"April");
                 	monthMap.put(5,"May");
                 	monthMap.put(6,"June");
                 	monthMap.put(7,"July");
                 	monthMap.put(8,"August");
                 	monthMap.put(9,"September");
                 	monthMap.put(10,"October");
                 	monthMap.put(11,"November");
                 	monthMap.put(12,"December");
                 	monthName = monthMap.get(monthNum);
                 	reportName = "Report " + getCNFData.CNF_Name + " " + monthName + " - " + yearNum;
                 	//reportName = "Report Test" + monthName + " - " + yearNum;
                 	startDateText = currentdate.toString("yyyy-MM") + "-01";
                 	startDate = startDateText.toDate();
                 	endDate = startDate.addMonth(1).addDay(-1);
                 	startDateFormatted = startDate.toString("yyyy-MM-dd");
                 	endDateFormatted = endDate.toString("yyyy-MM-dd");
                 	fieldMap = Map();
                 	fieldMap.put("customfield_id","2962877000000207101");
                 	fieldMap.put("value",getCNFData.CRM_CNF_ID);
                 	// 	expensemap.put("custom_fields",{fieldMap});
                 	reportJson = {"report_name":reportName,"description":reportName,"start_date":startDateFormatted,"end_date":endDateFormatted,"policy_id":"-1","custom_fields":{fieldMap}};
                 	repquery = Map();
                 	repquery.put("report_name",reportName);
                 	repquery.put("page",0);
                 	repquery.put("per_page",200);
                 	ZohoReportID = "";
                 	if(getExpenseData.ReportID.isEmpty() == false)
                 	{
                 		ZohoReportID = getExpenseData.ReportID;
                 	}
                 	//info ZohoReportID;
                 	if(ZohoReportID.isEmpty() == false)
                 	{
                 		getreport = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/expense/v1/expensereports/" + ZohoReportID
                 			type :GET
                 			connection:"zoho_oauth_connection"
                 		];
                 		//info getreport;
                 		reportID = "";
                 		if(getreport.containkey("code") && getreport.get("code") == 0)
                 		{
                 			reportResp = {"Module":"Report","Trigger":"GetReportData","Resp":getreport.get("message")};
                 			reportData = getreport.get("expense_report");
                 			if(reportData.isEmpty() == false)
                 			{
                 				reportID = reportData.get("report_id");
                 			}
                 		}
                 	}
                 	if(ZohoReportID.isEmpty() == true)
                 	{
                 		getreport = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/expense/v1/expensereports"
                 			type :GET
                 			parameters:repquery
                 			connection:"zoho_oauth_connection"
                 		];
                 		//info getreport;
                 		if(getreport.containkey("code") && getreport.get("code") == 0)
                 		{
                 			reportResp = {"Module":"Report","Trigger":"GetReportData","Resp":getreport.get("message")};
                 			cnfReportId = "";
                 			reportID = "";
                 			reports = getreport.get("expense_reports");
                 			if(reports.size() > 0)
                 			{
                 				for each  m2 in reports
                 				{
                 					if(m2.get("report_name") == reportName)
                 					{
                 						cnfReportId = m2.get("report_id");
                 						break;
                 					}
                 				}
                 				reportID = cnfReportId;
                 			}
                 		}
                 	}
                 	if(reportID == "")
                 	{
                 		createReport = invokeurl
                 		[
                 			url :"https://www.zohoapis.in/expense/v1/expensereports"
                 			type :POST
                 			parameters:reportJson.toString()
                 			connection:"zoho_oauth_connection"
                 		];
                 		//info createReport;
                 		reportResp = {"Module":"Report","Trigger":"Create","Resp":createReport.get("message")};
                 		if(createReport.containkey("code") && createReport.get("code") == 0)
                 		{
                 			repoData = createReport.get("expense_report");
                 			reportID = repoData.getJson("report_id");
                 		}
                 	}
                 	getExpenseData.Report_Response=reportResp.toString();
                 	// 	expensemap = Map();
                 	// 	expensemap.put("currency_id",2962877000000000064);
                 	// 	expensemap.put("date",getExpenseData.Expense_Date.toString("yyyy-MM-dd"));
