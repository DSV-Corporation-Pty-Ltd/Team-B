													input.IGST_Val = igstCal;
												}
												input.Tax_Amount = ifnull(input.CGST_Val,0) + ifnull(input.IGST_Val,0);
												input.Grand_Total = ifnull(input.Tax_Amount,0) + ifnull(input.Sub_Total,0);
											}
