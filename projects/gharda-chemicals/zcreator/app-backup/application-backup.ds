			on_the_user_input_of_expe as "on the user input of expense category"
			{
				type =  form
				form = Expense_Master

				record event = on add or edit

				on user input of Expense_Category
				{
					actions 
					{
						custom deluge script
						(
											getexpensecat = Expense_Category[Category == input.Expense_Category.Category];
										// if(getexpensecat.count() > 0)
										// {
										// 	input.Expense_Type = getexpensecat.ID;
										// 	input.GL_Code = getexpensecat.GL_Code;
										// 	if(getexpensecat.Expense_Type == "VARIABLE")
										// 	{
										// 		show Enter_Quantity;
										// 	}
										// }
										getExpenseTxData = Expense_Tax_Master[CNF_Name == input.CNF_Name && Expense_Category == input.Expense_Category];
										hide CSGST;
										hide CGST;
										hide SGST;
										hide RCM_CGST;
										hide RCM;
										hide IGST;
										hide RCM_IGST;
										if(getExpenseTxData.count() > 0)
										{
											if(getExpenseTxData.CGST != "NO" && getExpenseTxData.CGST != "")
											{
												show CGST;
												input.CGST = getExpenseTxData.CGST + " %";
											}
											if(getExpenseTxData.SGST != "NO" && getExpenseTxData.SGST != "")
											{
												show SGST;
												input.SGST = getExpenseTxData.SGST + " %";
											}
											if(getExpenseTxData.CSGST != "NO" && getExpenseTxData.CSGST != "")
											{
												show CSGST;
												input.CSGST = getExpenseTxData.CSGST + " %";
											}
											if(getExpenseTxData.RCM_CGST != "NO" && getExpenseTxData.RCM_CGST != "")
											{
												show RCM_CGST;
												input.RCM_CGST = getExpenseTxData.RCM_CGST + " %";
											}
											if(getExpenseTxData.RCM_IGST != "NO" && getExpenseTxData.RCM_IGST != "")
											{
												show RCM_IGST;
												input.RCM_IGST = getExpenseTxData.RCM_IGST + " %";
											}
											if(getExpenseTxData.RCM != "NO" && getExpenseTxData.RCM != "")
											{
												show RCM;
												input.RCM = getExpenseTxData.RCM + " %";
											}
											if(getExpenseTxData.IGST != "NO" && getExpenseTxData.IGST != "")
											{
												show IGST;
												input.IGST = getExpenseTxData.IGST + " %";
											}
											input.Tax = ifnull(getExpenseTxData.Tax,0);
											if(input.Tax != null && input.Tax > 0)
											{
												input.Tax_Amount = ifnull(input.Tax,0) / 100 * ifnull(input.Amount1,0);
												input.Amount = ifnull(input.Amount1,0) + ifnull(input.Tax_Amount,0);
											}
											else
											{
												//	input.Tax_Amount = 0;
												input.Amount = ifnull(input.Amount1,0);
											}
										}
										else
										{
											input.Tax = 0;
											input.Tax_Amount = 0;
											input.Amount1 = 0;
										}
										if(input.Tax_Amount < 1)
										{
											input.Tax_Amount = 0;
										}
						)
					}
				}

			}
