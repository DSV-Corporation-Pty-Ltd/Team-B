						)
					}
				}

			}
			leave_request_days as "leave request days"
			{
				type =  form
				form = Leave_Request

				record event = on add

				on user input of To
				{
					actions 
					{
						custom deluge script
						(
											if(input.From != null && input.To != null)
										{
											if(input.Type_field == "Half Day")
											{
												if(input.From.equals(input.To))
												{
													input.Total_Days = 0.5;
												}
												else
												{
													alert "Half Day leave can only be applied for a single day.";
													input.To = null;
													input.Total_Days = null;
												}
												return;
											}
											if(input.Type_field == "Full Day")
											{
												sd = input.From;
												ed = input.To;
												total = sd.daysBetween(ed) + 1;
												rem = total % 7;
												full_weeks = (total - rem) / 7;
												weekend_days = full_weeks * 2;
												if(rem > 0)
												{
													start_dow = sd.getDayOfWeek();
													delta_sun = (8 - start_dow) % 7;
													delta_sat = (7 - start_dow) % 7;
													if(delta_sun < rem)
													{
														weekend_days = weekend_days + 1;
													}
													if(delta_sat < rem)
													{
														weekend_days = weekend_days + 1;
													}
												}
												weekdays = total - weekend_days;
												input.Total_Days = weekdays;
												return;
											}
											input.Total_Days = null;
										}
						)
					}
				}

			}
			Create_Record_In_CRM as "Create Record In CRM"
			{
				type =  form
				form = Liquidation_Agent

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											agent = Map();
										agent.put("Name",input.Liquidation_Agent_Name);
										agent.put("Email",input.Email);
										agent.put("Contact_Number",input.Contact_Number);
										agent.put("Region",input.Region);
										// agent.put("Taluka",input.Market);
										// agent.put("Territory_name",input.Territory1.Territory_Name);
										agent.put("Pan_Card_Number",input.Pan_Card_Number);
										agent.put("Aadhar_Card_Number",input.Aadhar_Card_Number);
										agent.put("Address_Line_1",input.Street);
										agent.put("Country",input.Country);
										agent.put("City_District",input.City);
										agent.put("State_Province",input.State);
										agent.put("Postal_Code",input.Zipcode);
										agent.put("Creator_record_Id",input.ID.toString());
										agent.put("Headquarter",input.Headquarter);
										other = Map();
										crmRecord = zoho.crm.createRecord("Liquidation_Agent_Master",agent,other,"zoho_oauth_connection");
										if(crmRecord.isEmpty() == false)
										{
											recordID = crmRecord.get("id");
											input.CRMID = recordID.toString();
											if(input.Upload_Aadhar_Card.isNull() == false)
											{
												attachmentResp = zoho.crm.attachFile("Liquidation_Agent_Master",recordID.toLong(),input.Upload_Aadhar_Card,"zoho_oauth_connection");
											}
											if(input.Upload_Aadhar_Card.isNull() == false)
											{
												attachmentResp1 = zoho.crm.attachFile("Liquidation_Agent_Master",recordID.toLong(),input.Upload_Pan_Card,"zoho_oauth_connection");
											}
										}
						)
					}
				}

			}
